---
---

<section class="mx-auto w-full max-w-[1200px] px-6 py-12">
  <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
    
    <!-- Card 1: AI -->
    <div class="card-ai col-span-1 md:col-span-4 relative flex flex-col justify-between overflow-hidden rounded-[40px] pt-10 px-8 pb-0">
      <!-- Text -->
      <div class="relative z-10 flex flex-col items-end text-right mb-8">
        <span class="text-[10px] font-bold tracking-[0.2em] text-[#5c3e73] uppercase mb-1">Ayuda a los scouts</span>
        <h2 class="text-4xl font-bold text-[#5c3e73] font-gt tracking-tight">AI</h2>
      </div>
      
      <!-- Mockup UI -->
      <div class="ui-mockup relative w-[120%] -ml-[10%] bg-white rounded-t-[16px] shadow-2xl overflow-hidden mt-auto">
        <!-- Header -->
        <div class="bg-[#0b64a0] h-10 px-4 flex items-center gap-3">
          <div class="w-4 h-4 rounded-sm bg-white/20 flex-shrink-0"></div>
          <div class="h-2 w-10 bg-white/30 rounded-full"></div>
          <div class="h-2 w-8 bg-white/30 rounded-full"></div>
          <div class="h-2 w-12 bg-white/30 rounded-full"></div>
          <div class="h-2 w-8 bg-white/30 rounded-full"></div>
        </div>
        <!-- Body -->
        <div class="p-5 h-[220px] bg-white flex flex-col gap-3">
          <div class="h-2 w-full bg-[#f3eaff] rounded-full"></div>
          <div class="h-2 w-3/4 bg-[#f3eaff] rounded-full mb-2"></div>
          
          <div class="border border-[#e7dbf5] rounded-xl p-4 shadow-sm relative">
            <div class="flex items-center gap-2 mb-4">
              <span class="text-xs font-bold text-[#8356ad]">AI Assist <span class="text-[#bba3d6] font-normal">✨ make longer</span></span>
            </div>
            <div class="h-2 w-full bg-[#f0f0f5] rounded-full mb-2"></div>
            <div class="h-2 w-full bg-[#f0f0f5] rounded-full mb-2"></div>
            <div class="h-2 w-5/6 bg-[#f0f0f5] rounded-full mb-4"></div>
            
            <div class="flex gap-2">
              <div class="h-6 w-12 border border-[#d2bbf1] rounded flex items-center justify-center">
                <div class="w-6 h-1 bg-[#d2bbf1] rounded-full"></div>
              </div>
              <div class="h-6 w-16 bg-[#8356ad] rounded flex items-center justify-center">
                <div class="w-8 h-1 bg-white rounded-full"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Card 2: Articulos -->
    <div class="card-articulos col-span-1 md:col-span-8 relative flex flex-col justify-between overflow-hidden rounded-[40px] pt-10 px-10 pb-0">
      <!-- Text -->
      <div class="relative z-10 flex flex-col items-end text-right mb-8">
        <span class="text-[10px] font-bold tracking-[0.2em] text-[#3a6355] uppercase mb-1">Ayuda a los scouts</span>
        <h2 class="text-4xl font-bold text-[#3a6355] font-gt tracking-tight">Artículos</h2>
      </div>
      
      <!-- Mockup UI -->
      <div class="ui-mockup relative w-[110%] -ml-[5%] bg-white rounded-t-[16px] shadow-2xl overflow-hidden mt-auto">
        <!-- Header -->
        <div class="bg-[#0b64a0] h-10 px-4 flex items-center gap-3">
          <div class="w-4 h-4 rounded-sm bg-white/20 flex-shrink-0"></div>
          <div class="h-2 w-10 bg-white/30 rounded-full"></div>
          <div class="h-2 w-12 bg-white/30 rounded-full"></div>
          <div class="h-2 w-8 bg-white/30 rounded-full"></div>
          <div class="h-2 w-10 bg-white/30 rounded-full"></div>
          <div class="h-2 w-12 bg-white/30 rounded-full"></div>
          <div class="h-2 w-8 bg-white/30 rounded-full"></div>
        </div>
        <!-- Body -->
        <div class="p-6 h-[260px] bg-white flex flex-col">
          <!-- Toolbar -->
          <div class="flex justify-between items-center mb-6">
            <div class="w-4 h-4 border-t-2 border-l-2 border-[#a0aab2] transform -rotate-45"></div>
            <div class="flex gap-2">
              <div class="px-4 py-1.5 border border-[#e2e8f0] rounded text-[10px] font-bold text-[#64748b]">Preview</div>
              <div class="px-4 py-1.5 bg-[#0ea5e9] rounded text-[10px] font-bold text-white flex items-center gap-2">
                Update <span class="text-white/70 text-[8px]">▼</span>
              </div>
            </div>
          </div>
          
          <!-- Content -->
          <div class="mb-4">
            <span class="px-3 py-1 border border-[#64c9a3] text-[#64c9a3] rounded-full text-[10px] font-bold">Published</span>
          </div>
          
          <h3 class="text-2xl font-bold text-[#1e293b] mb-6 font-gt">Where do you source your materials?</h3>
          
          <div class="flex flex-col gap-3">
            <div class="h-2 w-full bg-[#f1f5f9] rounded-full"></div>
            <div class="h-2 w-full bg-[#f1f5f9] rounded-full"></div>
            <div class="h-2 w-[90%] bg-[#f1f5f9] rounded-full"></div>
            <div class="h-2 w-[95%] bg-[#f1f5f9] rounded-full mt-2"></div>
            <div class="h-2 w-full bg-[#f1f5f9] rounded-full"></div>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .card-ai {
    background-color: #cd94eb;
  }
  
  .card-articulos {
    background-color: #aee2cd;
  }
</style>
