---
import BentoCard from './BentoCard.astro';
---

<section class="mx-auto w-full max-w-[1200px] px-6 py-12">
  <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
    
    <!-- Card 1: AI -->
    <BentoCard 
      href="#"
      class="card-ai col-span-1 md:col-span-4 px-8"
      subtitle="Ayuda a los scouts"
      title="AI"
      textColor="text-[#5c3e73]"
      imageAlt="AI Mockup"
    />

    <!-- Card 2: Artículos -->
    <BentoCard 
      href="#"
      class="card-articulos col-span-1 md:col-span-8 px-10"
      subtitle="Ayuda a los scouts"
      title="Artículos"
      textColor="text-[#3a6355]"
      imageAlt="Artículos Mockup"
    />

    <!-- Card 3: Figma Plugins -->
    <BentoCard 
      href="#"
      class="card-plugins col-span-1 md:col-span-8 px-10"
      subtitle="Figma"
      title="Plugins"
      textColor="text-[#5e4b3c]"
      imageAlt="Plugins Mockup"
    />

    <!-- Card 4: Help Scout Mobile -->
    <BentoCard 
      href="#"
      class="card-mobile col-span-1 md:col-span-4 px-8"
      subtitle="Help Scout"
      title="Mobile"
      textColor="text-[#3e5366]"
      imageAlt="Mobile Mockup"
    />

  </div>
</section>

<style>
  .card-ai {
    background-color: #cd94eb;
  }
  
  .card-articulos {
    background-color: #aee2cd;
  }
  
  .card-plugins {
    background-color: #e3bc9b;
  }
  
  .card-mobile {
    background-color: #bce1fb;
  }
</style>
