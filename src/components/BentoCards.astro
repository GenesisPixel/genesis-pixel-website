---
import BentoCard from './BentoCard.astro';

const { variant = 'default' } = Astro.props;
const isEqual = variant === 'equal';

const iconPool = ['svg-1.png', 'svg-2.png', 'svg-3.png', 'svg-4.png', 'svg-5.png', 'svg-6.png', 'svg-7.png', 'svg-8.png', 'svg-9.png', 'svg-10.png', 'svg-11.png'];

function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

const shuffled = shuffle(iconPool);
const icons = [];
// Generate enough icons for all cards (12 total)
for (let i = 0; i < 12; i++) {
  icons.push(shuffled[i % shuffled.length]);
}
---

<section class="mx-auto w-full max-w-[1200px] px-6 py-12">
  <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
    
    <!-- Card 1: Transitions -->
    <div class:list={['col-span-1 relative group transition-transform duration-300 hover:-translate-y-[6px]', isEqual ? 'md:col-span-6' : 'md:col-span-4']}>
      <span style="position: absolute; top: 3px; right: 3px; background: #9FA6FF; color: var(--color-bg); font-size: 17px; padding: 2px 8px; border-radius: 0; font-weight: 100; transform: rotate(10deg); font-family: var(--font-afronaut, system-ui, sans-serif); z-index: 30;">Principiante</span>
      <div class="absolute inset-0 z-20 pointer-events-none">
        <img src={`/svg/${icons[0]}`} alt="Icon" class="absolute -top-[46px] left-4 w-20 h-20 bento-icon" />
      </div>
      <BentoCard 
        href="/transitions/que-son"
        class="bg-[#cd94eb] px-8"
        subtitle="Capítulo 1"
        title="Transitions"
        textColor="text-[#5c3e73]"
        imageSrc="/img/card-1.jpg"
        imageAlt="Transitions Mockup"
      />
    </div>

    <!-- Card 2: Transform -->
    <div class:list={['col-span-1 relative group transition-transform duration-300 hover:-translate-y-[6px]', isEqual ? 'md:col-span-6' : 'md:col-span-8']}>
      <span style="position: absolute; top: 3px; right: 3px; background: #57B0FB; color: var(--color-bg); font-size: 17px; padding: 2px 8px; border-radius: 0; font-weight: 100; transform: rotate(10deg); font-family: var(--font-afronaut, system-ui, sans-serif); z-index: 30;">Intermedio</span>
      <div class="absolute inset-0 z-20 pointer-events-none">
        <img src={`/svg/${icons[1]}`} alt="Icon" class="absolute -top-[46px] left-8 w-20 h-20 bento-icon" />
        <img src={`/svg/${icons[2]}`} alt="Icon" class="absolute -top-[6px] left-1/3 w-20 h-20 bento-icon bento-icon-delay" />
      </div>
      <BentoCard 
        href="/transform/que-es"
        class="bg-[#aee2cd] px-10"
        subtitle="Capítulo 2"
        title="Transform"
        textColor="text-[#3a6355]"
        imageSrc="/img/card-2.jpg"
        imageAlt="Transform Mockup"
      />
    </div>

    <!-- Card 3: Keyframes -->
    <div class:list={['col-span-1 relative group transition-transform duration-300 hover:-translate-y-[6px]', isEqual ? 'md:col-span-6' : 'md:col-span-8']}>
      <span style="position: absolute; top: 3px; right: 3px; background: #6e56cf; color: white; font-size: 17px; padding: 2px 8px; border-radius: 0; font-weight: 100; transform: rotate(10deg); font-family: var(--font-afronaut, system-ui, sans-serif); z-index: 30;">Avanzado</span>
      <div class="absolute inset-0 z-20 pointer-events-none">
        <img src={`/svg/${icons[3]}`} alt="Icon" class="absolute -top-[46px] left-8 w-20 h-20 bento-icon" />
        <img src={`/svg/${icons[4]}`} alt="Icon" class="absolute -top-[14px] left-1/3 w-20 h-20 bento-icon bento-icon-delay" />
      </div>
      <BentoCard 
        href="/keyframes/que-son"
        class="bg-[#e3bc9b] px-10"
        subtitle="Capítulo 3"
        title="Keyframes"
        textColor="text-[#5e4b3c]"
        imageSrc="/img/card-3.jpg"
        imageAlt="Keyframes Mockup"
      />
    </div>

    <!-- Card 4: Interacciones -->
    <div class:list={['col-span-1 relative group transition-transform duration-300 hover:-translate-y-[6px]', isEqual ? 'md:col-span-6' : 'md:col-span-4']}>
      <span style="position: absolute; top: 3px; right: 3px; background: #FC5D7D; color: white; font-size: 17px; padding: 2px 8px; border-radius: 0; font-weight: 100; transform: rotate(10deg); font-family: var(--font-afronaut, system-ui, sans-serif); z-index: 30;">Avanzado</span>
      <div class="absolute inset-0 z-20 pointer-events-none">
        <img src={`/svg/${icons[5]}`} alt="Icon" class="absolute -top-[46px] left-4 w-20 h-20 bento-icon" />
      </div>
      <BentoCard 
        href="/interactions/que-son"
        class="bg-[#bce1fb] px-8"
        subtitle="Capítulo 4"
        title="Interacciones"
        textColor="text-[#3e5366]"
        imageSrc="/img/card-4.jpg"
        imageAlt="Interacciones Mockup"
      />
    </div>

  </div>

</section>

<!-- Sección Avanzado -->
<section class="mx-auto w-full max-w-[1200px] px-6 py-12">
  <h1 class="font-afronaut font-light text-[var(--color-text)] text-center mb-8" style="line-height: 0.85; letter-spacing: -0.05em; font-family: var(--font-afronaut);">Capítulos Avanzados</h1>
  
  <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
    
    <!-- Card 1: Three.js -->
    <div class:list={['col-span-1 relative group transition-transform duration-300 hover:-translate-y-[6px]', isEqual ? 'md:col-span-6' : 'md:col-span-4']}>
      <span style="position: absolute; top: 3px; right: 3px; background: #57B0FB; color: var(--color-bg); font-size: 17px; padding: 2px 8px; border-radius: 0; font-weight: 100; transform: rotate(10deg); font-family: var(--font-afronaut, system-ui, sans-serif); z-index: 30;">Avanzado</span>
      <div class="absolute inset-0 z-20 pointer-events-none">
        <img src={`/svg/${icons[6]}`} alt="Icon" class="absolute -top-[46px] left-4 w-20 h-20 bento-icon" />
      </div>
      <BentoCard 
        href="/threejs/que-es-threejs"
        class="bg-[var(--app-color-yellow300)] px-8"
        subtitle="Capítulo 5"
        title="Three.js"
        textColor="text-[#6b5220]"
        imageSrc="/img/card-5.jpg"
        imageAlt="Three.js Mockup"
      />
    </div>

    <!-- Card 2: Shaders -->
    <div class:list={['col-span-1 relative group transition-transform duration-300 hover:-translate-y-[6px]', isEqual ? 'md:col-span-6' : 'md:col-span-8']}>
      <span style="position: absolute; top: 3px; right: 3px; background: #9FA6FF; color: var(--color-bg); font-size: 17px; padding: 2px 8px; border-radius: 0; font-weight: 100; transform: rotate(10deg); font-family: var(--font-afronaut, system-ui, sans-serif); z-index: 30;">Avanzado</span>
      <div class="absolute inset-0 z-20 pointer-events-none">
        <img src={`/svg/${icons[7]}`} alt="Icon" class="absolute -top-[46px] left-8 w-20 h-20 bento-icon" />
        <img src={`/svg/${icons[8]}`} alt="Icon" class="absolute -top-[6px] left-1/3 w-20 h-20 bento-icon bento-icon-delay" />
      </div>
      <BentoCard 
        href="/shaders/que-son-los-shaders"
