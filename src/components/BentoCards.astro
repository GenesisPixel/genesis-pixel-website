        textColor="text-[#3a5a7a]"
        imageSrc="/img/card-6.jpg"
        imageAlt="Shaders Mockup"
      />
    </div>

    <!-- Card 3: Muy Pronto -->
    <div class:list={['col-span-1 relative group transition-transform duration-300 hover:-translate-y-[6px] opacity-70', isEqual ? 'md:col-span-6' : 'md:col-span-8']}>
      <span style="position: absolute; top: 3px; right: 3px; background: #FC5D7D; color: white; font-size: 17px; padding: 2px 8px; border-radius: 0; font-weight: 100; transform: rotate(10deg); font-family: var(--font-afronaut, system-ui, sans-serif); z-index: 30;">Muy Pronto</span>
      <div class="absolute inset-0 z-20 pointer-events-none">
        <img src={`/svg/${icons[9]}`} alt="Icon" class="absolute -top-[46px] left-8 w-20 h-20 bento-icon" />
        <img src={`/svg/${icons[10]}`} alt="Icon" class="absolute -top-[14px] left-1/3 w-20 h-20 bento-icon bento-icon-delay" />
      </div>
      <BentoCard 
        href="javascript:void(0)"
        class="bg-[#1a1a1a] px-10"
        subtitle="Próximamente"
        title="WebGL"
        textColor="text-white"
        imageSrc="/img/card-7.jpg"
        imageAlt="WebGL Mockup"
        cursor="not-allowed"
      />
    </div>

    <!-- Card 4: Muy Pronto -->
    <div class:list={['col-span-1 relative group transition-transform duration-300 hover:-translate-y-[6px] opacity-70', isEqual ? 'md:col-span-6' : 'md:col-span-4']}>
      <span style="position: absolute; top: 3px; right: 3px; background: #FDD88E; color: var(--color-bg); font-size: 17px; padding: 2px 8px; border-radius: 0; font-weight: 100; transform: rotate(10deg); font-family: var(--font-afronaut, system-ui, sans-serif); z-index: 30;">Muy Pronto</span>
      <div class="absolute inset-0 z-20 pointer-events-none">
        <img src={`/svg/${icons[11]}`} alt="Icon" class="absolute -top-[46px] left-4 w-20 h-20 bento-icon" />
      </div>
      <BentoCard 
        href="javascript:void(0)"
        class="bg-white px-8"
        subtitle="Próximamente"
        title="Canvas"
        textColor="text-[#1a1a1a]"
        imageSrc="/img/card-8.jpg"
        imageAlt="Canvas Mockup"
        cursor="not-allowed"
      />
    </div>

  </div>
</section>

<style>
  .bento-icon {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.5s cubic-bezier(0.34, 1.56, 0.64, 1),
                transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .group:hover .bento-icon {
    opacity: 1;
    transform: translateY(0px);
  }
  .bento-icon-delay {
    transition-delay: 75ms;
  }
</style>
