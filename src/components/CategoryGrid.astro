---
import { categories } from '../data/categories';

interface Props {
  showAll?: boolean;
}

const { showAll = true } = Astro.props;

const displayCategories = showAll ? categories : categories.slice(0, 6);

const colorMap: Record<string, string> = {
  blue: 'from-[var(--app-color-blue500)]/20 to-[var(--app-color-blue600)]/5 border-[var(--app-color-blue500)]/20',
  green: 'from-[var(--app-color-green500)]/20 to-[var(--app-color-green600)]/5 border-[var(--app-color-green500)]/20',
  yellow: 'from-[var(--app-color-yellow500)]/20 to-[var(--app-color-yellow600)]/5 border-[var(--app-color-yellow500)]/20',
  purple: 'from-[var(--dm-purple)]/20 to-[var(--dm-purple)]/5 border-[var(--dm-purple)]/20',
  charcoal: 'from-[var(--app-color-charcoal500)]/20 to-[var(--app-color-charcoal600)]/5 border-[var(--app-color-charcoal500)]/20',
  indigo: 'from-[var(--dm-indigo)]/20 to-[var(--dm-indigo)]/5 border-[var(--dm-indigo)]/20',
};

const iconMap: Record<string, string> = {
  css: 'M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z',
  svg: 'M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z',
  canvas: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
  threejs: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4',
  gsap: 'M13 10V3L4 14h7v7l9-11h-7z',
  webgl: 'M14 10l-2 1m0 0l-2-1m2 1v2.5M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4',
};
---

<div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
  {displayCategories.map((category) => (
    <a
      href={`/aprender/${category.id}`}
      class={`group relative overflow-hidden rounded-[var(--radius-base)] border bg-gradient-to-br p-6 transition-all hover:scale-[1.02] ${colorMap[category.color]}`}
    >
      <div class="flex items-start justify-between">
        <div class="flex h-10 w-10 items-center justify-center rounded-[var(--doodler-radius-md)] bg-white/10">
          <svg class="h-5 w-5 text-[var(--color-text)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={iconMap[category.icon]} />
          </svg>
        </div>
        <span class="text-sm text-[var(--dm-light-300)]">{category.lessonsCount} lecciones</span>
      </div>

      <h3 class="mt-4 text-lg font-semibold text-[var(--color-text)]">{category.title}</h3>

      <p class="mt-2 text-sm text-[var(--dm-light-300)] line-clamp-2">{category.description}</p>

      <div class="mt-4 flex items-center text-sm text-[var(--color-text)] opacity-0 transition-opacity group-hover:opacity-100">
        <span>Explorar</span>
        <svg class="ml-1 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </div>
    </a>
  ))}
</div>
