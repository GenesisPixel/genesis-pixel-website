---
import SectionTitle from './SectionTitle.astro';

interface Props {
  chapterNumber: string;
  chapterLabel: string;
  title: string;
  readingTime: number;
  difficulty?: string;
  author?: string;
}

const { chapterNumber, chapterLabel, title, readingTime, difficulty = 'CSS Animation', author = 'Genesis Pixel' } = Astro.props;
---

<div class="mb-8 flex flex-col items-center text-center">
  <div class="inline-flex items-center gap-2 text-sm text-[var(--dm-light-300)]">
    <span class="flex h-6 w-6 items-center justify-center rounded-md bg-[var(--color-text)]/10 text-xs font-semibold text-[var(--color-text)]">{chapterNumber}</span>
    {chapterLabel}
  </div>
  <SectionTitle title={title} />
  <div class="mt-6 flex flex-wrap justify-center gap-6">
    <div class="flex flex-col">
      <h5 class="text-xs font-medium text-[var(--color-text)]">Tiempo de lectura</h5>
      <p class="mt-1 text-sm font-light text-white">{readingTime} min</p>
    </div>
    <div class="flex flex-col">
      <h5 class="text-xs font-medium text-[var(--color-text)]">Escrito por</h5>
      <div class="mt-1 flex items-center gap-2">
        <a href="#" class="h-[30px] w-[30px] rounded-full bg-[var(--dm-blue)]"></a>
        <span class="text-sm font-light text-white">{author}</span>
      </div>
    </div>
    <div class="flex flex-col">
      <h5 class="text-xs font-medium text-[var(--color-text)]">Tema</h5>
      <p class="mt-1 text-sm font-light text-white">{difficulty}</p>
    </div>
  </div>
</div>
