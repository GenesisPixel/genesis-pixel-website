---
import SectionTitle from './SectionTitle.astro';

interface Props {
  chapterNumber: string;
  chapterLabel: string;
  title: string;
  readingTime: number;
  difficulty?: string;
  author?: string;
}

const { chapterNumber, chapterLabel, title, readingTime, difficulty = '', author = 'Sebastian V.' } = Astro.props;

// Extract lesson number from chapterLabel (e.g. "Capítulo 1 · Lección 3" → 3)
const lessonMatch = chapterLabel.match(/Lección (\d+)/);
const isProyectoFinal = chapterLabel.includes('Proyecto Final');
const lessonNumber = isProyectoFinal ? 20 : (lessonMatch ? parseInt(lessonMatch[1]) : 1);

// Base dates per topic (month is 0-indexed in JS)
const baseDates = {
  '@keyframes': new Date(2025, 3, 2),     // 02/04/2025
  'CSS Transform': new Date(2024, 5, 23),  // 23/06/2024
  'Interactions': new Date(2025, 6, 1),    // 01/07/2025
  'Three.js': new Date(2026, 0, 13),       // 13/01/2026
  'Shaders GLSL': new Date(2026, 2, 21),   // 21/03/2026
};

// Advance days per topic
const advanceDays = {
  'Three.js': 4,
  'Shaders GLSL': 4,
};

// Transitions default base date
const baseDate = baseDates[difficulty] || new Date(2024, 2, 19); // 19/03/2024
const daysToAdvance = advanceDays[difficulty] || 2;

// Advance days per lesson
baseDate.setDate(baseDate.getDate() + (lessonNumber - 1) * daysToAdvance);

const publishedDate = `${String(baseDate.getDate()).padStart(2, '0')}/${String(baseDate.getMonth() + 1).padStart(2, '0')}/${baseDate.getFullYear()}`;
---

<div class="mb-16" style="margin-bottom: 120px;">
  <div class="flex flex-col items-center text-center" style="perspective: 800px;">
    <div class="inline-flex items-center gap-2 text-sm text-[var(--dm-light-300)]">
      <span class="flex h-6 w-6 items-center justify-center rounded-md bg-[var(--color-text)]/10 text-xs font-semibold text-[var(--color-text)]">{chapterNumber}</span>
      {chapterLabel}
    </div>
    <SectionTitle title={title} />
  </div>
  <div class="mt-8 mb-5 grid grid-cols-2 gap-6 sm:flex sm:flex-wrap sm:justify-center sm:gap-10">
    <div class="flex flex-col">
      <h5 class="text-xs font-medium text-[var(--color-text)]">Redactado por</h5>
      <a href="https://sebas-dev.vercel.app/" target="_blank" class="mt-1 flex items-center gap-2">
        <img src="/img/face.jpg" alt="Author" class="h-[30px] w-[30px] rounded-full object-cover" />
        <span class="text-sm font-light italic text-white">{author}</span>
      </a>
    </div>
    <div class="flex flex-col">
      <h5 class="text-xs font-medium text-[var(--color-text)]">Fecha de publicación</h5>
      <p class="mt-1 text-sm font-light italic text-white">{publishedDate}</p>
    </div>
    <div class="flex flex-col">
      <h5 class="text-xs font-medium text-[var(--color-text)]">Tiempo de lectura</h5>
      <p class="mt-1 text-sm font-light italic text-white">{readingTime} min</p>
    </div>
    <div class="flex flex-col">
      <h5 class="text-xs font-medium text-[var(--color-text)]">Tema</h5>
      <p class="mt-1 text-sm font-light italic text-white">{difficulty}</p>
    </div>
  </div>
</div>
