---
interface Props {
  errors: { label: string; description: string }[];
}

const { errors } = Astro.props;
---

<div class="py-6 overflow-hidden">
  <h3 class="mb-6 font-medium text-[var(--color-text)] text-lg">
    Errores Comunes
  </h3>
  <div class="flex flex-col gap-4">
    {errors.map((error, index) => (
      <div class="block w-full">
        <div 
          class="w-fit max-w-[90%] rounded-[20px] bg-[var(--color-text)] p-5 text-[var(--color-bg)] shadow-md transition-transform hover:-translate-y-1"
          style={`transform: translateX(${index * 20}px);`}
        >
          <p class="m-0 text-[15px] font-medium">
            <span class="mr-1 font-bold text-[16px]">{error.label}:</span>
            {error.description}
          </p>
        </div>
      </div>
    ))}
  </div>
</div>
