---
interface Props {
  errors: { label: string; description: string }[];
}

const { errors } = Astro.props;
---

<div class="py-6">
  <p class="mb-6 font-afronaut text-2xl text-[var(--color-text)]" style="font-size: 1.75rem; line-height: 1.1; letter-spacing: -0.02em; opacity: 1 !important;">
    Errores Comunes
  </p>
  <div class="flex flex-col gap-5">
    {errors.slice(0, 4).map((error, index) => (
      <div class="flex gap-4">
        <span class="mt-0.5 shrink-0 font-afronaut text-[13px] text-[var(--color-text)] opacity-40" style="opacity: 0.4 !important;">
          {String(index + 1).padStart(2, '0')}
        </span>
        <div class="flex flex-col gap-1">
          <span class="text-[14px] font-semibold text-white" style="color: white; opacity: 1 !important;">
            {error.label}
          </span>
          <span class="text-[13px] leading-relaxed text-[var(--dm-light-200)]">
            {error.description}
          </span>
        </div>
      </div>
    ))}
  </div>
</div>
