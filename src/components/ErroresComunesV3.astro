---
interface Props {
  errors: { label: string; description: string }[];
}

const { errors } = Astro.props;
---

<div class="py-6">
  <h3 class="mb-4 font-medium text-[var(--color-text)]">
    Errores Comunes
  </h3>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-6">
    {errors.slice(0, 8).map((error, index) => (
      <div class="flex gap-4">
        <span class="mt-0.5 shrink-0 font-afronaut text-[13px] text-[var(--color-text)] opacity-40" style="opacity: 0.4 !important;">
          {String(index + 1).padStart(2, '0')}
        </span>
        <div class="flex flex-col gap-1">
          <span class="text-[14px] font-semibold text-white" style="color: white; opacity: 1 !important;">
            {error.label}
          </span>
          <span class="text-[13px] leading-relaxed text-[var(--dm-light-200)]">
            {error.description}
          </span>
        </div>
      </div>
    ))}
  </div>
</div>
