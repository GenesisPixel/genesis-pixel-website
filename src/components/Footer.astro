---
const currentYear = new Date().getFullYear();

const footerLinks = [
  {
    title: 'Plataforma',
    links: [
      { label: 'Aprender', href: '/aprender' },
      { label: 'Proyectos', href: '/proyectos' },
      { label: 'Proyectos', href: '/proyectos' },
      { label: 'Recursos', href: '/recursos' },
    ],
  },
  {
    title: 'Animaciones',
    links: [
      { label: 'CSS Animations', href: '/aprender/css' },
      { label: 'SVG', href: '/aprender/svg' },
      { label: 'Canvas', href: '/aprender/canvas' },
      { label: 'Three.js', href: '/aprender/threejs' },
    ],
  },
  {
    title: 'Comunidad',
    links: [
      { label: 'GitHub', href: 'https://github.com', external: true },
      { label: 'Discord', href: '#', external: true },
      { label: 'Twitter', href: '#', external: true },
    ],
  },
];
---

<footer class="relative mx-auto mt-12 max-w-7xl px-6 pb-6">

  <div class="relative overflow-hidden rounded-[40px] bg-white/[0.02] px-10 py-16 backdrop-blur-md md:px-16 md:py-20">
    
    <div class="relative z-10 grid grid-cols-1 gap-12 md:grid-cols-12 md:gap-8">
      
      <!-- Logo y Descripción -->
      <div class="md:col-span-5 lg:col-span-4">
        <a href="/" class="font-afronaut text-3xl font-light text-[var(--color-text)] transition-opacity hover:opacity-80">
          GenesisPixel
        </a>
        <p class="mt-6 max-w-sm text-[15px] leading-relaxed text-[var(--dm-light-200)]">
          Domina el arte de las animaciones web y el desarrollo creativo paso a paso. Desde los fundamentos de CSS hasta experiencias interactivas en 3D.
        </p>
        
        <div class="mt-8 flex gap-4">
          <a href="#" class="group flex h-10 w-10 items-center justify-center rounded-full bg-white/5 text-[var(--color-text)] transition-all hover:scale-110 hover:bg-[var(--color-text)] hover:text-[var(--dm-dark-500)]">
            <span class="sr-only">GitHub</span>
            <svg class="h-5 w-5 transition-transform group-hover:-rotate-12" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
          <a href="#" class="group flex h-10 w-10 items-center justify-center rounded-full bg-white/5 text-[var(--color-text)] transition-all hover:scale-110 hover:bg-[var(--color-text)] hover:text-[var(--dm-dark-500)]">
            <span class="sr-only">Twitter</span>
            <svg class="h-5 w-5 transition-transform group-hover:rotate-12" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Enlaces Grid -->
      <div class="md:col-span-7 lg:col-span-8">
        <div class="grid grid-cols-2 gap-8 sm:grid-cols-3">
          {footerLinks.map((group) => (
            <div class="flex flex-col gap-6">
              <h3 class="font-afronaut text-sm uppercase tracking-wider text-white/50">{group.title}</h3>
              <ul class="flex flex-col gap-4">
                {group.links.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      class="inline-block text-[15px] font-medium text-[var(--dm-light-300)] transition-all duration-300 hover:-translate-y-0.5 hover:text-[var(--color-text)]"
                      {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                    >
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Inferior -->
    <div class="relative z-10 mt-16 flex flex-col items-center justify-between gap-6 border-t border-white/10 pt-8 sm:flex-row">
      <p class="text-[13px] text-white/40">
        &copy; {currentYear} GenesisPixel. Todos los derechos reservados.
      </p>
      <div class="flex gap-6 text-[13px] text-white/40">
        <a href="#" class="transition-colors hover:text-white">Términos</a>
        <a href="#" class="transition-colors hover:text-white">Privacidad</a>
      </div>
    </div>
    
  </div>
</footer>
