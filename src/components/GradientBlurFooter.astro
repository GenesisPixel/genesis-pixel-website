---
<div class="gradient-blur-footer-container" id="footer-gradient-container">
  <div class="content--canvas gradient-blur-wrapper"></div>
  <div class="gradient-overlay"></div>
</div>

<script is:inline src="/js/noise.min.js"></script>
<script is:inline src="/js/util.js"></script>
<script is:inline src="/js/shift.js"></script>

<script>
  function initFooterGradient() {
    // We need to temporarily make the footer container the only '.content--canvas' 
    // because shift.js uses document.querySelector('.content--canvas')
    const heroCanvas = document.querySelector('.gradient-blur-container .content--canvas');
    if (heroCanvas) heroCanvas.style.display = 'none';

    if (typeof setup === 'function') {
      setup();
    }

    if (heroCanvas) heroCanvas.style.display = 'block';
  }

  document.addEventListener('astro:page-load', initFooterGradient);
  // Also call it immediately in case it's already loaded
  initFooterGradient();
</script>

<style>
  .gradient-blur-footer-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
    overflow: hidden;
  }

  .gradient-blur-wrapper {
    width: 100%;
    height: 100%;
  }

  .gradient-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, transparent 0%, hsla(160, 23%, 18%, 0.3) 50%, var(--color-bg) 100%);
    z-index: 5;
  }

  :global(.content--canvas canvas) {
    position: absolute !important;
    top: 0;
    left: 0;
    width: 100% !important;
    height: 100% !important;
    object-fit: cover;
    z-index: 1;
  }
</style>
