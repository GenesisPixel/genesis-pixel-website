---
---

<div class="gradient-blur-footer-container" id="footer-gradient-container">
  <div class="footer-canvas-wrapper"></div>
  <div class="gradient-overlay"></div>
</div>

<script is:inline>
  function initFooterGradient() {
    const container = document.getElementById('footer-gradient-container');
    const wrapper = container?.querySelector('.footer-canvas-wrapper');
    if (!wrapper) return;

    // Remove any existing canvas
    const existing = wrapper.querySelector('canvas');
    if (existing) existing.remove();

    // Create visible canvas
    const canvasB = document.createElement('canvas');
    canvasB.style.cssText = 'position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: block;';
    wrapper.appendChild(canvasB);

    // Offscreen canvas for fresh particles
    const canvasA = document.createElement('canvas');
    
    const ctxA = canvasA.getContext('2d');
    const ctxB = canvasB.getContext('2d');
    
    let animationId;
    let hue = 220;
    const particles = [];
    const particleCount = 140;

    function resize() {
      const rect = container.getBoundingClientRect();
      const dpr = window.devicePixelRatio || 1;
      const w = Math.round(rect.width * dpr);
      const h = Math.round(rect.height * dpr);
      
      canvasA.width = w;
      canvasA.height = h;
      canvasB.width = w;
      canvasB.height = h;
      canvasB.style.width = rect.width + 'px';
      canvasB.style.height = rect.height + 'px';
      
      ctxA.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctxB.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    function createParticle() {
      const rect = container.getBoundingClientRect();
      return {
        x: Math.random() * rect.width,
        y: Math.random() * rect.height,
        vx: (Math.random() - 0.5) * 0.5,
        vy: (Math.random() - 0.5) * 0.5,
        radius: 30 + Math.random() * 120,
        hue: hue + (Math.random() - 0.5) * 60,
        life: 0,
        ttl: 100 + Math.random() * 200,
        alpha: 0
      };
    }

    for (let i = 0; i < particleCount; i++) {
      particles.push(createParticle());
    }

    function draw() {
      const rect = container.getBoundingClientRect();
      const w = rect.width;
      const h = rect.height;

      // Draw fresh particles on offscreen canvas
      ctxA.clearRect(0, 0, w, h);
      ctxA.globalCompositeOperation = 'screen';
      hue++;

      for (const p of particles) {
        p.x += p.vx;
        p.y += p.vy;
        p.life++;
        p.alpha = Math.min(p.life / 30, 1) * Math.max(1 - p.life / p.ttl, 0);

        if (p.life > p.ttl || p.x < -p.radius || p.x > w + p.radius || p.y < -p.radius || p.y > h + p.radius) {
          Object.assign(p, createParticle());
        }

        if (p.alpha > 0) {
          ctxA.beginPath();
          ctxA.arc(p.x, p.y, p.radius * (1 - p.life / p.ttl * 0.5), 0, Math.PI * 2);
          ctxA.fillStyle = `hsla(${p.hue}, 60%, 30%, ${p.alpha * 0.15})`;
          ctxA.fill();
        }
      }

      // Blur offscreen canvas onto visible canvas (double buffer like shift.js)
      ctxB.save();
      ctxB.filter = 'blur(50px)';
      ctxB.drawImage(canvasA, 0, 0);
      ctxB.restore();

      animationId = requestAnimationFrame(draw);
    }

    resize();
    draw();

    const resizeObserver = new ResizeObserver(() => resize());
    resizeObserver.observe(container);

    document.addEventListener('astro:before-swap', () => {
      if (animationId) cancelAnimationFrame(animationId);
      resizeObserver.disconnect();
    });
  }

  document.addEventListener('astro:page-load', initFooterGradient);
  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    initFooterGradient();
  }
</script>

<style>
  .gradient-blur-footer-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
    clip-path: inset(0 calc(50% - 450px));
  }

  .footer-canvas-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .gradient-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, transparent 0%, hsla(160, 23%, 18%, 0.3) 50%, var(--color-bg) 100%);
    z-index: 5;
  }
</style>
