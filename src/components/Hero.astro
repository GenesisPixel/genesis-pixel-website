---
interface Props {
  title: string;
  description: string;
  primaryCTA?: { label: string; href: string };
  secondaryCTA?: { label: string; href: string };
}

const { title, description, primaryCTA, secondaryCTA } = Astro.props;
---

<style>
  @keyframes gradient-move {
    0% {
      top: 0%;
    }
    80% {
      top: 0%;
    }
    100% {
      top: -130%;
    }
  }

  .hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 50%;
    background: var(--color-gradient);
    animation: gradient-move 10s ease-in-out infinite;
  }
</style>

<section class="relative flex min-h-[80vh] items-center justify-center overflow-hidden px-6 pt-16">
  <div class="hero-bg"></div>

  <div class="relative z-10 mx-auto max-w-4xl text-center">
    <h1 class="font-acorn text-5xl font-bold leading-tight tracking-tight text-[var(--color-text)] sm:text-7xl">
      {title}
    </h1>

    <p class="mx-auto mt-6 max-w-2xl text-lg text-[var(--dm-light-200)] sm:text-xl">
      {description}
    </p>

    <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
      {primaryCTA && (
        <a
          href={primaryCTA.href}
          class="inline-flex items-center justify-center rounded-[var(--radius-base)] bg-[var(--color-text)] px-6 py-3 text-sm font-semibold text-[var(--dm-dark-500)] transition-all hover:opacity-90"
        >
          {primaryCTA.label}
          <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      )}

      {secondaryCTA && (
        <a
          href={secondaryCTA.href}
          class="inline-flex items-center justify-center rounded-[var(--radius-base)] border border-white/10 bg-white/5 px-6 py-3 text-sm font-semibold text-[var(--color-text)] transition-all hover:bg-white/10"
        >
          {secondaryCTA.label}
        </a>
      )}
    </div>

    <div class="mt-16 flex items-center justify-center gap-8 text-sm text-[var(--dm-light-300)]">
      <div class="flex items-center gap-2">
        <svg class="h-5 w-5 text-[var(--dm-green)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        <span>76+ Lecciones</span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="h-5 w-5 text-[var(--dm-green)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        <span>Ejemplos Interactivos</span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="h-5 w-5 text-[var(--dm-green)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        <span>100% Gratuito</span>
      </div>
    </div>
  </div>
</section>
