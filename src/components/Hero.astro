---
interface Props {
  title: string;
  description: string;
  primaryCTA?: { label: string; href: string };
  secondaryCTA?: { label: string; href: string };
  tertiaryCTA?: { label: string; href: string };
}

const { title, description, primaryCTA, secondaryCTA, tertiaryCTA } = Astro.props;

const splitIndex = title.indexOf(' con ');
const firstLine = title.substring(0, splitIndex);
const secondLine = title.substring(splitIndex + 1);

const renderChars = (text) => text.split(' ').map(word => 
  `<span class="inline-block whitespace-nowrap">` +
  word.split('').map(char => `<span class="hero-char inline-block opacity-0">${char}</span>`).join('') +
  `</span>`
).join(' ');

const rot1 = Math.floor(Math.random() * 41) - 20;
const rot2 = Math.floor(Math.random() * 41) - 20;

const titleChars = renderChars(firstLine) + '<br/>' + renderChars(secondLine);
---

<style>
  @keyframes gradient-move {
    0% {
      top: 0%;
    }
    80% {
      top: 0%;
    }
    100% {
      top: -130%;
    }
  }

  .hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 50%;
    background: var(--color-gradient);
    animation: gradient-move 10s ease-in-out infinite;
  }

  @keyframes scaleIn {
    from {
      transform: scale(0);
      opacity: 0;
    }
    to {
      transform: scale(1);
      opacity: 1;
    }
  }

  .svg-animate {
    opacity: 0;
  }

  .svg-animate-delay {
    opacity: 0;
  }

  :global(.hero-char) {
    font-family: var(--font-afronaut) !important;
  }
</style>

<section class="relative flex  justify-center overflow-hidden px-6 pt-[160px] pb-[40px]">

  <div class="relative z-10 mx-auto max-w-4xl text-center">
    <div class="relative inline-block">
      <img src="/svg/svg-1.png" alt="" class="absolute -top-10 -right-12 w-[50px] sm:w-[90px] opacity-60 svg-animate" data-rotate={rot1} aria-hidden="true" />
      <img src="/svg/svg-2.png" alt="" class="absolute -bottom-4 w-[35px] sm:w-[55px] opacity-60 svg-animate-delay" style="left: 90px;" data-rotate={rot2} aria-hidden="true" />
      <h1 id="hero-title" class="font-afronaut font-light text-[var(--color-text)]" style="line-height: 0.85; letter-spacing: -0.05em; font-family: var(--font-afronaut);">
        <Fragment set:html={titleChars} />
      </h1>
    </div>
   
    <div class="mx-auto pt-[30px] max-w-[650px]">
      <span class=" font-normal! text-[20px] text-[var(--dm-light-200)] sm:text-xl">
        {description}
      </span>

    </div>


    
  </div>
</section>

<script>
  import gsap from 'gsap';

  document.addEventListener('astro:page-load', () => {
    const title = document.getElementById('hero-title');
    const chars = title?.querySelectorAll('.hero-char');
    const svgOrbit = document.querySelector('.svg-animate');
    const svgStar = document.querySelector('.svg-animate-delay');
    
    if (chars) {
      gsap.set(chars, { 
        opacity: 0, 
        y: 60, 
        rotateX: -40,
        scale: 0.9,
        filter: 'blur(10px)' 
      });
      
      gsap.to(chars, {
        opacity: 1,
        y: 0,
        rotateX: 0,
        scale: 1,
        filter: 'blur(0px)',
        duration: 0.9,
        stagger: {
          each: 0.025,
          from: 'start'
        },
        ease: 'power3.out',
        delay: 0.2
      });
    }

    if (svgOrbit) {
      const r1 = parseFloat(svgOrbit.dataset.rotate) || 0;
      gsap.set(svgOrbit, { opacity: 0, y: 40, filter: 'blur(10px)', rotate: r1 });
      gsap.to(svgOrbit, {
        opacity: 0.6,
        y: 0,
        filter: 'blur(0px)',
        rotate: r1,
        duration: 0.9,
        ease: 'power3.out',
        delay: 1.5
      });
    }

    if (svgStar) {
      const r2 = parseFloat(svgStar.dataset.rotate) || 0;
      gsap.set(svgStar, { opacity: 0, y: 40, filter: 'blur(10px)', rotate: r2 });
      gsap.to(svgStar, {
        opacity: 0.6,
        y: 0,
        filter: 'blur(0px)',
        rotate: r2,
        duration: 0.9,
        ease: 'power3.out',
        delay: 1.7
      });
    }
  });
</script>
