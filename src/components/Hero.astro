---
interface Props {
  title: string;
  description: string;
  primaryCTA?: { label: string; href: string };
  secondaryCTA?: { label: string; href: string };
  tertiaryCTA?: { label: string; href: string };
}

const { title, description, primaryCTA, secondaryCTA, tertiaryCTA } = Astro.props;

const splitIndex = title.indexOf(' con ');
const firstLine = title.substring(0, splitIndex);
const secondLine = title.substring(splitIndex + 1);

const renderChars = (text) => text.split(' ').map(word => 
  `<span class="inline-block whitespace-nowrap">` +
  word.split('').map(char => `<span class="hero-char inline-block opacity-0">${char}</span>`).join('') +
  `</span>`
).join(' ');

const titleChars = renderChars(firstLine) + '<br/>' + renderChars(secondLine);
---

<style>
  @keyframes gradient-move {
    0% {
      top: 0%;
    }
    80% {
      top: 0%;
    }
    100% {
      top: -130%;
    }
  }

  .hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 50%;
    background: var(--color-gradient);
    animation: gradient-move 10s ease-in-out infinite;
  }

  @keyframes scaleIn {
    from {
      transform: scale(0);
      opacity: 0;
    }
    to {
      transform: scale(1);
      opacity: 1;
    }
  }

  .svg-animate {
    opacity: 0;
  }

  .svg-animate-delay {
    opacity: 0;
  }

  :global(.hero-char) {
    font-family: var(--font-afronaut) !important;
  }
</style>

<section class="relative flex min-h-[80vh] items-center justify-center overflow-hidden px-6 pt-16">

  <div class="relative z-10 mx-auto max-w-4xl text-center">
    <div class="relative inline-block">
      <img src="/svg/stars-in-orbit.svg" alt="" class="absolute -top-10 -right-12 w-[90px] opacity-60 svg-animate" aria-hidden="true" />
      <img src="/svg/stars.svg" alt="" class="absolute -bottom-4 w-[55px] opacity-60 svg-animate-delay" style="left: 90px;" aria-hidden="true" />
      <h1 id="hero-title" class="font-afronaut font-light text-[var(--color-text)]" style="line-height: 0.85; letter-spacing: -0.05em; font-family: var(--font-afronaut);">
        <Fragment set:html={titleChars} />
      </h1>
    </div>

    <p class="mx-auto mt-6 max-w-2xl text-lg text-[var(--dm-light-200)] sm:text-xl">
      {description}
    </p>

    <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
      {primaryCTA && (
        <a
          href={primaryCTA.href}
          class="inline-flex items-center justify-center rounded-[30px] bg-[var(--color-text)] px-6 py-3 text-sm font-normal text-[var(--dm-dark-500)] transition-all hover:opacity-90"
        >
          {primaryCTA.label}
          <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      )}

      {secondaryCTA && (
        <a
          href={secondaryCTA.href}
          class="inline-flex items-center justify-center rounded-[30px] border border-white/10 bg-white/5 px-6 py-3 text-sm font-normal text-[var(--color-text)] transition-all hover:bg-white/10"
        >
          {secondaryCTA.label}
        </a>
      )}

      {tertiaryCTA && (
        <a
          href={tertiaryCTA.href}
          class="inline-flex items-center justify-center rounded-[30px] border border-white/10 bg-white/5 px-6 py-3 text-sm font-normal text-[var(--color-text)] transition-all hover:bg-white/10"
        >
          {tertiaryCTA.label}
          <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      )}
    </div>

    <div class="mt-16 flex items-center justify-center gap-8 text-sm text-[var(--dm-light-300)]">
      <div class="flex items-center gap-2">
        <svg class="h-5 w-5 text-[var(--dm-green)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        <span>76+ Lecciones</span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="h-5 w-5 text-[var(--dm-green)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        <span>Ejemplos Interactivos</span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="h-5 w-5 text-[var(--dm-green)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        <span>100% Gratuito</span>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  document.addEventListener('astro:page-load', () => {
    const title = document.getElementById('hero-title');
    const chars = title?.querySelectorAll('.hero-char');
    const svgOrbit = document.querySelector('.svg-animate');
    const svgStar = document.querySelector('.svg-animate-delay');
    
    if (chars) {
      gsap.set(chars, { 
        opacity: 0, 
        y: 60, 
        rotateX: -40,
        scale: 0.9,
        filter: 'blur(10px)' 
      });
      
      gsap.to(chars, {
        opacity: 1,
        y: 0,
        rotateX: 0,
        scale: 1,
        filter: 'blur(0px)',
        duration: 0.9,
        stagger: {
          each: 0.025,
          from: 'start'
        },
        ease: 'power3.out',
        delay: 0.2
      });
    }

    if (svgOrbit) {
      gsap.set(svgOrbit, { opacity: 0, y: 40, filter: 'blur(10px)' });
      gsap.to(svgOrbit, {
        opacity: 0.6,
        y: 0,
        filter: 'blur(0px)',
        duration: 0.9,
        ease: 'power3.out',
        delay: 1.5
      });
    }

    if (svgStar) {
      gsap.set(svgStar, { opacity: 0, y: 40, filter: 'blur(10px)' });
      gsap.to(svgStar, {
        opacity: 0.6,
        y: 0,
        filter: 'blur(0px)',
        duration: 0.9,
        ease: 'power3.out',
        delay: 1.7
      });
    }
  });
</script>
