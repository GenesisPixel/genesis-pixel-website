---
interface Props {
  title: string;
  description: string;
  level: string;
  duration: string;
  href: string;
}

const { title, description, level, duration, href } = Astro.props;

const levelColors = {
  basico: 'bg-[var(--dm-green)]/20 text-[var(--dm-green)]',
  intermedio: 'bg-[var(--dm-yellow)]/20 text-[var(--dm-yellow)]',
  avanzado: 'bg-[var(--dm-red)]/20 text-[var(--dm-red)]',
};
---

<a
  {href}
  class="group flex items-center gap-4 rounded-[var(--radius-base)] border border-white/5 bg-white/[0.02] p-4 transition-all hover:border-white/10 hover:bg-white/[0.04]"
>
  <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-[var(--doodler-radius-md)] bg-white/5 text-[var(--dm-light-200)] group-hover:bg-white/10">
    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
  </div>

  <div class="min-w-0 flex-1">
    <h4 class="text-sm font-medium text-[var(--color-text)] group-hover:text-white">{title}</h4>
    <p class="mt-0.5 truncate text-xs text-[var(--dm-light-300)]">{description}</p>
  </div>

  <div class="flex items-center gap-3">
    <span class={`inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium ${levelColors[level as keyof typeof levelColors]}`}>
      {level}
    </span>
    <span class="text-xs text-[var(--dm-light-300)]">{duration}</span>
  </div>
</a>
