---
const navItems = [
  { href: '/', label: 'Inicio' },
  { href: '/aprender', label: 'Aprender' },
  { href: '/keyframes/que-son', label: 'Keyframes' },
  { href: '/transitions/que-son', label: 'Transitions' },
  { href: '/transform/que-es', label: 'Transform' },
  { href: '/interactions/que-son', label: 'Interactions' },
  { href: '/threejs/que-es-threejs', label: 'Three.js' },
  { href: '/shaders/que-son-los-shaders', label: 'Shaders' },
];
---

<style>
  .nav-island {
    position: fixed;
    top: 16px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    border-radius: 9999px;
    background: rgba(28, 28, 30, 0.72);
    backdrop-filter: blur(40px) saturate(180%);
    -webkit-backdrop-filter: blur(40px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.06);
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.3),
      0 2px 8px rgba(0, 0, 0, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
    padding: 4px 12px;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .nav-brand {
    font-family: var(--font-afronaut);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    white-space: nowrap;
    padding: 6px 12px;
    transition: opacity 0.3s ease;
    position: relative;
    display: inline-flex;
    align-items: center;
  }

  .nav-brand:hover {
    opacity: 0.8;
  }

  @keyframes sacudir {
    0%, 60%, 100% { transform: rotate(10deg); }
    65% { transform: rotate(15deg); }
    70% { transform: rotate(10deg); }
    75% { transform: rotate(15deg); }
    80% { transform: rotate(10deg); }
  }

  .badge-nuevo {
    animation: sacudir 3s ease-in-out infinite;
  }

  .nav-brand-stars {
    position: absolute;
    top: -3px;
    right: 0px;
    width: 18px;
    height: 18px;
    opacity: 0.7;
  }

  .nav-divider {
    width: 1px;
    height: 20px;
    background: rgba(255, 255, 255, 0.1);
    flex-shrink: 0;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2px;
    position: relative;
  }

  .nav-links a {
    position: relative;
    padding: 6px 14px;
    padding-left: 31px;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--dm-light-300);
    text-decoration: none;
    border-radius: 9999px;
    transition: color 0.3s ease;
    white-space: nowrap;
    z-index: 1;
    opacity: 1 !important;
    display: inline-flex;
    align-items: center;
    gap: 2px;
  }

  .nav-links a:hover {
    color: white;
  }

  .nav-links a.active {
    color: white;
  }

  .nav-indicator {
    position: absolute;
    top: 0;
    bottom: 0;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.08);
    border: none;
    transition: all 0.45s cubic-bezier(0.34, 1.56, 0.64, 1);
    pointer-events: none;
    z-index: 0;
    opacity: 0;
    display: flex;
    align-items: center;
    padding-left: 9px;
  }

  .nav-indicator.visible {
    opacity: 1;
  }

  @keyframes cycle-icons {
    0%, 9.09% { content: url("/svg/svg-1.png"); }
    9.09%, 18.18% { content: url("/svg/svg-2.png"); }
    18.18%, 27.27% { content: url("/svg/svg-3.png"); }
    27.27%, 36.36% { content: url("/svg/svg-4.png"); }
    36.36%, 45.45% { content: url("/svg/svg-5.png"); }
    45.45%, 54.54% { content: url("/svg/svg-6.png"); }
    54.54%, 63.63% { content: url("/svg/svg-7.png"); }
    63.63%, 72.72% { content: url("/svg/svg-8.png"); }
    72.72%, 81.81% { content: url("/svg/svg-9.png"); }
    81.81%, 90.90% { content: url("/svg/svg-10.png"); }
    90.90%, 100% { content: url("/svg/svg-11.png"); }
  }

  .nav-indicator-icon {
    width: 14px;
    height: 14px;
    animation: cycle-icons 5.5s linear infinite;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .mobile-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 9999px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.04);
    color: var(--dm-light-200);
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    flex-shrink: 0;
  }

  .mobile-toggle:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  .mobile-toggle:active {
    transform: scale(0.9);
  }

  .mobile-toggle svg {
    width: 18px;
    height: 18px;
    transition: transform 0.3s ease;
  }

  .mobile-toggle.open svg {
    transform: rotate(90deg);
  }

  /* Mobile menu overlay */
  .mobile-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    z-index: 49;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .mobile-overlay.open {
    opacity: 1;
    pointer-events: all;
  }

  /* Mobile sidebar menu */
  .mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: 65%;
    height: 100vh;
    z-index: 50;
    background: rgba(10, 15, 12, 0.95);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transform: translateX(-100%);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 4px 0 24px rgba(0, 0, 0, 0.5);
    overflow-y: auto;
    padding: 24px 10px;
    padding-top: 64px;
  }

  .mobile-menu.open {
    transform: translateX(0);
  }

  .mobile-menu .mobile-header {
    margin-bottom: 24px;
  }

  .mobile-menu .mobile-header a {
    font-family: var(--font-afronaut);
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    padding: 8px 12px;
    display: flex;
    align-items: center;
    gap: 8px;
    border-radius: 8px;
    transition: all 0.2s ease;
  }

  .mobile-menu .mobile-header a:hover {
    background: rgba(255, 255, 255, 0.04);
  }

  .mobile-menu .chapter-group {
    margin-bottom: 24px;
  }

  .mobile-menu .chapter-title {
    font-family: var(--font-afronaut);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text);
    padding: 8px 12px;
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    border-radius: 8px;
    transition: all 0.2s ease;
    opacity: 1;
  }

  .mobile-menu .chapter-title:hover {
    background: rgba(255, 255, 255, 0.04);
    opacity: 1;
  }

  .mobile-menu .chapter-number {
    width: 24px;
    height: 24px;
    border-radius: 6px;
    background: var(--color-text);
    color: var(--dm-dark-500);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.6875rem;
    font-weight: 600;
    flex-shrink: 0;
  }

  .mobile-menu .lesson-list {
    margin-left: 36px;
    border-left: 1px dashed rgba(255, 255, 255, 0.06);
    padding-left: 12px;
    position: relative;
  }

  .mobile-menu a {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    padding-left: 6px;
    font-size: 0.8125rem;
    font-weight: 400;
    color: var(--dm-light-300);
    text-decoration: none;
    border-radius: 0 5px 5px 0;
    transition: all 0.2s ease;
    margin-bottom: 2px;
    opacity: 0.7;
    position: relative;
    z-index: 1;
  }

  .mobile-menu a:hover {
    opacity: 1;
    color: white;
  }

  .mobile-menu a.active {
    opacity: 1;
    color: white;
  }

  .mobile-menu .lesson-badge {
    background: #FC5D7D;
    color: hsla(158, 23%, 18%, 1);
    font-size: 8px;
    padding: 1px 4px;
    border-radius: 0;
    font-weight: 100;
    font-family: var(--font-afronaut, system-ui, sans-serif);
    letter-spacing: 0.02em;
    transform: rotate(-3deg);
  }

  .mobile-menu a:nth-child(2) .lesson-badge { transform: rotate(2deg); background: #9FA6FF; }
  .mobile-menu a:nth-child(3) .lesson-badge { transform: rotate(-2deg); background: #56C288; color: hsla(158, 23%, 18%, 1); }
  .mobile-menu a:nth-child(4) .lesson-badge { transform: rotate(3deg); background: #FDD88E; color: hsla(158, 23%, 18%, 1); }
  .mobile-menu a:nth-child(5) .lesson-badge { transform: rotate(-1deg); background: #57B0FB; }
  .mobile-menu a:nth-child(6) .lesson-badge { transform: rotate(2deg); background: #FC5D7D; color: hsla(158, 23%, 18%, 1); }
  .mobile-menu a:nth-child(7) .lesson-badge { transform: rotate(-3deg); background: #9FA6FF; }
  .mobile-menu a:nth-child(8) .lesson-badge { transform: rotate(1deg); background: #56C288; }
  .mobile-menu a:nth-child(9) .lesson-badge { transform: rotate(-2deg); background: #FDD88E; color: hsla(158, 23%, 18%, 1); }
  .mobile-menu a:nth-child(10) .lesson-badge { transform: rotate(3deg); background: #57B0FB; }
  .mobile-menu a:nth-child(11) .lesson-badge { transform: rotate(-1deg); background: #FC5D7D; }
  .mobile-menu a:nth-child(12) .lesson-badge { transform: rotate(2deg); background: #9FA6FF; }

  .mobile-menu .nav-stars-icon {
    width: 12px;
    height: 12px;
    opacity: 0;
    transform: scale(0.5) rotate(-30deg);
    transition: opacity 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .mobile-menu a.active .nav-stars-icon {
    opacity: 1;
    transform: scale(1) rotate(0deg);
  }

  .mobile-close-btn {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.05);
    color: var(--dm-light-300);
    border: none;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .mobile-close-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    color: white;
  }

  @media (max-width: 768px) {
    .nav-links {
      display: none;
    }
    .mobile-toggle {
      display: flex;
    }
    .nav-divider {
      display: none;
    }
    .nav-island {
      width: auto;
      max-width: calc(100% - 32px);
    }
  }

  /* Entry animation - only plays once thanks to transition:persist */
  @keyframes island-enter {
    0% {
      opacity: 0;
      transform: translateX(-50%) translateY(-20px) scale(0.9);
    }
    100% {
      opacity: 1;
      transform: translateX(-50%) translateY(0) scale(1);
    }
  }

  .nav-island:not(.nav-island--loaded) {
    animation: island-enter 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  /* Glow effect on active */
  .nav-links a.active {
    text-shadow: none;
  }
</style>

<header class="nav-island" id="nav-island" transition:persist transition:animate="none">
  <nav class="nav-inner">
    <a href="/" class="nav-brand">
      <span style="color: white; font-weight: 200; font-family: var(--font-afronaut);">GenesisPixel</span>
      <img src="/svg/stars.svg" alt="" class="nav-brand-stars" aria-hidden="true" />
    </a>

    <div class="nav-divider"></div>

    <div class="nav-links" id="nav-links">
      <div class="nav-indicator" id="nav-indicator">
        <img src="/svg/svg-1.png" alt="" class="nav-indicator-icon" aria-hidden="true" />
      </div>
      {navItems.map((item) => (
        <a
          href={item.href}
          data-nav-item
        >
          {item.label}
          {item.label === 'Shaders' && (
            <span class="badge-nuevo" style="position: absolute; top: -5px; right: -8px; background: #56C288; color: var(--color-bg); font-size: 10px; padding: 1px 4px; border-radius: 0; font-weight: 100; margin-left: 4px; font-family: var(--font-afronaut, system-ui, sans-serif);">Pro</span>
          )}
          {item.label === 'Three.js' && (
            <span class="badge-nuevo" style="position: absolute; top: -5px; right: -8px; background: #FC5D7D; color: white; font-size: 10px; padding: 1px 4px; border-radius: 0; font-weight: 100; margin-left: 4px; font-family: var(--font-afronaut, system-ui, sans-serif);">Nuevo</span>
          )}
          {item.label === 'Keyframes' && (
            <span style="position: absolute; top: -5px; right: -8px; background: #9FA6FF; color: var(--color-bg); font-size: 10px; padding: 1px 4px; border-radius: 0; font-weight: 100; margin-left: 4px; transform: rotate(10deg); font-family: var(--font-afronaut, system-ui, sans-serif);">Principiante</span>
          )}
          {item.label === 'Transitions' && (
            <span style="position: absolute; top: -5px; right: -8px; background: #a855f7; color: white; font-size: 10px; padding: 1px 4px; border-radius: 0; font-weight: 100; margin-left: 4px; transform: rotate(10deg); font-family: var(--font-afronaut, system-ui, sans-serif);">Intermedio</span>
          )}
          {item.label === 'Transform' && (
            <span style="position: absolute; top: -5px; right: -8px; background: #57B0FB; color: var(--color-bg); font-size: 10px; padding: 1px 4px; border-radius: 0; font-weight: 100; margin-left: 4px; transform: rotate(10deg); font-family: var(--font-afronaut, system-ui, sans-serif);">Avanzado</span>
          )}
          {item.label === 'Interactions' && (
            <span style="position: absolute; top: -5px; right: -8px; background: #f59e0b; color: var(--color-bg); font-size: 10px; padding: 1px 4px; border-radius: 0; font-weight: 100; margin-left: 4px; transform: rotate(10deg); font-family: var(--font-afronaut, system-ui, sans-serif);">UI/UX</span>
          )}
        </a>
      ))}
    </div>

    <div class="nav-actions">
      <button class="mobile-toggle" id="mobile-menu-toggle">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" id="hamburger-icon">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>
</header>

<div class="mobile-overlay" id="mobile-overlay"></div>

<div class="mobile-menu" id="mobile-menu" transition:persist transition:animate="none">
  <button class="mobile-close-btn" id="mobile-close">
    <svg xmlns="/img/svg-2.png" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
  </button>
  <div class="mobile-header">
    <a href="/">GenesisPixel</a>
  </div>
  <div class="chapter-group">
    <a href="/" class="chapter-title">
      <span class="chapter-number">01</span>
      Menú Principal
    </a>
    <div class="lesson-list">
      {navItems.map((item, index) => (
        <a href={item.href}>
          <span class="lesson-badge">{String(index + 1).padStart(2, '0')}</span>
          {item.label}
        </a>
      ))}
    </div>
  </div>
</div>

<script>
  function initNavbar() {
    const island = document.getElementById('nav-island');
    const navLinks = document.getElementById('nav-links');
    const indicator = document.getElementById('nav-indicator');
    const menuToggle = document.getElementById('mobile-menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileOverlay = document.getElementById('mobile-overlay');
    const mobileClose = document.getElementById('mobile-close');

    let mobileOpen = false;

    // Mark island as loaded so the CSS entry animation never replays
    if (island && !island.classList.contains('nav-island--loaded')) {
      island.classList.add('nav-island--loaded');
    }

    // Update active links based on the current URL (since navbar is persisted)
    const currentPath = window.location.pathname;
    navLinks?.querySelectorAll('a[data-nav-item]').forEach((link) => {
      const href = link.getAttribute('href');
      const isActive =
        href === currentPath ||
        (href === '/keyframes/que-son' && currentPath.startsWith('/keyframes/')) ||
        (href === '/transitions/que-son' && currentPath.startsWith('/transitions/')) ||
        (href === '/interactions/que-son' && currentPath.startsWith('/interactions/')) ||
        (href === '/transform/que-es' && currentPath.startsWith('/transform/')) ||
        (href === '/threejs/que-es-threejs' && currentPath.startsWith('/threejs/')) ||
        (href === '/shaders/que-son-los-shaders' && currentPath.startsWith('/shaders/'));
      if (isActive) {
        link.classList.add('active');
      } else {
        link.classList.remove('active');
      }
    });
    mobileMenu?.querySelectorAll('a').forEach((link) => {
      const href = link.getAttribute('href');
      const isActive =
        href === currentPath ||
        (href === '/keyframes/que-son' && currentPath.startsWith('/keyframes/')) ||
        (href === '/transitions/que-son' && currentPath.startsWith('/transitions/')) ||
        (href === '/interactions/que-son' && currentPath.startsWith('/interactions/')) ||
        (href === '/transform/que-es' && currentPath.startsWith('/transform/')) ||
        (href === '/threejs/que-es-threejs' && currentPath.startsWith('/threejs/')) ||
        (href === '/shaders/que-son-los-shaders' && currentPath.startsWith('/shaders/'));
      if (isActive) {
        link.classList.add('active');
      } else {
        link.classList.remove('active');
      }
    });

    function updateIndicator() {
      const activeLink = navLinks?.querySelector('a.active') as HTMLElement;
      if (!activeLink || !indicator || !navLinks) return;

      const linksRect = navLinks.getBoundingClientRect();
      const activeRect = activeLink.getBoundingClientRect();

      indicator.style.left = `${activeRect.left - linksRect.left}px`;
      indicator.style.width = `${activeRect.width}px`;
      indicator.classList.add('visible');
    }

    function handleHover(e: Event) {
      const target = e.target as HTMLElement;
      if (target.tagName !== 'A' || !indicator || !navLinks) return;

      const linksRect = navLinks.getBoundingClientRect();
      const targetRect = target.getBoundingClientRect();

      indicator.style.left = `${targetRect.left - linksRect.left}px`;
      indicator.style.width = `${targetRect.width}px`;
      indicator.classList.add('visible');
    }

    function handleHoverEnd() {
      updateIndicator();
    }

    navLinks?.addEventListener('mouseover', handleHover);
    navLinks?.addEventListener('mouseout', handleHoverEnd);

    function openMobile() {
      mobileOpen = true;
      mobileMenu?.classList.add('open');
      mobileOverlay?.classList.add('open');
      menuToggle?.classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function closeMobile() {
      mobileOpen = false;
      mobileMenu?.classList.remove('open');
      mobileOverlay?.classList.remove('open');
      menuToggle?.classList.remove('open');
      document.body.style.overflow = '';
    }

    menuToggle?.addEventListener('click', () => {
      if (mobileOpen) {
        closeMobile();
      } else {
        openMobile();
      }
    });

    mobileClose?.addEventListener('click', closeMobile);
    mobileOverlay?.addEventListener('click', closeMobile);

    mobileMenu?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMobile);
    });

    setTimeout(updateIndicator, 50);
  }

  document.addEventListener('astro:page-load', initNavbar);
  document.addEventListener('astro:after-swap', initNavbar);
  document.addEventListener('DOMContentLoaded', initNavbar);
</script>
