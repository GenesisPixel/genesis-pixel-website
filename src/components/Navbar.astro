---
const navItems = [
  { href: '/', label: 'Inicio' },
  { href: '/aprender', label: 'Aprender' },
  { href: '/keyframes/que-son', label: 'Keyframes' },
  { href: '/ejemplos', label: 'Ejemplos' },
  { href: '/proyectos', label: 'Proyectos' },
  { href: '/recursos', label: 'Recursos' },
];
---

<style>
  .nav-island {
    position: fixed;
    top: 16px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    border-radius: 9999px;
    background: rgba(28, 28, 30, 0.72);
    backdrop-filter: blur(40px) saturate(180%);
    -webkit-backdrop-filter: blur(40px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.06);
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.3),
      0 2px 8px rgba(0, 0, 0, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
    padding: 4px 12px;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .nav-brand {
    font-family: var(--font-afronaut);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    white-space: nowrap;
    padding: 6px 12px;
    transition: opacity 0.3s ease;
    position: relative;
    display: inline-flex;
    align-items: center;
  }

  .nav-brand:hover {
    opacity: 0.8;
  }

  .nav-brand-stars {
    position: absolute;
    top: -3px;
    right: 0px;
    width: 18px;
    height: 18px;
    opacity: 0.7;
  }

  .nav-divider {
    width: 1px;
    height: 20px;
    background: rgba(255, 255, 255, 0.1);
    flex-shrink: 0;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2px;
    position: relative;
  }

  .nav-links a {
    position: relative;
    padding: 6px 14px;
    padding-left: 31px;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--dm-light-300);
    text-decoration: none;
    border-radius: 9999px;
    transition: color 0.3s ease;
    white-space: nowrap;
    z-index: 1;
    opacity: 1 !important;
    display: inline-flex;
    align-items: center;
    gap: 2px;
  }

  .nav-links a:hover {
    color: white;
  }

  .nav-links a.active {
    color: white;
  }

  .nav-indicator {
    position: absolute;
    top: 0;
    bottom: 0;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.08);
    border: none;
    transition: all 0.45s cubic-bezier(0.34, 1.56, 0.64, 1);
    pointer-events: none;
    z-index: 0;
    opacity: 0;
    display: flex;
    align-items: center;
    padding-left: 9px;
  }

  .nav-indicator.visible {
    opacity: 1;
  }

  .nav-indicator-icon {
    width: 14px;
    height: 14px;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .mobile-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 9999px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.04);
    color: var(--dm-light-200);
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    flex-shrink: 0;
  }

  .mobile-toggle:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  .mobile-toggle:active {
    transform: scale(0.9);
  }

  .mobile-toggle svg {
    width: 18px;
    height: 18px;
    transition: transform 0.3s ease;
  }

  .mobile-toggle.open svg {
    transform: rotate(90deg);
  }

  /* Mobile menu */
  .mobile-menu {
    position: fixed;
    top: 72px;
    left: 50%;
    transform: translateX(-50%) translateY(-8px) scale(0.96);
    z-index: 99;
    width: calc(100% - 32px);
    max-width: 360px;
    border-radius: 24px;
    background: rgba(28, 28, 30, 0.92);
    backdrop-filter: blur(40px) saturate(180%);
    -webkit-backdrop-filter: blur(40px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.06);
    box-shadow:
      0 24px 64px rgba(0, 0, 0, 0.5),
      0 8px 24px rgba(0, 0, 0, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
    opacity: 0;
    pointer-events: none;
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    overflow: hidden;
  }

  .mobile-menu.open {
    opacity: 1;
    pointer-events: all;
    transform: translateX(-50%) translateY(0) scale(1);
  }

  .mobile-menu-inner {
    padding: 8px;
  }

  .mobile-menu a {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    border-radius: 16px;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--dm-light-300);
    text-decoration: none;
    transition: all 0.25s ease;
  }

  .mobile-menu a:hover {
    background: rgba(255, 255, 255, 0.06);
    color: var(--color-text);
  }

  .mobile-menu a.active {
    background: rgba(255, 255, 255, 0.08);
    color: var(--color-text);
  }

  .mobile-menu a.active::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-text);
    flex-shrink: 0;
    box-shadow: 0 0 8px var(--color-text);
  }

  .mobile-menu .nav-stars-icon {
    opacity: 0;
    transform: scale(0.5) rotate(-30deg);
    transition: opacity 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    width: 16px;
    height: 16px;
  }

  .mobile-menu a.active .nav-stars-icon {
    opacity: 1;
    transform: scale(1) rotate(0deg);
  }

  .mobile-menu a:not(.active)::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.12);
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .nav-links {
      display: none;
    }
    .mobile-toggle {
      display: flex;
    }
    .nav-divider {
      display: none;
    }
    .nav-island {
      width: auto;
      max-width: calc(100% - 32px);
    }
  }

  /* Entry animation - only plays once thanks to transition:persist */
  @keyframes island-enter {
    0% {
      opacity: 0;
      transform: translateX(-50%) translateY(-20px) scale(0.9);
    }
    100% {
      opacity: 1;
      transform: translateX(-50%) translateY(0) scale(1);
    }
  }

  .nav-island:not(.nav-island--loaded) {
    animation: island-enter 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  /* Glow effect on active */
  .nav-links a.active {
    text-shadow: none;
  }
</style>

<header class="nav-island" id="nav-island" transition:persist transition:animate="none">
  <nav class="nav-inner">
    <a href="/" class="nav-brand">
      <span style="color: white; font-weight: 200; font-family: var(--font-afronaut);">GenesisPixel</span>
      <img src="/svg/stars.svg" alt="" class="nav-brand-stars" aria-hidden="true" />
    </a>

    <div class="nav-divider"></div>

    <div class="nav-links" id="nav-links">
      <div class="nav-indicator" id="nav-indicator">
        <svg class="nav-indicator-icon" fill="none" viewBox="0 0 180 180" xmlns="http://www.w3.org/2000/svg">
          <path d="m30.5729 109.394c3.0469 3.046 9.1992 3.808 13.9453-.469 1.582-1.406 4.8633-4.922 11.1328-11.1916 29.9414-30.3516 49.688-50.2735 53.906-46.4649 3.399 2.9883-6.972 17.6367-16.8162 31.2305-18.457 25.723-33.164 43.535-22.2656 54.434 8.7305 8.73 22.3242-.059 43.2418-18.399 11.778-10.371 20.625-18.7498 23.204-16.113 1.933 1.875-1.055 6.855-5.45 14.473-5.683 9.726-12.773 20.156-5.976 26.953 4.687 4.629 13.769 2.636 24.961-8.321 1.992-1.992 2.461-4.218.879-5.8-1.524-1.465-3.633-1.231-5.215.234-8.145 7.969-13.477 10.488-14.824 9.082-1.582-1.523 1.289-6.738 7.265-17.227 7.559-13.242 11.602-21.562 5.215-27.773-8.555-8.3203-18.691.5859-37.441 17.051-17.6371 15.527-22.7934 18.047-25.0199 15.879-2.9883-3.047 1.582-8.438 21.3279-36.0355 18.457-25.8398 29.18-41.9531 19.16-51.6211-13.652-13.3008-31.2301-2.8125-79.3942 44.8242-6.3867 6.3281-9.9023 9.668-11.3086 11.1914-4.5117 4.98-3.5742 11.016-.5273 14.063z" fill="white"/>
        </svg>
      </div>
      {navItems.map((item) => (
        <a
          href={item.href}
          data-nav-item
        >
          {item.label}
        </a>
      ))}
    </div>

    <div class="nav-actions">
      <button class="mobile-toggle" id="mobile-menu-toggle">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" id="hamburger-icon">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>
</header>

<div class="mobile-menu" id="mobile-menu" transition:persist transition:animate="none">
  <div class="mobile-menu-inner">
    {navItems.map((item) => (
      <a href={item.href}>
        <svg class="nav-stars-icon" fill="none" viewBox="0 0 180 180" xmlns="http://www.w3.org/2000/svg">
          <path d="m30.5729 109.394c3.0469 3.046 9.1992 3.808 13.9453-.469 1.582-1.406 4.8633-4.922 11.1328-11.1916 29.9414-30.3516 49.688-50.2735 53.906-46.4649 3.399 2.9883-6.972 17.6367-16.8162 31.2305-18.457 25.723-33.164 43.535-22.2656 54.434 8.7305 8.73 22.3242-.059 43.2418-18.399 11.778-10.371 20.625-18.7498 23.204-16.113 1.933 1.875-1.055 6.855-5.45 14.473-5.683 9.726-12.773 20.156-5.976 26.953 4.687 4.629 13.769 2.636 24.961-8.321 1.992-1.992 2.461-4.218.879-5.8-1.524-1.465-3.633-1.231-5.215.234-8.145 7.969-13.477 10.488-14.824 9.082-1.582-1.523 1.289-6.738 7.265-17.227 7.559-13.242 11.602-21.562 5.215-27.773-8.555-8.3203-18.691.5859-37.441 17.051-17.6371 15.527-22.7934 18.047-25.0199 15.879-2.9883-3.047 1.582-8.438 21.3279-36.0355 18.457-25.8398 29.18-41.9531 19.16-51.6211-13.652-13.3008-31.2301-2.8125-79.3942 44.8242-6.3867 6.3281-9.9023 9.668-11.3086 11.1914-4.5117 4.98-3.5742 11.016-.5273 14.063z" fill="white"/>
        </svg>
          {item.label}
        </a>
      ))}
  </div>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    const island = document.getElementById('nav-island');
    const navLinks = document.getElementById('nav-links');
    const indicator = document.getElementById('nav-indicator');
    const menuToggle = document.getElementById('mobile-menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');

    // Mark island as loaded so the CSS entry animation never replays
    if (island && !island.classList.contains('nav-island--loaded')) {
      island.classList.add('nav-island--loaded');
    }

    // Update active links based on the current URL (since navbar is persisted)
    const currentPath = window.location.pathname;
    navLinks?.querySelectorAll('a[data-nav-item]').forEach((link) => {
      const href = link.getAttribute('href');
      const isActive = href === currentPath || (href === '/keyframes/que-son' && currentPath.startsWith('/keyframes/'));
      if (isActive) {
        link.classList.add('active');
      } else {
        link.classList.remove('active');
      }
    });
    mobileMenu?.querySelectorAll('a').forEach((link) => {
      const href = link.getAttribute('href');
      const isActive = href === currentPath || (href === '/keyframes/que-son' && currentPath.startsWith('/keyframes/'));
      if (isActive) {
        link.classList.add('active');
      } else {
        link.classList.remove('active');
      }
    });

    function updateIndicator() {
      const activeLink = navLinks?.querySelector('a.active') as HTMLElement;
      if (!activeLink || !indicator || !navLinks) return;

      const linksRect = navLinks.getBoundingClientRect();
      const activeRect = activeLink.getBoundingClientRect();

      indicator.style.left = `${activeRect.left - linksRect.left}px`;
      indicator.style.width = `${activeRect.width}px`;
      indicator.classList.add('visible');
    }

    function handleHover(e: Event) {
      const target = e.target as HTMLElement;
      if (target.tagName !== 'A' || !indicator || !navLinks) return;

      const linksRect = navLinks.getBoundingClientRect();
      const targetRect = target.getBoundingClientRect();

      indicator.style.left = `${targetRect.left - linksRect.left}px`;
      indicator.style.width = `${targetRect.width}px`;
      indicator.classList.add('visible');
    }

    function handleHoverEnd() {
      updateIndicator();
    }

    navLinks?.addEventListener('mouseover', handleHover);
    navLinks?.addEventListener('mouseout', handleHoverEnd);

    let mobileOpen = false;
    menuToggle?.addEventListener('click', () => {
      mobileOpen = !mobileOpen;
      mobileMenu?.classList.toggle('open', mobileOpen);
      menuToggle?.classList.toggle('open', mobileOpen);
    });

    document.addEventListener('click', (e) => {
      if (mobileOpen && !mobileMenu?.contains(e.target as Node) && !menuToggle?.contains(e.target as Node)) {
        mobileOpen = false;
        mobileMenu?.classList.remove('open');
        menuToggle?.classList.remove('open');
      }
    });

    setTimeout(updateIndicator, 50);
  });
</script>
