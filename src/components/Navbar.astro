---
const navItems = [
  { href: '/', label: 'Inicio' },
  { href: '/aprender', label: 'Aprender' },
  { href: '/keyframes/que-son', label: 'Keyframes' },
  { href: '/ejemplos', label: 'Ejemplos' },
  { href: '/proyectos', label: 'Proyectos' },
  { href: '/recursos', label: 'Recursos' },
];
---

<style>
  .nav-island {
    position: fixed;
    top: 16px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    border-radius: 9999px;
    background: rgba(28, 28, 30, 0.72);
    backdrop-filter: blur(40px) saturate(180%);
    -webkit-backdrop-filter: blur(40px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.06);
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.3),
      0 2px 8px rgba(0, 0, 0, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
    transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    padding: 6px 12px;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .nav-brand {
    font-family: var(--font-afronaut);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    white-space: nowrap;
    padding: 6px 12px;
    transition: opacity 0.3s ease;
    position: relative;
    display: inline-flex;
    align-items: center;
  }

  .nav-brand:hover {
    opacity: 0.8;
  }

  .nav-brand-stars {
    position: absolute;
    top: -3px;
    right: 0px;
    width: 18px;
    height: 18px;
    opacity: 0.7;
  }

  .nav-divider {
    width: 1px;
    height: 20px;
    background: rgba(255, 255, 255, 0.1);
    flex-shrink: 0;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2px;
    position: relative;
  }

  .nav-links a {
    position: relative;
    padding: 6px 14px;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--dm-light-300);
    text-decoration: none;
    border-radius: 9999px;
    transition: color 0.3s ease;
    white-space: nowrap;
    z-index: 1;
    opacity: 1 !important;
    display: inline-flex;
    align-items: center;
    gap: 2px;
  }

  .nav-links a:hover {
    color: white;
  }

  .nav-links a.active {
    color: white;
  }

  .nav-stars-icon {
    width: 14px;
    height: 14px;
    margin-right: 2px;
    opacity: 0;
    transform: scale(0.5) rotate(-30deg);
    transition: opacity 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    flex-shrink: 0;
  }

  .nav-links a.active .nav-stars-icon {
    opacity: 1;
    transform: scale(1) rotate(0deg);
  }

  .nav-indicator {
    position: absolute;
    top: -2px;
    bottom: -2px;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.06);
    transition: all 0.45s cubic-bezier(0.34, 1.56, 0.64, 1);
    pointer-events: none;
    z-index: 0;
    opacity: 0;
  }

  .nav-indicator.visible {
    opacity: 1;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .mobile-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 9999px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.04);
    color: var(--dm-light-200);
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    flex-shrink: 0;
  }

  .mobile-toggle:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  .mobile-toggle:active {
    transform: scale(0.9);
  }

  .mobile-toggle svg {
    width: 18px;
    height: 18px;
    transition: transform 0.3s ease;
  }

  .mobile-toggle.open svg {
    transform: rotate(90deg);
  }

  /* Mobile menu */
  .mobile-menu {
    position: fixed;
    top: 72px;
    left: 50%;
    transform: translateX(-50%) translateY(-8px) scale(0.96);
    z-index: 99;
    width: calc(100% - 32px);
    max-width: 360px;
    border-radius: 24px;
    background: rgba(28, 28, 30, 0.92);
    backdrop-filter: blur(40px) saturate(180%);
    -webkit-backdrop-filter: blur(40px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.06);
    box-shadow:
      0 24px 64px rgba(0, 0, 0, 0.5),
      0 8px 24px rgba(0, 0, 0, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
    opacity: 0;
    pointer-events: none;
    transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    overflow: hidden;
  }

  .mobile-menu.open {
    opacity: 1;
    pointer-events: all;
    transform: translateX(-50%) translateY(0) scale(1);
  }

  .mobile-menu-inner {
    padding: 8px;
  }

  .mobile-menu a {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    border-radius: 16px;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--dm-light-300);
    text-decoration: none;
    transition: all 0.25s ease;
  }

  .mobile-menu a:hover {
    background: rgba(255, 255, 255, 0.06);
    color: var(--color-text);
  }

  .mobile-menu a.active {
    background: rgba(255, 255, 255, 0.08);
    color: var(--color-text);
  }

  .mobile-menu a.active::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-text);
    flex-shrink: 0;
    box-shadow: 0 0 8px var(--color-text);
  }

  .mobile-menu .nav-stars-icon {
    opacity: 0;
    transform: scale(0.5) rotate(-30deg);
    transition: opacity 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    width: 16px;
    height: 16px;
  }

  .mobile-menu a.active .nav-stars-icon {
    opacity: 1;
    transform: scale(1) rotate(0deg);
  }

  .mobile-menu a:not(.active)::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.12);
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .nav-links {
      display: none;
    }
    .mobile-toggle {
      display: flex;
    }
    .nav-divider {
      display: none;
    }
    .nav-island {
      width: auto;
      max-width: calc(100% - 32px);
    }
  }

  /* Entry animation - only plays once thanks to transition:persist */
  @keyframes island-enter {
    0% {
      opacity: 0;
      transform: translateX(-50%) translateY(-20px) scale(0.9);
    }
    100% {
      opacity: 1;
      transform: translateX(-50%) translateY(0) scale(1);
    }
  }

  .nav-island:not(.nav-island--loaded) {
    animation: island-enter 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  /* Glow effect on active */
  .nav-links a.active {
    text-shadow: none;
  }
</style>

