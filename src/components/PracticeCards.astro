---
interface Props {
  title: string;
  description: string;
  steps: { number: number; text: string; color: string; rotate: string }[];
}

const { title, description, steps } = Astro.props;
---

<div class="py-6">
  <div class="mb-8">
    <h3 class="mb-2 text-center font-medium text-[var(--color-text)]">
      {title.charAt(0).toUpperCase() + title.slice(1).toLowerCase()}
    </h3>
    <p class="text-center text-sm text-soft-white max-w-2xl mx-auto">
      {description}
    </p>
  </div>
  <div class="flex flex-wrap gap-3 justify-center">
    {steps.map((step) => (
      <div
        class="w-[calc(33.333%-0.5rem)] lg:w-[calc(20%-0.375rem)] p-3 text-center text-xs h-[140px] flex flex-col items-center justify-center"
        style={`background: var(--${step.color}); transform: rotate(${step.rotate}); transition: transform 0.2s ease-in-out;`}
        onmouseenter="this.style.transform='rotate(0deg)'"
        onmouseleave={`this.style.transform='rotate(${step.rotate})'`}
      >
        <span class="mb-1 block text-lg font-medium font-afronaut" style="color: var(--color-bg);">{String(step.number).padStart(2, '0')}</span>
        <span style="color: var(--color-bg);">{step.text}</span>
      </div>
    ))}
  </div>
</div>
