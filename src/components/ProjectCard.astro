---
interface Props {
  title: string;
  description: string;
  category: string;
  difficulty: string;
  tags: string[];
  href?: string;
}

const { title, description, category, difficulty, tags, href = '#' } = Astro.props;

const difficultyColors = {
  basico: 'bg-[var(--dm-green)]/20 text-[var(--dm-green)]',
  intermedio: 'bg-[var(--dm-yellow)]/20 text-[var(--dm-yellow)]',
  avanzado: 'bg-[var(--dm-red)]/20 text-[var(--dm-red)]',
};

const categoryLabels: Record<string, string> = {
  css: 'CSS',
  svg: 'SVG',
  canvas: 'Canvas',
  threejs: 'Three.js',
  gsap: 'GSAP',
  webgl: 'WebGL',
};
---

<a
  {href}
  class="group block overflow-hidden rounded-[var(--radius-base)] border border-white/5 bg-white/[0.02] transition-all hover:border-white/10 hover:bg-white/[0.04]"
>
  <div class="aspect-video bg-gradient-to-br from-white/5 to-transparent">
    <div class="flex h-full items-center justify-center text-[var(--dm-light-300)]">
      <svg class="h-12 w-12 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
      </svg>
    </div>
  </div>

  <div class="p-5">
    <div class="flex items-center gap-2">
      <span class="text-xs font-medium text-[var(--dm-light-300)]">{categoryLabels[category]}</span>
      <span class="text-[var(--dm-light-300)]">·</span>
      <span class={`text-xs font-medium ${difficultyColors[difficulty as keyof typeof difficultyColors]}`}>{difficulty}</span>
    </div>

    <h3 class="mt-2 text-lg font-semibold text-[var(--color-text)] group-hover:text-white">{title}</h3>

    <p class="mt-2 text-sm text-[var(--dm-light-300)] line-clamp-2">{description}</p>

    <div class="mt-4 flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="rounded-full bg-white/5 px-2.5 py-0.5 text-xs text-[var(--dm-light-300)]">{tag}</span>
      ))}
    </div>
  </div>
</a>
