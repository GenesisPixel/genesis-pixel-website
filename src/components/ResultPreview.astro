---
interface Props {
  description?: string;
}

const { description } = Astro.props;
---

<div class="flex-1">
  <div class="overflow-hidden rounded-none shadow-lg" style="background-color: hsla(158, 23%, 10%, 1);">
    <!-- Console Header -->
    <div class="flex items-center gap-4 border-b px-4 py-3" style="border-color: rgba(255,255,255,0.06); background-color: hsla(158, 23%, 8%, 1);">
      <div class="flex gap-1.5">
        <div class="h-2.5 w-2.5 rounded-full bg-[var(--dm-red)]"></div>
        <div class="h-2.5 w-2.5 rounded-full bg-[var(--dm-yellow)]"></div>
        <div class="h-2.5 w-2.5 rounded-full bg-[var(--dm-green)]"></div>
      </div>
      <div class="flex items-center gap-1.5 font-mono text-[11px]">
        <span class="flex tracking-tighter text-[var(--dm-green)]">
          <span class="font-bold">></span>
          <span class="animate-blink font-bold">_</span>
        </span>
      </div>
    </div>
    
    <!-- Result Content -->
    <div class="flex items-center justify-center p-8 max-h-[400px] overflow-y-auto" style="min-height: 260px;">
      <slot />
    </div>
  </div>
  
  {description && (
    <p class="mt-4 text-sm text-[var(--dm-light-300)]">
      {description}
    </p>
  )}
</div>
