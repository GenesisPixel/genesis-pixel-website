---
interface Props {
  title: string;
}

const { title } = Astro.props;

const icons = ['svg-1.png', 'svg-2.png', 'svg-3.png', 'svg-4.png', 'svg-5.png', 'svg-6.png', 'svg-7.png', 'svg-8.png', 'svg-9.png', 'svg-10.png', 'svg-11.png'];
const shuffled = icons.sort(() => 0.5 - Math.random());
const icon1 = shuffled[0];
const icon2 = shuffled[1];

const rot1 = Math.floor(Math.random() * 21) - 10;
const rot2 = Math.floor(Math.random() * 21) - 10;

const renderChars = (text: string) => text.split(' ').map((word) =>
  `<span class="inline-block whitespace-nowrap">` +
  word.split('').map(char => `<span class="section-title-char inline-block opacity-0">${char}</span>`).join('') +
  `</span>`
).join(' ');

const titleChars = renderChars(title);
---

<div class="text-center" style="transform-style: preserve-3d;">
  <div class="relative inline-block">
    <img src={`/svg/${icon1}`} alt="" class="absolute opacity-60 svg-icon-animate" style="right: 0; top: -10px;" data-rotate={rot1} aria-hidden="true" />
    <img src={`/svg/${icon2}`} alt="" class="absolute bottom-2 opacity-60 svg-icon-animate-delay" style="left: -10px;" data-rotate={rot2} aria-hidden="true" />
    <h1 class="font-afronaut font-light text-[var(--color-text)]" style="line-height: 0.85; letter-spacing: -0.05em;">
      <Fragment set:html={titleChars} />
    </h1>
  </div>
</div>

<style>
  :global(.section-title-char) {
    font-family: var(--font-afronaut) !important;
  }

  .svg-icon-animate {
    width: 80px;
  }

  .svg-icon-animate-delay {
    width: 50px;
  }

  @media (max-width: 640px) {
    .svg-icon-animate {
      width: 50px;
    }

    .svg-icon-animate-delay {
      width: 32px;
    }
  }
</style>

<script>
  import gsap from 'gsap';

  document.addEventListener('astro:page-load', () => {
    const chars = document.querySelectorAll('.section-title-char');
    const icons = document.querySelectorAll('.svg-icon-animate');
    const iconsDelay = document.querySelectorAll('.svg-icon-animate-delay');

    if (chars.length) {
      gsap.set(chars, {
        opacity: 0,
        y: 60,
        rotateX: -40,
        scale: 0.9,
        filter: 'blur(10px)'
      });

      gsap.to(chars, {
        opacity: 1,
        y: 0,
        rotateX: 0,
        scale: 1,
        filter: 'blur(0px)',
        duration: 0.9,
        stagger: {
          each: 0.025,
          from: 'start'
        },
        ease: 'power3.out',
        delay: 0.2
      });
    }

    icons.forEach(el => {
      const r = parseFloat(el.dataset.rotate) || 0;
      gsap.set(el, { opacity: 0, y: 40, filter: 'blur(10px)', rotate: r });
      gsap.to(el, {
        opacity: 0.6,
        y: 0,
        filter: 'blur(0px)',
        rotate: r,
        duration: 0.9,
        ease: 'power3.out',
        delay: 1.5
      });
    });

    iconsDelay.forEach(el => {
      const r = parseFloat(el.dataset.rotate) || 0;
      gsap.set(el, { opacity: 0, y: 40, filter: 'blur(10px)', rotate: r });
      gsap.to(el, {
        opacity: 0.6,
        y: 0,
        filter: 'blur(0px)',
        rotate: r,
        duration: 0.9,
        ease: 'power3.out',
        delay: 1.7
      });
    });
  });
</script>
