---
interface Props {
  tabs: { id: string; label: string; code: string }[];
  group?: string;
}

const { tabs, group = 'default' } = Astro.props;
const tabGroupId = `tab-group-${group}`;
---

<div class="overflow-hidden rounded-none shadow-lg" style="background-color: hsla(158, 23%, 10%, 1); flex: 1; min-width: 0;">
  <!-- Console Header -->
  <div class="flex items-center border-b" style="border-color: rgba(255,255,255,0.06); background-color: hsla(158, 23%, 8%, 1);">
    <!-- Left: dots + cursor + tabs -->
    <div class="flex items-center gap-3 px-4 py-2.5 flex-1 min-w-0">
      <div class="flex gap-1.5 shrink-0">
        <div class="h-2.5 w-2.5 rounded-full bg-[var(--dm-red)]"></div>
        <div class="h-2.5 w-2.5 rounded-full bg-[var(--dm-yellow)]"></div>
        <div class="h-2.5 w-2.5 rounded-full bg-[var(--dm-green)]"></div>
      </div>

      <div class="flex items-center gap-1 font-mono text-[11px] shrink-0">
        <span class="text-[var(--dm-green)] font-bold">></span>
        <span class="animate-blink text-[var(--dm-green)] font-bold">_</span>
      </div>

      <!-- Tabs -->
      <div class="flex items-center gap-0.5">
        {tabs.map((tab, i) => (
          <button
            class={`code-tab px-3 py-1 text-[11px] font-light text-soft-white transition-colors hover:bg-white/5 ${i === 0 ? 'active' : ''}`}
            data-tab={tab.id}
            data-group={tabGroupId}
          >
            {tab.label}
          </button>
        ))}
      </div>
    </div>

    <!-- Right: separator + copy -->
    <div class="flex items-center shrink-0 border-l" style="border-color: rgba(255,255,255,0.06);">
      <button class="copy-btn flex items-center gap-1.5 px-3 py-2.5 text-xs font-light text-soft-white transition-colors hover:bg-white/5">
        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
        </svg>
        Copiar
      </button>
    </div>
  </div>
  
  <!-- Code Content -->
  <div class="overflow-y-auto flex flex-col code-scroll" style="height: 400px;">
    {tabs.map((tab, i) => (
      <div class={`code-content ${i !== 0 ? 'hidden' : 'flex'} flex-1 flex-col`} data-tab={tab.id} data-group={tabGroupId}>
        <pre class="m-0 flex-1 overflow-x-auto p-4 text-sm text-[var(--dm-light-200)] bg-transparent code-scroll-x"><code>{tab.code}</code></pre>
      </div>
    ))}
  </div>
</div>

<style>
  .code-scroll {
    scrollbar-width: thin;
    scrollbar-color: rgba(255, 255, 255, 0.25) transparent;
  }

  .code-scroll::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }

  .code-scroll::-webkit-scrollbar-track {
    background: transparent;
  }

  .code-scroll::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.25);
    border-radius: 6px;
  }

  .code-scroll::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.4);
  }

  .code-scroll-x {
    scrollbar-width: thin;
    scrollbar-color: rgba(255, 255, 255, 0.25) transparent;
  }

  .code-scroll-x::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }

  .code-scroll-x::-webkit-scrollbar-track {
    background: transparent;
  }

  .code-scroll-x::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.25);
    border-radius: 6px;
  }

  .code-scroll-x::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.4);
  }
</style>
