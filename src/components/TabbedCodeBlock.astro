---
interface Props {
  tabs: { id: string; label: string; code: string }[];
  group?: string;
}

const { tabs, group = 'default' } = Astro.props;
const tabGroupId = `tab-group-${group}`;
---

<div class="mb-6 overflow-hidden rounded-none shadow-lg" style="background-color: hsla(158, 23%, 10%, 1);">
  <!-- Console Header -->
  <div class="flex items-center justify-between border-b px-4 py-2.5" style="border-color: rgba(255,255,255,0.06); background-color: hsla(158, 23%, 8%, 1);">
    <div class="flex items-center gap-4">
      <div class="flex gap-1.5">
        <div class="h-2.5 w-2.5 rounded-full bg-[var(--dm-red)]"></div>
        <div class="h-2.5 w-2.5 rounded-full bg-[var(--dm-yellow)]"></div>
        <div class="h-2.5 w-2.5 rounded-full bg-[var(--dm-green)]"></div>
      </div>
      
      <div class="flex items-center gap-1.5 font-mono text-[11px] mr-2">
        <span class="flex tracking-tighter text-[var(--dm-green)]">
          <span class="font-bold">></span>
          <span class="animate-blink font-bold">_</span>
        </span>
      </div>
      
      <!-- Tabs -->
      <div class="flex items-center gap-1">
        {tabs.map((tab, i) => (
          <button
            class={`code-tab rounded-md px-3 py-1 text-xs font-medium text-soft-white transition-colors hover:bg-white/5 ${i === 0 ? 'active' : ''}`}
            data-tab={tab.id}
            data-group={tabGroupId}
          >
            {tab.label}
          </button>
        ))}
      </div>
    </div>

    <button class="copy-btn flex items-center gap-1.5 rounded-md bg-white/5 px-2.5 py-1 text-xs font-light text-soft-white transition-colors hover:bg-white/10">
      <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
      </svg>
      Copiar
    </button>
  </div>
  
  <!-- Code Content with fixed height & scroll -->
  <div class="max-h-[400px] overflow-y-auto flex flex-col" style="min-height: 260px;">
    {tabs.map((tab, i) => (
      <div class={`code-content ${i !== 0 ? 'hidden' : 'flex'} flex-1 flex-col`} data-tab={tab.id} data-group={tabGroupId}>
        <pre class="m-0 flex-1 overflow-x-auto p-4 text-sm text-[var(--dm-light-200)] bg-transparent"><code>{tab.code}</code></pre>
      </div>
    ))}
  </div>
</div>
