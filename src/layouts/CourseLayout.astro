                  </span>
                  <h4 class="nav-btn-title">{prevLesson.title}</h4>
                </span>
              </a>
            ) : <div />}
            {nextLesson ? (
              <a href={nextLesson.href} class="nav-btn next">
                <span class="nav-btn-title-row">
                  <h4 class="nav-btn-title">{nextLesson.title}</h4>
                  <span class="nav-btn-icon" style="transform: rotate(0deg);">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 47 47" fill="none"><g clip-path="url(#clip0_323_1808_next)"><path d="M34.3487 34.6279C34.1433 34.9876 34.2684 35.4457 34.628 35.6511C34.9877 35.8566 35.4458 35.7315 35.6513 35.3718L34.3487 34.6279ZM46 23.4999L46.4029 24.1325C46.6126 23.9989 46.7425 23.7701 46.7497 23.5216C46.7569 23.2732 46.6405 23.0372 46.439 22.8917L46 23.4999ZM35.6365 11.6032C35.4174 11.2516 34.9548 11.1443 34.6033 11.3634C34.2518 11.5825 34.1444 12.0451 34.3635 12.3966L35.6365 11.6032ZM35.6513 35.3718C37.6132 31.9366 40.2994 29.1236 42.5104 27.1624C43.6133 26.184 44.5918 25.423 45.2927 24.9079C45.643 24.6504 45.9235 24.4547 46.115 24.3242C46.2108 24.259 46.2843 24.2101 46.3331 24.178C46.3575 24.1619 46.3757 24.15 46.3874 24.1424C46.3933 24.1386 46.3975 24.1359 46.4001 24.1342C46.4014 24.1334 46.4023 24.1328 46.4028 24.1325C46.403 24.1324 46.4032 24.1323 46.4032 24.1323C46.4032 24.1323 46.4031 24.1323 46.4031 24.1323C46.403 24.1324 46.4029 24.1325 46 23.4999C45.5971 22.8673 45.5969 22.8674 45.5967 22.8675C45.5966 22.8676 45.5964 22.8677 45.5962 22.8679C45.5958 22.8681 45.5953 22.8684 45.5947 22.8688C45.5934 22.8696 45.5918 22.8707 45.5897 22.872C45.5856 22.8747 45.5798 22.8784 45.5724 22.8832C45.5575 22.8928 45.5361 22.9067 45.5085 22.9249C45.4533 22.9613 45.3732 23.0146 45.2705 23.0845C45.0654 23.2243 44.7701 23.4303 44.4043 23.6992C43.673 24.2368 42.6578 25.0265 41.515 26.0403C39.2343 28.0633 36.4205 31.0004 34.3487 34.6279L35.6513 35.3718ZM46 23.4999C46.439 22.8917 46.439 22.8918 46.4391 22.8918C46.4391 22.8918 46.4391 22.8918 46.439 22.8918C46.439 22.8918 46.4388 22.8916 46.4385 22.8914C46.4379 22.891 46.4369 22.8903 46.4355 22.8892C46.4327 22.8872 46.4282 22.8839 46.4221 22.8795C46.4099 22.8706 46.3912 22.8569 46.3663 22.8385C46.3166 22.8018 46.2422 22.7464 46.1454 22.6732C45.9519 22.5267 45.6693 22.3091 45.3168 22.0273C44.6117 21.4635 43.6284 20.6441 42.5205 19.6248C40.2984 17.5806 37.6029 14.758