                  </span>
                </span>
              </a>
            ) : <div />}
          </nav>
        )}
      </article>
    </div>
  </main>

  <Footer />
</Layout>

<script>
  import gsap from 'gsap';

  document.addEventListener('astro:page-load', () => {
    const h1 = document.querySelector('.main-content h1');
    
    if (h1) {
      const text = h1.textContent || '';
      const computedStyle = window.getComputedStyle(h1);
      const fontFamily = computedStyle.fontFamily;
      const fontWeight = computedStyle.fontWeight;
      const fontSize = computedStyle.fontSize;
      const lineHeight = computedStyle.lineHeight;
      const letterSpacing = computedStyle.letterSpacing;
      
      h1.innerHTML = '';
      h1.style.fontFamily = fontFamily;
      h1.style.fontWeight = fontWeight;
      h1.style.fontSize = fontSize;
      h1.style.lineHeight = lineHeight;
      h1.style.letterSpacing = letterSpacing;
      
      const words = text.split(' ');
      
      words.forEach((word, index) => {
        const wordSpan = document.createElement('span');
        wordSpan.style.display = 'inline-block';
        wordSpan.style.whiteSpace = 'nowrap';
        
        [...word].forEach((char) => {
          const span = document.createElement('span');
          span.className = 'h1-char';
          span.style.display = 'inline-block';
          span.style.opacity = '0';
          span.style.fontFamily = fontFamily;
          span.textContent = char;
          wordSpan.appendChild(span);
        });
        
        h1.appendChild(wordSpan);
        
        if (index < words.length - 1) {
          h1.appendChild(document.createTextNode(' '));
        }
      });
      
      const chars = h1.querySelectorAll('.h1-char');
      
      gsap.set(chars, { 
        opacity: 0, 
        y: 60, 
        rotateX: -40,
        scale: 0.9,
        filter: 'blur(10px)' 
      });
      
      gsap.to(chars, {
        opacity: 1,
        y: 0,
        rotateX: 0,
        scale: 1,
        filter: 'blur(0px)',
        duration: 0.9,
        stagger: {
          each: 0.025,
          from: 'start'
        },
        ease: 'power3.out',
        delay: 0.2
      });
    }

    // Lógica para el sidebar responsive
    const sidebar = document.getElementById('sidebar');
    const sidebarToggle = document.getElementById('sidebar-toggle');
    const sidebarClose = document.getElementById('sidebar-close');
    const sidebarOverlay = document.getElementById('sidebar-overlay');

    // Actualizar enlaces activos en el sidebar persistido
    if (sidebar) {
      const currentPath = window.location.pathname;
      const sidebarLinks = sidebar.querySelectorAll('.lesson-link');
      sidebarLinks.forEach((link) => {
        const href = link.getAttribute('href');
        if (href === currentPath) {
          link.classList.add('active');
        } else {
          link.classList.remove('active');
        }
      });

      const chapterTitles = sidebar.querySelectorAll('.chapter-title');
      chapterTitles.forEach((title) => {
        const href = title.getAttribute('href');
        if (href && currentPath.startsWith(href)) {
          title.classList.add('active');
        } else {
          title.classList.remove('active');
        }
      });

      // Posicionar el indicador en el link activo
      const indicator = document.getElementById('sidebar-indicator');
      const activeLink = sidebar.querySelector('.lesson-link.active');
      if (indicator && activeLink) {
        const list = activeLink.closest('.lesson-list');
        const listRect = list.getBoundingClientRect();
        const linkRect = activeLink.getBoundingClientRect();
        indicator.style.top = `${linkRect.top - listRect.top}px`;
        indicator.style.height = `${linkRect.height}px`;
      }
    }

    if (sidebar && sidebarToggle && sidebarClose && sidebarOverlay) {
      const openSidebar = () => {
        sidebar.classList.add('open');
        sidebarOverlay.classList.remove('hidden');
        setTimeout(() => sidebarOverlay.classList.remove('opacity-0'), 10);
        document.body.style.overflow = 'hidden';
      };

      const closeSidebar = () => {
        sidebar.classList.remove('open');
        sidebarOverlay.classList.add('opacity-0');
        setTimeout(() => sidebarOverlay.classList.add('hidden'), 300);
        document.body.style.overflow = '';
      };

      sidebarToggle.addEventListener('click', openSidebar);
      sidebarClose.addEventListener('click', closeSidebar);
      sidebarOverlay.addEventListener('click', closeSidebar);

      // Cerrar sidebar al hacer click en un enlace
      sidebar.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', closeSidebar);
      });

      // Mover indicador en hover
      const indicator = document.getElementById('sidebar-indicator');
      const lessonLinks = sidebar.querySelectorAll('.lesson-link');

      function moveIndicatorToLink(link) {
        if (!indicator) return;
        const list = link.closest('.lesson-list');
        if (!list) return;
        const listRect = list.getBoundingClientRect();
        const linkRect = link.getBoundingClientRect();
        indicator.style.top = `${linkRect.top - listRect.top}px`;
        indicator.style.height = `${linkRect.height}px`;
      }

      function resetIndicatorToActive() {
        const activeLink = sidebar.querySelector('.lesson-link.active');
        if (activeLink) {
          moveIndicatorToLink(activeLink);
        } else if (indicator) {
          indicator.style.top = '0px';
          indicator.style.height = '0px';
        }
      }

      lessonLinks.forEach((link) => {
        link.addEventListener('mouseenter', () => moveIndicatorToLink(link));
        link.addEventListener('mouseleave', () => resetIndicatorToActive());
      });
    }
  });
</script>
