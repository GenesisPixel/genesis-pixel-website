---
import '../styles/fonts.css';
import '../styles/global.css';
import GradientBlur from '../components/GradientBlur.astro';
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/jpeg" href="/img/icono.jpg" />
    <link rel="stylesheet" href="https://use.typekit.net/gmc0vlm.css" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ViewTransitions />
  </head>
  <body class="min-h-screen" style="background-color: var(--color-bg); color: var(--color-text);">
    <GradientBlur />
    <slot />
  </body>
</html>
