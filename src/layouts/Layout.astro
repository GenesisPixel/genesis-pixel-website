---
import '../styles/fonts.css';
import '../styles/global.css';
import GradientBlur from '../components/GradientBlur.astro';
import Navbar from '../components/Navbar.astro';
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/img/favicon.png" />
    <link rel="stylesheet" href="https://use.typekit.net/gmc0vlm.css" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ViewTransitions />
  </head>
  <body class="min-h-screen" style="background-color: var(--color-bg); color: var(--color-text);">
    <!-- Navbar is persisted globally so it never re-animates between pages -->
    <Navbar transition:persist transition:animate="none" />
    <GradientBlur transition:persist transition:animate="none" />
    <slot />
  </body>
</html>

<script is:inline>
  // Skip the view transition visual animation entirely.
  // This prevents the browser from taking DOM snapshots (which cause
  // a brief green flash from the body background). The DOM swap and
  // transition:persist still work — only the visual layer is skipped.
  document.addEventListener('astro:before-swap', (e) => {
    if (e.viewTransition) {
      e.viewTransition.skipTransition();
    }
  });

  // Always scroll to top on page navigation
  document.addEventListener('astro:after-swap', () => {
    window.scrollTo({ top: 0, behavior: 'instant' });
  });
</script>
