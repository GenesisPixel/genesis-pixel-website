---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import SectionHeader from '../components/SectionHeader.astro';

const chapters = [
  {
    number: '01',
    title: 'Keyframes',
    description: 'Aprende a crear animaciones CSS desde ceros usando @keyframes.',
    href: '/css-animation/keyframes',
  },
  {
    number: '02',
    title: 'Transforms',
    description: 'Domina las transformaciones 2D y 3D para animar elementos.',
    href: '/css-animation/transforms',
  },
  {
    number: '03',
    title: 'Transitions',
    description: 'Controla los cambios suaves entre estados de tus elementos.',
    href: '/css-animation/transitions',
  },
];
---

<Layout title="CSS Animation - GenesisPixel">
  <Navbar />

  <main class="mx-auto max-w-[1000px] px-6 pb-24 pt-24">
    <div class="mb-12">
      <h1 class="font-afronaut text-4xl font-light text-[var(--color-text)] sm:text-5xl">CSS Animation</h1>
      <p class="mt-4 text-lg text-[var(--dm-light-300)]">
        Domina las animaciones CSS con estos tres capítulos.
      </p>
    </div>

    <section class="mb-16">
      <SectionHeader
        title="Capítulos"
        description="Elige un capítulo para comenzar."
      />
      <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {chapters.map((chapter) => (
          <a
            href={chapter.href}
            class="group block rounded-2xl border border-white/5 bg-white/[0.03] p-6 transition-all duration-300 hover:border-white/10 hover:bg-white/[0.06]"
          >
            <span class="text-sm font-medium text-[var(--dm-light-300)]">
              Capítulo {chapter.number}
            </span>
            <h3 class="mt-2 text-lg font-semibold text-[var(--color-text)] group-hover:text-white">
              {chapter.title}
            </h3>
            <p class="mt-3 text-sm text-[var(--dm-light-300)]">
              {chapter.description}
            </p>
          </a>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</Layout>
