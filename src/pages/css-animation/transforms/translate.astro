---
import CourseLayout from '../../../layouts/CourseLayout.astro';
import ChapterHeader from '../../../components/ChapterHeader.astro';
import CodeBlock from '../../../components/CodeBlock.astro';
import TabbedCodeBlock from '../../../components/TabbedCodeBlock.astro';
import ResultPreview from '../../../components/ResultPreview.astro';
import ConsejoProfesional from '../../../components/ConsejoProfesional.astro';
import ErroresComunesV3 from '../../../components/ErroresComunesV3.astro';
import PracticeCards from '../../../components/PracticeCards.astro';

const translateExample = `/* Movimiento horizontal */
.element {
  transform: translateX(100px);
}

/* Movimiento vertical */
.element {
  transform: translateY(-50px);
}

/* Movimiento en ambos ejes */
.element {
  transform: translate(100px, -50px);
}

/* Porcentajes */
.element {
  transform: translateX(50%);
}`;

const animationExample = `@keyframes slideIn {
  from {
    transform: translateX(-100%);
    opacity: 0;
  }
  to {
    transform: translateX(0);
    opacity: 1;
  }
}

.slide-element {
  animation: slideIn 0.6s ease-out forwards;
}`;

const htmlCode = `<div class="slider">
  <div class="slider-item">Elemento 1</div>
  <div class="slider-item">Elemento 2</div>
  <div class="slider-item">Elemento 3</div>
</div>`;

const cssCode = `.slider-item {
  transform: translateX(-100%);
  opacity: 0;
  animation: slideIn 0.6s ease-out forwards;
}

.slider-item:nth-child(2) {
  animation-delay: 0.2s;
}

.slider-item:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes slideIn {
  to {
    transform: translateX(0);
    opacity: 1;
  }
}`;

const practiceSteps = [
  { number: 1, text: 'Crea 5 elementos div con diferentes textos', color: 'dm-purple', rotate: '10deg' },
  { number: 2, text: 'Define un @keyframes que use translateX para moverlos', color: 'dm-green', rotate: '2deg' },
  { number: 3, text: 'Aplica animation-delay escalonado a cada elemento', color: 'app-color-yellow400', rotate: '-5deg' },
  { number: 4, text: 'Experimenta con diferentes valores de translate', color: 'dm-blue', rotate: '2deg' },
  { number: 5, text: 'Añade efectos de opacidad para cada entrada', color: 'dm-red', rotate: '-5deg' },
];
---

<CourseLayout
  title="Translate - CSS Transforms"
  currentLesson="/css-animation/transforms/translate"
  nextLesson={{ title: 'Scale', href: '/css-animation/transforms/scale' }}
>
  <ChapterHeader
    chapterNumber="02"
    chapterLabel="Capítulo 2 · Lección 1"
    title="Translate"
    readingTime={10}
    difficulty="CSS Transform"
  />

  <article class="prose prose-invert max-w-none" style="margin-top: 64px;">
    <h3>¿Qué es Translate?</h3>
    <p>
      La función <code>translate()</code> es una de las transformaciones CSS más utilizadas. Permite mover un elemento desde su posición original sin afectar el flujo del documento. A diferencia de cambiar las propiedades <code>top</code>, <code>left</code>, <code>right</code> o <code>bottom</code>, translate no afecta el layout y es significativamente más performante.
    </p>
    <p>
      Translate funciona en el espacio 2D, permitiéndote mover elementos horizontalmente con <code>translateX()</code>, verticalmente con <code>translateY()</code>, o en ambos ejes simultáneamente con <code>translate()</code>. También acepta porcentajes, lo que lo hace especialmente útil para centrar elementos o crear layouts responsive.
    </p>

    <h3>Valores y Unidades</h3>
    <p>
      Puedes usar diferentes unidades con translate: píxeles (<code>px</code>), ems (<code>em</code>), rems (<code>rem</code>), porcentajes (<code>%</code>), y unidades viewport (<code>vw</code>, <code>vh</code>). Los porcentajes se calculan sobre el tamaño del propio elemento, no del contenedor, lo que lo hace ideal para centrar elementos.
    </p>
    <p>
      También puedes usar valores negativos para mover el elemento en la dirección opuesta. Por ejemplo, <code>translateX(-50%)</code> mueve el elemento a la izquierda la mitad de su propio ancho.
    </p>

    <h3>Translate en Animaciones</h3>
    <p>
      Cuando usas translate en animaciones, es una de las transformaciones más performantes porque puede ser acelerada por hardware (GPU). Esto significa que el navegador puede optimizar su renderizado y evitar reflujo del layout, resultando en animaciones más suaves, especialmente en dispositivos móviles.
    </p>
  </article>

  <h2 class="mt-8 mb-4 font-afronaut text-2xl font-light text-[var(--color-text)]">Ejemplos Prácticos</h2>

  <CodeBlock code={translateExample} />
  <CodeBlock code={animationExample} />

  <div class="mb-6 flex flex-col gap-6 lg:flex-row">
    <TabbedCodeBlock
      group="example"
      tabs={[
        { id: 'html', label: 'HTML', code: htmlCode },
        { id: 'css', label: 'CSS', code: cssCode },
      ]}
    />
    <ResultPreview description="Los elementos se deslizan desde la izquierda con un retraso escalonado.">
      <div class="flex flex-col gap-4">
        <div class="animate-slideIn rounded-lg bg-[var(--color-text)] px-6 py-3 text-[var(--dm-dark-500)] text-sm font-medium">
          Elemento Deslizante 1
        </div>
        <div class="animate-slideIn2 rounded-lg bg-[var(--color-text)] px-6 py-3 text-[var(--dm-dark-500)] text-sm font-medium">
          Elemento Deslizante 2
        </div>
        <div class="animate-slideIn3 rounded-lg bg-[var(--color-text)] px-6 py-3 text-[var(--dm-dark-500)] text-sm font-medium">
          Elemento Deslizante 3
        </div>
      </div>
    </ResultPreview>
  </div>

  <div class="my-8 flex flex-col gap-6">
    <ConsejoProfesional tip='Usa <code>translate()</code> en lugar de <code>top/left/right/bottom</code> para animaciones. Las transformaciones son aceleradas por hardware y ofrecen mejor rendimiento que las propiedades de posicionamiento.' />

    <ErroresComunesV3 errors={[
      { label: 'Olvidar la unidad', description: 'Siempre especifica una unidad (px, %, em, etc.). Los valores sin unidad pueden causar comportamientos inesperados.' },
      { label: 'Confundir % en translate con % en top/left', description: 'En translate, el porcentaje se calcula sobre el tamaño del elemento, no del contenedor.' },
      { label: 'No usar GPU acceleration', description: 'Para mejores performances, combina translate con will-change o transform: translateZ(0).' },
      { label: 'Usar top/left en lugar de translate', description: 'Animar top/left causa reflow del layout y es mucho menos performante que usar translate.' },
      { label: 'Olvidar el orden de las transformaciones', description: 'El orden importa: translate() rotate() no es lo mismo que rotate() translate().' },
      { label: 'Desbordamiento (Overflow)', description: 'Mover un elemento fuera de la pantalla puede crear barras de desplazamiento horizontales no deseadas.' },
      { label: 'Problemas con elementos inline', description: 'La propiedad transform solo funciona en elementos block o inline-block, no en elementos puramente inline como un <span>.' },
      { label: 'Valores fraccionarios borrosos', description: 'Usar porcentajes o valores fraccionarios puede hacer que el texto se vea borroso. Usa valores enteros o translateZ(0).' },
    ]} />

    <PracticeCards
      title="Practica lo Aprendido"
      description="Crea un carrusel de elementos que se deslicen desde la derecha. Cada elemento debe entrar con un ligero retraso escalonado."
      steps={practiceSteps}
    />
  </div>
</CourseLayout>

<style>
  @keyframes slideIn {
    from {
      transform: translateX(-100%);
      opacity: 0;
    }
    to {
      transform: translateX(0);
      opacity: 1;
    }
  }

  .animate-slideIn {
    animation: slideIn 0.6s ease-out forwards;
  }

  .animate-slideIn2 {
    animation: slideIn 0.6s ease-out 0.2s forwards;
    opacity: 0;
  }

  .animate-slideIn3 {
    animation: slideIn 0.6s ease-out 0.4s forwards;
    opacity: 0;
  }
</style>

<script>
  import { initCodeInteractions } from '../../../scripts/code-interactions.js';
  document.addEventListener('astro:page-load', () => initCodeInteractions());
</script>
