---
import CourseLayout from '../../../layouts/CourseLayout.astro';

const translateExample = `/* Movimiento horizontal */
.element {
  transform: translateX(100px);
}

/* Movimiento vertical */
.element {
  transform: translateY(-50px);
}

/* Movimiento en ambos ejes */
.element {
  transform: translate(100px, -50px);
}

/* Porcentajes */
.element {
  transform: translateX(50%);
}`;

const animationExample = `@keyframes slideIn {
  from {
    transform: translateX(-100%);
    opacity: 0;
  }
  to {
    transform: translateX(0);
    opacity: 1;
  }
}

.slide-element {
  animation: slideIn 0.6s ease-out forwards;
}`;

const htmlCode = `<div class="slider">
  <div class="slider-item">Elemento 1</div>
  <div class="slider-item">Elemento 2</div>
  <div class="slider-item">Elemento 3</div>
</div>`;

const cssCode = `.slider-item {
  transform: translateX(-100%);
  opacity: 0;
  animation: slideIn 0.6s ease-out forwards;
}

.slider-item:nth-child(2) {
  animation-delay: 0.2s;
}

.slider-item:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes slideIn {
  to {
    transform: translateX(0);
    opacity: 1;
  }
}`;
---

<CourseLayout
  title="Translate - Transforms - CSS Animation"
  currentLesson="/css-animation/transforms/translate"
  prevLesson={{ title: 'Introducción', href: '/css-animation/transforms' }}
  nextLesson={{ title: 'Scale', href: '/css-animation/transforms/scale' }}
>
  <div class="mb-8">
    <div class="inline-flex items-center gap-2 text-sm text-[var(--dm-light-300)]">
      <span class="flex h-6 w-6 items-center justify-center rounded-md bg-[var(--color-text)]/10 text-xs font-semibold text-[var(--color-text)]">02</span>
      Capítulo 2 · Lección 1
    </div>
    <h1 class="mt-4 font-afronaut text-4xl font-light text-[var(--color-text)] sm:text-5xl">Translate</h1>
    <div class="mt-4 flex flex-wrap gap-3 text-sm text-[var(--dm-light-300)]">
      <span class="flex items-center gap-1">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        10 min de lectura
      </span>
      <span class="rounded-full bg-[var(--dm-green)]/20 px-3 py-1 text-xs font-medium text-[var(--dm-green)]">Principiante</span>
    </div>
  </div>

  <article class="prose prose-invert max-w-none">
    <h3>¿Qué es Translate?</h3>
    <p>
      La función <code>translate()</code> es una de las transformaciones CSS más utilizadas. Permite mover un elemento desde su posición original sin afectar el flujo del documento. A diferencia de cambiar las propiedades <code>top</code>, <code>left</code>, <code>right</code> o <code>bottom</code>, translate no afecta el layout y es significativamente más performante.
    </p>
    <p>
      Translate funciona en el espacio 2D, permitiéndote mover elementos horizontalmente con <code>translateX()</code>, verticalmente con <code>translateY()</code>, o en ambos ejes simultáneamente con <code>translate()</code>. También acepta porcentajes, lo que lo hace especialmente útil para centrar elementos o crear layouts responsive.
    </p>

    <h3>Valores y Unidades</h3>
    <p>
      Puedes usar diferentes unidades con translate: píxeles (<code>px</code>), ems (<code>em</code>), rems (<code>rem</code>), porcentajes (<code>%</code>), y unidades viewport (<code>vw</code>, <code>vh</code>). Los porcentajes se calculan sobre el tamaño del propio elemento, no del contenedor, lo que lo hace ideal para centrar elementos.
    </p>
    <p>
      También puedes usar valores negativos para mover el elemento en la dirección opuesta. Por ejemplo, <code>translateX(-50%)</code> mueve el elemento a la izquierda la mitad de su propio ancho.
    </p>

    <h3>Translate en Animaciones</h3>
    <p>
      Cuando usas translate en animaciones, es una de las transformaciones más performantes porque puede ser acelerada por hardware (GPU). Esto significa que el navegador puede optimizar su renderizado y evitar reflujo del layout, resultando en animaciones más suaves, especialmente en dispositivos móviles.
    </p>
  </article>

  <h2 class="mt-8 mb-4 font-afronaut text-2xl font-light text-[var(--color-text)]">Ejemplos Prácticos</h2>
  
  <div class="mb-6">
    <div class="flex items-center justify-between">
      <h3 class="mb-4 text-sm font-medium text-[var(--color-text)]">Sintaxis de Translate</h3>
      <button class="copy-btn mb-4 flex items-center gap-1.5 rounded-md bg-white/10 px-3 py-1 text-xs font-light text-soft-white hover:bg-white/20 transition-colors" data-code={translateExample}>
        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
        </svg>
        Copiar
      </button>
    </div>
    <pre class="overflow-x-auto rounded-lg bg-[var(--dm-dark-500)] p-4 text-sm text-[var(--dm-light-200)]"><code>{translateExample}</code></pre>
  </div>

  <div class="mb-6">
    <div class="flex items-center justify-between">
      <h3 class="mb-4 text-sm font-medium text-[var(--color-text)]">Animación con Translate</h3>
      <button class="copy-btn mb-4 flex items-center gap-1.5 rounded-md bg-white/10 px-3 py-1 text-xs font-light text-soft-white hover:bg-white/20 transition-colors" data-code={animationExample}>
        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
        </svg>
        Copiar
      </button>
    </div>
    <pre class="overflow-x-auto rounded-lg bg-[var(--dm-dark-500)] p-4 text-sm text-[var(--dm-light-200)]"><code>{animationExample}</code></pre>
  </div>

  <div class="mb-6 flex flex-col gap-6 lg:flex-row">
    <div class="flex-1">
      <div class="mb-4 flex items-center gap-2">
        <button class="code-tab active rounded-md px-3 py-1.5 text-xs font-light text-soft-white transition-colors" data-tab="html">HTML</button>
        <button class="code-tab rounded-md px-3 py-1.5 text-xs font-light text-soft-white transition-colors" data-tab="css">CSS</button>
        <div class="flex-1"></div>
        <button class="copy-btn flex items-center gap-1.5 rounded-md bg-white/10 px-3 py-1 text-xs font-light text-soft-white hover:bg-white/20 transition-colors">
          <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
          </svg>
          Copiar
        </button>
      </div>
      <div class="code-content" data-tab="html">
        <pre class="overflow-x-auto rounded-lg bg-[var(--dm-dark-500)] p-4 text-sm text-[var(--dm-light-200)]"><code>{htmlCode}</code></pre>
      </div>
      <div class="code-content hidden" data-tab="css">
        <pre class="overflow-x-auto rounded-lg bg-[var(--dm-dark-500)] p-4 text-sm text-[var(--dm-light-200)]"><code>{cssCode}</code></pre>
      </div>
    </div>
    <div class="flex-1">
      <h3 class="mb-4 text-sm font-medium text-[var(--color-text)]">Resultado</h3>
      <div class="flex flex-col gap-4 rounded-lg bg-[var(--dm-dark-500)] p-8">
        <div class="animate-slideIn rounded-lg bg-[var(--color-text)] px-6 py-3 text-[var(--dm-dark-500)] text-sm font-medium">
          Elemento Deslizante 1
        </div>
        <div class="animate-slideIn2 rounded-lg bg-[var(--color-text)] px-6 py-3 text-[var(--dm-dark-500)] text-sm font-medium">
          Elemento Deslizante 2
        </div>
        <div class="animate-slideIn3 rounded-lg bg-[var(--color-text)] px-6 py-3 text-[var(--dm-dark-500)] text-sm font-medium">
          Elemento Deslizante 3
        </div>
      </div>
      <p class="mt-4 text-sm text-[var(--dm-light-300)]">
        Los elementos se deslizan desde la izquierda con un retraso escalonado.
      </p>
    </div>
  </div>

  <div class="my-8 flex flex-col gap-6">
    <div class="border-l-[3px] border-[var(--color-text)] bg-[var(--dm-green-bg)] p-6">
      <h3 class="mb-4 text-sm font-medium text-[var(--color-text)]">
        Consejo Profesional
      </h3>
      <p class="text-sm text-soft-white">
        Usa <code>translate()</code> en lugar de <code>top/left/right/bottom</code> para animaciones. Las transformaciones son aceleradas por hardware y ofrecen mejor rendimiento que las propiedades de posicionamiento.
      </p>
    </div>

    <div class="p-6">
      <h3 class="mb-4 font-medium text-[var(--color-text)]">
        Errores Comunes
      </h3>
      <ul class="space-y-2 text-sm text-soft-white">
        <li class="flex items-start gap-2">
          <span class="mt-1 text-yellow-500">•</span>
          <span><strong>Olvidar la unidad:</strong> Siempre especifica una unidad (px, %, em, etc.). Los valores sin unidad pueden causar comportamientos inesperados.</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="mt-1 text-yellow-500">•</span>
          <span><strong>Confundir % en translate con % en top/left:</strong> En translate, el porcentaje se calcula sobre el tamaño del elemento, no del contenedor.</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="mt-1 text-yellow-500">•</span>
          <span><strong>No usar GPU acceleration:</strong> Para mejores performances, combina translate con will-change o transform: translateZ(0).</span>
        </li>
      </ul>
    </div>

    <div class="p-6">
      <h3 class="mb-4 font-medium text-[var(--color-text)]">
        Practica lo Aprendido
      </h3>
      <p class="mb-4 text-sm text-soft-white">
        Crea un carrusel de elementos que se deslicen desde la derecha. Cada elemento debe entrar con un ligero retraso escalonado.
      </p>
      <div class="flex gap-3">
        <div class="flex-1 p-3 text-center text-xs h-[120px] flex flex-col items-center justify-center transition-transform" style="background: var(--dm-purple); transform: rotate(10deg); transition: transform 0.2s ease-in-out;" onmouseenter="this.style.transform='rotate(0deg)'" onmouseleave="this.style.transform='rotate(10deg)'">
          <span class="mb-1 block text-lg font-medium font-afronaut" style="color: var(--color-bg);">1</span>
          <span style="color: var(--color-bg);">Crea 5 elementos div con diferentes textos</span>
        </div>
        <div class="flex-1 p-3 text-center text-xs h-[120px] flex flex-col items-center justify-center transition-transform" style="background: var(--dm-green); transform: rotate(2deg); transition: transform 0.2s ease-in-out;" onmouseenter="this.style.transform='rotate(0deg)'" onmouseleave="this.style.transform='rotate(2deg)'">
          <span class="mb-1 block text-lg font-medium font-afronaut" style="color: var(--color-bg);">2</span>
          <span style="color: var(--color-bg);">Define un @keyframes que use translateX para moverlos</span>
        </div>
        <div class="flex-1 p-3 text-center text-xs h-[120px] flex flex-col items-center justify-center transition-transform" style="background: var(--app-color-yellow400); transform: rotate(-5deg); transition: transform 0.2s ease-in-out;" onmouseenter="this.style.transform='rotate(0deg)'" onmouseleave="this.style.transform='rotate(-5deg)'">
          <span class="mb-1 block text-lg font-medium font-afronaut" style="color: var(--color-bg);">3</span>
          <span style="color: var(--color-bg);">Aplica animation-delay escalonado a cada elemento</span>
        </div>
        <div class="flex-1 p-3 text-center text-xs h-[120px] flex flex-col items-center justify-center transition-transform" style="background: var(--dm-blue); transform: rotate(2deg); transition: transform 0.2s ease-in-out;" onmouseenter="this.style.transform='rotate(0deg)'" onmouseleave="this.style.transform='rotate(2deg)'">
          <span class="mb-1 block text-lg font-medium font-afronaut" style="color: var(--color-bg);">4</span>
          <span style="color: var(--color-bg);">Experimenta con diferentes valores de translate</span>
        </div>
        <div class="flex-1 p-3 text-center text-xs h-[120px] flex flex-col items-center justify-center transition-transform" style="background: var(--dm-red); transform: rotate(-5deg); transition: transform 0.2s ease-in-out;" onmouseenter="this.style.transform='rotate(0deg)'" onmouseleave="this.style.transform='rotate(-5deg)'">
          <span class="mb-1 block text-lg font-medium font-afronaut" style="color: var(--color-bg);">5</span>
          <span style="color: var(--color-bg);">Añade efectos de opacidad para cada entrada</span>
        </div>
      </div>
    </div>
  </div>
</CourseLayout>

<style>
  @keyframes slideIn {
    from {
      transform: translateX(-100%);
      opacity: 0;
    }
    to {
      transform: translateX(0);
      opacity: 1;
    }
  }

  .animate-slideIn {
    animation: slideIn 0.6s ease-out forwards;
  }

  .animate-slideIn2 {
    animation: slideIn 0.6s ease-out 0.2s forwards;
    opacity: 0;
  }

  .animate-slideIn3 {
    animation: slideIn 0.6s ease-out 0.4s forwards;
    opacity: 0;
  }

  .code-tab.active {
    background: rgba(255, 255, 255, 0.1);
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('.copy-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        let codeToCopy = btn.getAttribute('data-code');
        
        if (!codeToCopy) {
          const container = btn.closest('.flex-1');
          const activeTab = container?.querySelector('.code-content:not(.hidden) code');
          if (activeTab) {
            codeToCopy = activeTab.textContent || '';
          }
        }

        if (codeToCopy) {
          await navigator.clipboard.writeText(codeToCopy);
          const originalText = btn.innerHTML;
          btn.innerHTML = '<svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Copiado!';
          btn.classList.add('bg-[var(--dm-green)]');
          setTimeout(() => {
            btn.innerHTML = originalText;
            btn.classList.remove('bg-[var(--dm-green)]');
          }, 2000);
        }
      });
    });

    document.querySelectorAll('.code-tab').forEach((tab) => {
      tab.addEventListener('click', () => {
        const container = tab.closest('.flex-1');
        container?.querySelectorAll('.code-tab').forEach(t => t.classList.remove('active'));
        container?.querySelectorAll('.code-content').forEach(c => c.classList.add('hidden'));
        tab.classList.add('active');
        container?.querySelector(`.code-content[data-tab="${tab.getAttribute('data-tab')}"]`)?.classList.remove('hidden');
      });
    });
  });
</script>
