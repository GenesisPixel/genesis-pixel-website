---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const examples = [
  { id: 1, title: 'Transiciones CSS', category: 'css', difficulty: 'basico' },
  { id: 2, title: 'Keyframes Animations', category: 'css', difficulty: 'basico' },
  { id: 3, title: 'SVG Path Animation', category: 'svg', difficulty: 'intermedio' },
  { id: 4, title: 'Canvas Particles', category: 'canvas', difficulty: 'intermedio' },
  { id: 5, title: 'Three.js Scene', category: 'threejs', difficulty: 'avanzado' },
  { id: 6, title: 'GSAP ScrollTrigger', category: 'gsap', difficulty: 'intermedio' },
  { id: 7, title: 'WebGL Shader', category: 'webgl', difficulty: 'avanzado' },
  { id: 8, title: 'CSS Grid Animation', category: 'css', difficulty: 'intermedio' },
  { id: 9, title: 'SVG Morphing', category: 'svg', difficulty: 'avanzado' },
  { id: 10, title: 'Canvas Fireworks', category: 'canvas', difficulty: 'intermedio' },
  { id: 11, title: 'Three.js Model', category: 'threejs', difficulty: 'avanzado' },
  { id: 12, title: 'GSAP Timeline', category: 'gsap', difficulty: 'basico' },
];

const categoryLabels: Record<string, string> = {
  css: 'CSS',
  svg: 'SVG',
  canvas: 'Canvas',
  threejs: 'Three.js',
  gsap: 'GSAP',
  webgl: 'WebGL',
};

const difficultyColors = {
  basico: 'bg-[var(--dm-green)]/20 text-[var(--dm-green)]',
  intermedio: 'bg-[var(--dm-yellow)]/20 text-[var(--dm-yellow)]',
  avanzado: 'bg-[var(--dm-red)]/20 text-[var(--dm-red)]',
};
---

<Layout title="Ejemplos - GenesisPixel">
  <Navbar />

  <main class="mx-auto max-w-7xl px-6 pb-24 pt-24">
    <div class="mb-12">
      <h1 class="font-acorn text-4xl font-bold text-[var(--color-text)] sm:text-5xl">Ejemplos</h1>
      <p class="mt-4 text-lg text-[var(--dm-light-300)]">
        Explora ejemplos interactivos de animaciones y técnicas de desarrollo creativo.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {examples.map((example) => (
        <a
          href={`/ejemplos/${example.id}`}
          class="group overflow-hidden rounded-[var(--radius-base)] border border-white/5 bg-white/[0.02] transition-all hover:border-white/10 hover:bg-white/[0.04]"
        >
          <div class="aspect-video bg-gradient-to-br from-white/5 to-transparent">
            <div class="flex h-full items-center justify-center text-[var(--dm-light-300)]">
              <svg class="h-12 w-12 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
              </svg>
            </div>
          </div>

          <div class="p-4">
            <div class="flex items-center gap-2">
              <span class="text-xs font-medium text-[var(--dm-light-300)]">{categoryLabels[example.category]}</span>
              <span class="text-[var(--dm-light-300)]">·</span>
              <span class={`text-xs font-medium ${difficultyColors[example.difficulty as keyof typeof difficultyColors]}`}>
                {example.difficulty}
              </span>
            </div>
            <h3 class="mt-2 text-sm font-medium text-[var(--color-text)] group-hover:text-white">
              {example.title}
            </h3>
          </div>
        </a>
      ))}
    </div>
  </main>

  <Footer />
</Layout>
