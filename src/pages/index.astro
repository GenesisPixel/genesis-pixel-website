---
import Layout from '../layouts/Layout.astro';
import GradientBlur from '../components/GradientBlur.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import BentoCards from '../components/BentoCards.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="GenesisPixel - Aprende Animaciones Web y Desarrollo Creativo">
  <GradientBlur />
  <Navbar />

  <Hero
    title="GenesisPixel"
    description="Aprende animaciones web y desarrollo creativo paso a paso. Desde CSS básico hasta experiencias 3D profesionales."
    primaryCTA={{ label: 'Comenzar a Aprender', href: '/aprender' }}
    secondaryCTA={{ label: 'Explorar Ejemplos', href: '/ejemplos' }}
  />

  <main class="w-full pb-24">
    <BentoCards />
  </main>

  <Footer />
</Layout>
