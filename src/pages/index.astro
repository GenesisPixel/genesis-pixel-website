---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import BentoCards from '../components/BentoCards.astro';
import Footer from '../components/Footer.astro';
import Container from '../components/Container.astro';
---

<Layout title="GenesisPixel | Inicio">
  <Hero
    title="El arte de crear con código"
    description="Aprende animaciones web y desarrollo creativo paso a paso. Desde CSS básico hasta experiencias 3D profesionales."
    primaryCTA={{ label: 'Comenzar a Aprender', href: '/keyframes/que-son' }}
    secondaryCTA={{ label: 'three.js', href: '/threejs' }}
    tertiaryCTA={{ label: 'Keyframes', href: '/keyframes/que-son' }}
  />

  <main class="pb-24">
    <BentoCards />
  </main>

  <Footer />
</Layout>
