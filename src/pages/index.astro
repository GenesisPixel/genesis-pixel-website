---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import BentoCards from '../components/BentoCards.astro';
import Footer from '../components/Footer.astro';
import Container from '../components/Container.astro';
---

<Layout title="GenesisPixel - Aprende Animaciones Web y Desarrollo Creativo">
  <Navbar />

  <Hero
    title="El Arte de Crear con Código"
    description="Aprende animaciones web y desarrollo creativo paso a paso. Desde CSS básico hasta experiencias 3D profesionales."
    primaryCTA={{ label: 'Comenzar a Aprender', href: '/aprender' }}
    secondaryCTA={{ label: 'Explorar Ejemplos', href: '/ejemplos' }}
    tertiaryCTA={{ label: 'CSS Animation', href: '/css-animation' }}
  />

  <main class="pb-24">
    <Container>
      <BentoCards />
    </Container>
  </main>

  <Footer />
</Layout>
