  transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275),
              box-shadow 0.4s ease;
}

/* HOVER INTERACTIONS */
.magic-card-p:hover {
  transform: translateY(-10px) scale(1.02);
  box-shadow: 0 20px 40px rgba(139, 92, 246, 0.2);
  border-color: rgba(139, 92, 246, 0.5);
}

.magic-card-p:hover .card-glow {
  opacity: 0.4;
  /* Keyframe 1: Glow animado al hacer hover */
  animation: pulseGlow 2s infinite alternate ease-in-out;
}

.magic-card-p:hover .magic-icon {
  color: white;
  transform: translateY(-5px);
  /* Keyframe 2: Icono flotando al hacer hover */
  animation: float 3s infinite ease-in-out;
}

/* KEYFRAMES */
@keyframes pulseGlow {
  0% { transform: scale(1); }
  100% { transform: scale(1.5); }
}

@keyframes float {
  0%, 100% { transform: translateY(-5px); }
  50% { transform: translateY(-15px); }
}
</style>

<script>
  import { initCodeInteractions } from '../../scripts/code-interactions.js';
  
  document.addEventListener('astro:page-load', () => {
    initCodeInteractions();
    
  });
  document.addEventListener('astro:after-swap', () => {
    initCodeInteractions();
    
  });
</script>