---
import InteractionsLayout from '../../layouts/InteractionsLayout.astro';
import ChapterHeader from '../../components/ChapterHeader.astro';
import TabbedCodeBlock from '../../components/TabbedCodeBlock.astro';
import ResultPreview from '../../components/ResultPreview.astro';
import ConsejoProfesional from '../../components/ConsejoProfesional.astro';
import ErroresComunesV3 from '../../components/ErroresComunesV3.astro';
import PracticeCards from '../../components/PracticeCards.astro';

const btnHtml = `<button class="btn-guardar" id="btnGuardar">
  <span class="btn-texto">Guardar Cambios</span>
  <span class="btn-cargando"></span>
  <svg class="btn-exito" viewBox="0 0 24 24" width="20" height="20">
    <path d="M20 6L9 17l-5-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
</button>

<script>
  const btn = document.getElementById('btnGuardar');
  btn.addEventListener('click', () => {
    btn.classList.add('loading');
    setTimeout(() => {
      btn.classList.remove('loading');
      btn.classList.add('success');
      setTimeout(() => btn.classList.remove('success'), 2000);
    }, 2000);
  });
<\/script>`;

const btnCss = `.btn-guardar {
  position: relative; padding: 14px 28px; background: #9FA6FF; color: hsla(158,23%,18%,1);
  border: none; border-radius: 0; font-weight: 600; cursor: pointer;
  overflow: hidden; transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  display: flex; justify-content: center; align-items: center; min-width: 180px;
  font-family: 'afronaut', serif;
}

.btn-guardar:hover {
  transform: translateY(-2px); box-shadow: none;
}

.btn-guardar:active {
  transform: scale(0.95); box-shadow: 0 2px 4px rgba(159,166,255,0.3);
}

.btn-texto { transition: all 0.3s ease; }
.btn-cargando {
  position: absolute; width: 18px; height: 18px;
  border: 2px solid rgba(158,23%,18%,0.3); border-top-color: hsla(158,23%,18%,1); border-radius: 50%;
  opacity: 0; transform: scale(0.5); transition: all 0.3s ease;
}
.btn-exito {
  position: absolute; opacity: 0; transform: scale(0.5); transition: all 0.3s ease;
}

/* Estado Loading */
.btn-guardar.loading { background: #8090e0; pointer-events: none; }
.btn-guardar.loading .btn-texto { opacity: 0; transform: translateY(-20px); }
.btn-guardar.loading .btn-cargando { opacity: 1; transform: scale(1); animation: girar 1s linear infinite; }

/* Estado Success */
.btn-guardar.success { background: #10b981; pointer-events: none; }
.btn-guardar.success .btn-texto { opacity: 0; transform: translateY(-20px); }
.btn-guardar.success .btn-exito { opacity: 1; transform: scale(1); }

@keyframes girar { to { transform: rotate(360deg); } }`;

const modalHtml = `<button class="abrir-modal" id="abrirModal">Ver Detalles</button>

<div class="modal-overlay" id="modalOverlay">
  <div class="modal-caja">
    <h5 style="margin-top:0; margin-bottom:4px; font-weight:700; text-align:center;">Detalles del Componente</h5>
    <span style="font-weight:300; font-family:'afronaut',serif; text-align:center; display:block;">
      Este modal se anima de forma independiente al overlay para dar una sensación física real.
    </span>
    <div class="modal-actions" style="display:flex; flex-direction:row; justify-content:flex-end; gap:12px; margin-top:24px;">
      <button class="cerrar-modal" id="cerrarModal"
        style="padding:10px 20px; border-radius:0; background:transparent; border:1px dashed #444; color:#444; font-family:'afronaut',serif;">
        Cancelar
      </button>
      <button class="aceptar-modal"
        style="padding:10px 20px; border-radius:0; background:hsla(158,23%,18%,1); color:hsla(160,52%,71%,1); font-family:'afronaut',serif;">
        Aceptar
      </button>
    </div>
  </div>
</div>

<script>
  const abrir = document.getElementById('abrirModal');
  const cerrar = document.getElementById('cerrarModal');
  const aceptar = document.querySelector('.aceptar-modal');
  const overlay = document.getElementById('modalOverlay');

  abrir.addEventListener('click', () => overlay.classList.add('visible'));
  cerrar.addEventListener('click', () => overlay.classList.remove('visible'));
  aceptar.addEventListener('click', () => overlay.classList.remove('visible'));
  overlay.addEventListener('click', (e) => {
    if(e.target === overlay) overlay.classList.remove('visible');
  });
<\/script>`;

const modalCss = `.abrir-modal {
  padding: 10px 20px; border-radius: 0; border: none;
  background: #9FA6FF; color: hsla(158,23%,18%,1);
  cursor: pointer; font-family: 'afronaut', serif;
}

/* Overlay */
.modal-overlay {
  position: fixed; inset: 0;
  background: hsla(158,23%,18%,0.9);
  backdrop-filter: blur(8px);
  display: flex; justify-content: center; align-items: center;
  z-index: 1000;
  opacity: 0; visibility: hidden;
  transition: all 0.4s ease;
}

/* Caja Modal */
.modal-caja {
  background: hsla(160,52%,71%,1);
  padding: 32px; border-radius: 0;
  width: 300px; height: 300px;
  text-align: center; color: hsla(158,23%,18%,1);
  border: 1px solid rgba(255,255,255,0.1);
  box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);
  backdrop-filter: blur(10px);
  display: flex; flex-direction: column; justify-content: space-between;
  transform: rotate(-5deg) scale(0.9) translateY(20px);
  opacity: 0;
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

/* Animación de entrada secuencial */
.modal-overlay.visible { opacity: 1; visibility: visible; }
.modal-overlay.visible .modal-caja {
  transform: rotate(-5deg) scale(1) translateY(0);
  opacity: 1; transition-delay: 0.1s;
}`;

const practiceSteps = [
  { number: 1, text: 'Integra el botón interactivo dentro de la caja del modal', color: 'dm-purple', rotate: '2deg' },
  { number: 2, text: 'Añade el estado de "Focus" al botón para mejorar accesibilidad', color: 'dm-green', rotate: '-3deg' },
  { number: 3, text: 'Modifica la curva del modal de rebote a ease-in-out', color: 'app-color-yellow400', rotate: '4deg' },
  { number: 4, text: 'Supera el desafío final haciendo que el modal se cierre automáticamente tras el éxito', color: 'dm-blue', rotate: '-1deg' },
];
---

<InteractionsLayout
  title="GenesisPixel | Proyecto Final de Interactions "
  currentLesson="/interactions/proyecto-final"
  prevLesson={{ title: 'Performance', href: '/interactions/performance' }}
>
  <ChapterHeader
    chapterNumber="04"
    chapterLabel="Capítulo 4 · Proyecto Final"
    title="Proyecto Final de Interactions"
    readingTime={10}
    difficulty="Interactions"
  />

  <article class="prose prose-invert max-w-none" style="margin-top: 64px;">
    <h3>El arte de la orquestación UI</h3>
    <p>
      ¡Felicidades! Has llegado al final del Capítulo 4. A lo largo de estas lecciones, no solo has aprendido a mover cosas en la pantalla, sino a darles <strong>sentido, peso y contexto</strong>. Has dejado de diseñar pantallas estáticas para empezar a diseñar flujos interactivos.
    </p>

    <h3>1. Botones con retroalimentación completa</h3>
    <p>
      El botón "Guardar" que vas a ver combina estados de hover (elevación), active (presión física), loading (asumiendo la asincronía) y success (informando al usuario que todo salió bien). Todo en un mismo componente sin tener que bloquear toda la interfaz del usuario. Es el pilar de un formulario moderno.
    </p>

    <h3>2. Modales secuenciales</h3>
    <p>
      Un modal no es solo un div en el centro de la pantalla. En el proyecto 2, verás cómo la opacidad del fondo oscuro y la caja del modal tienen ritmos diferentes (delay). Esto guía el ojo del usuario primero hacia el centro oscuro y luego le entrega el contenido con una animación de rebote amigable.
    </p>

    <h3>El verdadero secreto: la consistencia</h3>
    <p>
      El sello final de calidad en cualquier interfaz premium es que los botones se sientan parte del mismo universo físico que los modales. Si usas un <code>cubic-bezier</code> elástico en un lado, úsalo en el otro. Mantén los tiempos entre 150ms y 400ms para que las interacciones sean enérgicas pero perceptibles.
    </p>
  </article>

  <div class="my-8 not-prose">
    <ConsejoProfesional tip="¡Has dominado el feedback visual! Estas microinteracciones son lo que diferencia a una aplicación web genérica de un producto digital premium amado por los usuarios." />
  </div>

  <!-- Proyecto 1: Botón con feedback completo -->
  <div class="mt-16 mb-4 text-center">
    <h3 class="font-medium mb-2">Proyecto 1 — Botón con feedback completo</h3>
    <p class="text-sm mb-6" style="color: white; opacity: 0.7;">
      Un botón que reacciona físicamente, muestra estado de carga asíncrono y confirma el éxito sin necesidad de molestas alertas de navegador.
    </p>
  </div>

  <div class="mb-6 flex flex-col gap-6 lg:flex-row">
    <TabbedCodeBlock
      group="proyecto-boton"
      tabs={[
        { id: 'html', label: 'HTML', code: btnHtml },
        { id: 'css', label: 'CSS', code: btnCss },
      ]}
    />
    <ResultPreview description="Haz clic en el botón. Observa cómo asume el estado de carga y termina con una palomita de éxito.">
      <div class="flex items-center justify-center h-full w-full">
        <button class="btn-guardar-p" id="btnGuardarP">
          <span class="btn-texto-p">Guardar Cambios</span>
          <span class="btn-cargando-p"></span>
          <svg class="btn-exito-p" viewBox="0 0 24 24" width="20" height="20">
            <path d="M20 6L9 17l-5-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </ResultPreview>
  </div>

  <!-- Proyecto 2: Modal animado -->
  <div class="mt-16 mb-4 text-center">
    <h3 class="font-medium mb-2">Proyecto 2 — Modal con Delay</h3>
    <p class="text-sm mb-6" style="color: white; opacity: 0.7;">
      Un overlay que desenfoca la página y una caja que aparece con retraso secuencial para no abrumar la vista del usuario.
    </p>
  </div>

  <div class="mb-6 flex flex-col gap-6 lg:flex-row">
    <TabbedCodeBlock
      group="proyecto-modal"
      tabs={[
        { id: 'html', label: 'HTML', code: modalHtml },
        { id: 'css', label: 'CSS', code: modalCss },
      ]}
    />
    <ResultPreview description="Haz clic en 'Ver Detalles'. Fíjate cómo la caja llega ligeramente después de oscurecerse el fondo.">
      <div class="flex items-center justify-center h-full w-full">
        <button class="abrir-modal-p" id="abrirModalP">Ver Detalles</button>
        <div class="modal-overlay-p" id="modalOverlayP">
          <div class="modal-caja-p">
            <h5 style="margin-top:0; margin-bottom:4px; font-weight:700; text-align:center;">Detalles del Componente</h5>
            <span style="font-weight:300; font-family:'afronaut',serif; text-align:center; display:block;">Este modal se anima de forma independiente al overlay para dar una sensación física real.</span>
            <div class="modal-actions-p" style="display:flex; flex-direction:row; justify-content:flex-end; gap:12px; margin-top:24px;">
              <button class="cerrar-modal-p" id="cerrarModalP" style="padding:10px 20px; border-radius:0; cursor:pointer; background:transparent; border:1px dashed #444; color:#444; font-family:'afronaut',serif;">Cancelar</button>
              <button class="aceptar-modal-p" style="padding:10px 20px; border-radius:0; border:none; cursor:pointer; background:hsla(158,23%,18%,1); color:hsla(160,52%,71%,1); font-family:'afronaut',serif;">Aceptar</button>
            </div>
          </div>
        </div>
      </div>
    </ResultPreview>
  </div>

  <div class="my-8 flex flex-col gap-6">
    <PracticeCards
      title="Desafío Final"
      description="Combina ambos proyectos: pon el botón de guardar dentro del modal. Al hacer clic, que cargue, marque éxito y entonces cierre el modal."
      steps={practiceSteps}
    />
  </div>

  <!-- Resumen del capítulo -->
  <div class="py-6">
    <h3 class="mb-8 text-center font-medium text-[var(--color-text)]">
      Lo que aprendiste en este capítulo
    </h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-6">
      {[
        { prop: 'Interactions', desc: 'Interfaces vivas que responden a la acción del usuario' },
        { prop: 'Microinteracciones', desc: 'Pequeñas respuestas (likes, botones) que generan deleite' },
        { prop: 'Estados de Interfaz', desc: 'Default, hover, active, focus y disabled correctamente diseñados' },
        { prop: 'Loading States', desc: 'Loaders integrados que evitan bloquear toda la pantalla' },
        { prop: 'Success/Error Feedback', desc: 'Toasts o botones que cierran el ciclo asíncrono con color' },
        { prop: 'Cards interactivas', desc: 'Profundidad con hover combinado (scale de imagen + elevate)' },
        { prop: 'Modales & Overlays', desc: 'Apariciones secuenciales con transition-delay para suavidad' },
        { prop: 'Dropdowns & Tooltips', desc: 'El uso de transform-origin para una revelación orgánica' },
        { prop: 'Sistemas consistentes', desc: 'Motion Tokens (Variables CSS) para estandarizar las curvas' },
        { prop: 'Performance en UI', desc: 'Animar solo Transforms y Opacity para llegar a los 60 FPS' },
      ].map((item, index) => (
        <div class="flex gap-4">
          <span class="mt-0.5 shrink-0 font-afronaut text-[13px] text-[var(--color-text)]" style="opacity: 0.4 !important;">
            {String(index + 1).padStart(2, '0')}
          </span>
          <div class="flex flex-col gap-1">
            <span class="text-[14px] text-white" style="color: white; opacity: 1 !important; font-family: var(--font-afronaut, system-ui, sans-serif); font-weight: 300;">
              {item.prop}
            </span>
            <span class="text-[13px] leading-relaxed text-[var(--dm-light-200)]">
              {item.desc}
            </span>
          </div>
        </div>
      ))}
    </div>
  </div>
</InteractionsLayout>

<style>
  /* BTN PREVIEW */
  .btn-guardar-p {
    position: relative; padding: 14px 28px; background: #9FA6FF; color: hsla(158,23%,18%,1);
    border: none; border-radius: 0; font-weight: 600; cursor: pointer;
    overflow: hidden; transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    display: flex; justify-content: center; align-items: center; min-width: 180px;
    font-family: 'afronaut', serif !important;
  }
  .btn-guardar-p span, .btn-guardar-p svg {
    font-family: 'afronaut', serif !important;
  }
  .btn-guardar-p:hover { transform: translateY(-2px); box-shadow: none; }
  .btn-guardar-p:active { transform: scale(0.95); box-shadow: 0 2px 4px rgba(59,130,246,0.3); }
  
  .btn-texto-p { transition: all 0.3s ease; }
  .btn-cargando-p {
    position: absolute; width: 18px; height: 18px;
    border: 2px solid rgba(255,255,255,0.3); border-top-color: white; border-radius: 50%;
    opacity: 0; transform: scale(0.5); transition: all 0.3s ease;
  }
  .btn-exito-p { position: absolute; opacity: 0; transform: scale(0.5); transition: all 0.3s ease; }
  
  .btn-guardar-p.loading { background: #2563eb; pointer-events: none; }
  .btn-guardar-p.loading .btn-texto-p { opacity: 0; transform: translateY(-20px); }
  .btn-guardar-p.loading .btn-cargando-p { opacity: 1; transform: scale(1); animation: girar 1s linear infinite; }
  
  .btn-guardar-p.success { background: #10b981; pointer-events: none; }
  .btn-guardar-p.success .btn-texto-p { opacity: 0; transform: translateY(-20px); }
  .btn-guardar-p.success .btn-exito-p { opacity: 1; transform: scale(1); }
  @keyframes girar { to { transform: rotate(360deg); } }

  /* MODAL PREVIEW */
  .abrir-modal-p {
    padding: 10px 20px; border-radius: 0; border: none; font-weight: bold; cursor: pointer;
    background: #9FA6FF; color: hsla(158,23%,18%,1); transition: transform 0.2s;
    font-family: 'afronaut', serif;
  }
  .abrir-modal-p:hover { transform: scale(1.05); }
  
  .modal-overlay-p {
    position: fixed; inset: 0; background: hsla(158,23%,18%,0.9); backdrop-filter: blur(8px);
    display: flex; justify-content: center; align-items: center; z-index: 1000;
    opacity: 0; visibility: hidden; transition: all 0.4s ease;
  }
  
  .modal-caja-p {
    background: hsla(160,52%,71%,1); padding: 32px; border-radius: 0; width: 300px; height: 300px;
    text-align: center; color: hsla(158,23%,18%,1); border: 1px solid rgba(255,255,255,0.1);
    box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);
    backdrop-filter: blur(10px);
    display: flex; flex-direction: column; justify-content: space-between;
    transform: rotate(-5deg) scale(0.9) translateY(20px); opacity: 0;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  
  .modal-overlay-p.visible { opacity: 1; visibility: visible; }
  .modal-overlay-p.visible .modal-caja-p {
    transform: rotate(-5deg) scale(1) translateY(0); opacity: 1; transition-delay: 0.1s;
  }
</style>

<script>
  import { initCodeInteractions } from '../../scripts/code-interactions.js';
  
  const setupEvents = () => {
    initCodeInteractions();
    
    const btn = document.getElementById('btnGuardarP');
    if (btn) {
      btn.addEventListener('click', () => {
        btn.classList.add('loading');
        setTimeout(() => {
          btn.classList.remove('loading');
          btn.classList.add('success');
          setTimeout(() => btn.classList.remove('success'), 2000);
        }, 2000);
      });
    }

    const abrir = document.getElementById('abrirModalP');
    const cerrar = document.getElementById('cerrarModalP');
    const aceptar = document.querySelector('.aceptar-modal-p');
    const overlay = document.getElementById('modalOverlayP');
    
    if (abrir && cerrar && overlay) {
      abrir.addEventListener('click', () => overlay.classList.add('visible'));
      cerrar.addEventListener('click', () => overlay.classList.remove('visible'));
      if (aceptar) aceptar.addEventListener('click', () => overlay.classList.remove('visible'));
      overlay.addEventListener('click', (e) => {
        if(e.target === overlay) overlay.classList.remove('visible');
      });
    }
  };

  document.addEventListener('astro:page-load', setupEvents);
  document.addEventListener('astro:after-swap', setupEvents);
</script>
