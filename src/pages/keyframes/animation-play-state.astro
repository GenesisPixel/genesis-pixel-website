---
import CourseLayout from '../../layouts/CourseLayout.astro';
import ChapterHeader from '../../components/ChapterHeader.astro';
import TabbedCodeBlock from '../../components/TabbedCodeBlock.astro';
import ResultPreview from '../../components/ResultPreview.astro';
import ConsejoProfesional from '../../components/ConsejoProfesional.astro';
import ErroresComunesV3 from '../../components/ErroresComunesV3.astro';
import PracticeCards from '../../components/PracticeCards.astro';

const htmlCode = `<div class="interactive-control">
  <div class="control-box animate-box">Genesis</div>
  <button id="toggle-play-btn" class="control-btn">Pausar</button>
</div>`;

const cssCode = `@keyframes orbitSpin {
  0% { transform: rotate(0deg) translateX(40px) rotate(0deg); }
  100% { transform: rotate(360deg) translateX(40px) rotate(-360deg); }
}

.interactive-control {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24px;
}

.control-box {
  width: 60px;
  height: 60px;
  border-radius: 50%;
  background-color: #a855f7;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #121212;
  font-family: system-ui, sans-serif;
  font-weight: bold;
  font-size: 0.75rem;
  
  /* Animación */
  animation: orbitSpin 6s infinite linear;
  animation-play-state: running; /* Estado por defecto */
}

/* Al pausar */
.control-box.paused {
  animation-play-state: paused;
  background-color: #ef4444;
}

.control-btn {
  padding: 8px 16px;
  background-color: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 8px;
  color: #121212;
  font-family: system-ui, sans-serif;
  font-size: 0.8125rem;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s ease;
}

.control-btn:hover {
  background-color: rgba(255, 255, 255, 0.15);
}`;

const practiceSteps = [
  { number: 1, text: 'Usa animation-play-state: paused para congelar una animación en su punto actual', color: 'dm-purple', rotate: '2deg' },
  { number: 2, text: 'Prueba a cambiar a paused al hacer hover (:hover) sobre el elemento', color: 'dm-green', rotate: '-3deg' },
  { number: 3, text: 'Implementa un interruptor por JavaScript alternando la clase con animation-play-state', color: 'app-color-yellow400', rotate: '5deg' },
];

const hoverPauseCode = `.marquee-container:hover .marquee-track {
  animation-play-state: paused;
}`;
---

<CourseLayout
  title="Animation Play State - Genesis Pixel"
  currentLesson="/keyframes/animation-play-state"
  prevLesson={{ title: 'Animation Fill Mode', href: '/keyframes/animation-fill-mode' }}
  nextLesson={{ title: 'Shorthand Animation', href: '/keyframes/shorthand-animation' }}
>
  <ChapterHeader
    chapterNumber="01"
    chapterLabel="Capítulo 1 · Lección 13"
    title="Animation Play State"
    readingTime={6}
  />

  <article class="prose prose-invert max-w-none" style="margin-top: 64px;">
    <h3>El botón de pausa de tu animación</h3>
    <p>
      Imagina que estás viendo un video y alguien te habla. Pulsas pausa, respondes, y cuando vuelves a pulsar play, el video no empieza desde el principio; continúa exactamente donde lo dejaste. Eso es exactamente lo que hace <code>animation-play-state</code>.
    </p>
    <p>
      A diferencia de quitarle el nombre de la animación a un elemento (lo cual resetearía la animación de vuelta a 0 de inmediato), alterar el <code>play-state</code> congela los valores de todos los estilos interpolados en ese milisegundo exacto de la línea de tiempo. 
    </p>

    <h3>Los dos únicos estados</h3>
    <ul class="space-y-3 mt-4 mb-8 list-none pl-0">
      <li class="flex gap-3">
        <span>✦</span>
        <span><strong>running:</strong> (Por defecto) La animación avanza por su línea de tiempo normalmente.</span>
      </li>
      <li class="flex gap-3">
        <span>✦</span>
        <span><strong>paused:</strong> La animación se congela. El reloj se detiene y el elemento mantiene exactamente los estilos interpolados que tenía en ese instante.</span>
      </li>
    </ul>

    <h3>El caso de uso más importante: accesibilidad y UX</h3>
    <p>
      Hay una regla fundamental en accesibilidad web y diseño premium: <strong>nunca asumas que a todos los usuarios les gusta el movimiento constante</strong>. Para personas con desórdenes vestibulares o problemas de atención, una marquesina de logos moviéndose infinitamente hace que leer el resto de la página sea sumamente difícil.
    </p>
    <p>
      El patrón de diseño más elegante para solucionar esto es pausar las animaciones cuando el usuario posiciona el cursor sobre ellas (<code>:hover</code>). Esto le devuelve el control al usuario de forma intuitiva sin necesidad de escribir una sola línea de JavaScript:
    </p>
    <div class="my-6">
      <TabbedCodeBlock
        group="hover-pause"
        tabs={[
          { id: 'css', label: 'CSS', code: hoverPauseCode },
        ]}
      />
    </div>

    <h3>Pausas interactivas con JavaScript</h3>
    <p>
      Cuando el control de la pausa no depende del puntero sino de la lógica de negocio (por ejemplo, pausar una animación de fondo al abrir el menú principal), usar JavaScript para alternar una clase utilitaria es la forma profesional de hacerlo.
    </p>
  </article>

  <div class="my-8 not-prose">
    <ConsejoProfesional tip="Pausar animaciones pesadas cuando no están visibles en pantalla (por ejemplo, fuera del viewport mediante un IntersectionObserver) es una técnica excelente para reducir drásticamente el consumo de batería en smartphones." />
  </div>

  <h3 class="mb-8 mt-12 text-center font-medium text-[var(--color-text)]">
    Ejemplo práctico
  </h3>

  <div class="mb-6 flex flex-col gap-6 lg:flex-row">
    <TabbedCodeBlock
      group="play-state-demo"
      tabs={[
        { id: 'html', label: 'HTML', code: htmlCode },
        { id: 'css', label: 'CSS', code: cssCode },
      ]}
    />
    <ResultPreview description="Haz clic en el botón de abajo para pausar o reanudar el movimiento orbital del círculo en su posición exacta actual.">
      <div class="flex items-center justify-center h-full w-full px-4">
        <div class="interactive-control">
          <div id="play-state-target" class="control-box">Genesis</div>
          <button id="toggle-play-btn" class="control-btn">Pausar</button>
        </div>
      </div>
    </ResultPreview>
  </div>

  <div class="my-8 flex flex-col gap-6">
    <ErroresComunesV3 errors={[
      { label: 'Re-declarar la animación al pausar', description: 'No re-escribas la propiedad "animation" completa al pausar, ya que esto reiniciará la animación. Solo altera "animation-play-state".' },
      { label: 'Olvidar la accesibilidad en loops continuos', description: 'Los usuarios propensos a mareos por movimiento aprecian la posibilidad de detener animaciones en constante movimiento. Un play/pause es un gran detalle de A11y.' },
    ]} />

    <PracticeCards
      title="Practica lo Aprendido"
      description="Utiliza el botón interactivo para alternar el estado de ejecución y observa cómo se detiene instantáneamente."
      steps={practiceSteps}
    />
  </div>
</CourseLayout>

<style>
  @keyframes orbitSpin {
    0% { transform: rotate(0deg) translateX(40px) rotate(0deg); }
    100% { transform: rotate(360deg) translateX(40px) rotate(-360deg); }
  }

  .interactive-control {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .control-box {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background-color: #a855f7;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #121212;
    font-family: var(--font-afronaut, system-ui, sans-serif);
    font-weight: bold;
    font-size: 0.75rem;
    animation: orbitSpin 6s infinite linear;
    animation-play-state: running;
    transition: background-color 0.3s ease;
  }

  .control-box.paused {
    animation-play-state: paused;
    background-color: #ef4444;
  }

  .control-btn {
    padding: 8px 16px;
    background-color: #A0F36D;
    border: none;
    border-radius: 0;
    color: #121212;
    font-family: var(--font-afronaut, system-ui, sans-serif);
    font-size: 0.8125rem;
    font-weight: 500;
    cursor: pointer;
    transition: opacity 0.2s ease;
    margin-top: 15px;
  }

  .control-btn:hover {
    background-color: #A0F36D;
    opacity: 0.8;
  }
</style>

<script>
  import { initCodeInteractions } from '../../scripts/code-interactions.js';

  function setupPlayPause() {
    const btn = document.getElementById('toggle-play-btn');
    const target = document.getElementById('play-state-target');
    
    if (btn && target) {
      btn.addEventListener('click', () => {
        const isPaused = target.classList.toggle('paused');
        btn.textContent = isPaused ? 'Reanudar' : 'Pausar';
      });
    }
  }

  function setupRefreshReset() {
    document.querySelectorAll('.refresh-btn').forEach((rbtn) => {
      if (rbtn.hasAttribute('data-play-reset')) return;
      rbtn.setAttribute('data-play-reset', 'true');
      rbtn.addEventListener('click', () => {
        setTimeout(() => {
          setupPlayPause();
        }, 50);
      });
    });
  }

  document.addEventListener('astro:page-load', () => {
    initCodeInteractions();
    setupPlayPause();
    setupRefreshReset();
  });
  document.addEventListener('astro:after-swap', () => {
    initCodeInteractions();
    setupPlayPause();
    setupRefreshReset();
  });
</script>
