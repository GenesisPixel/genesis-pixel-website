---
import CourseLayout from '../../layouts/CourseLayout.astro';
import ChapterHeader from '../../components/ChapterHeader.astro';
import TabbedCodeBlock from '../../components/TabbedCodeBlock.astro';
import ResultPreview from '../../components/ResultPreview.astro';
import ConsejoProfesional from '../../components/ConsejoProfesional.astro';
import ErroresComunesV3 from '../../components/ErroresComunesV3.astro';
import PracticeCards from '../../components/PracticeCards.astro';

const htmlCode = `<div class="easing-tester">
  <div class="test-row">
    <span class="label">linear (Velocidad constante)</span>
    <div class="track"><div class="dot ease-linear"></div></div>
  </div>
  <div class="test-row">
    <span class="label">ease (Suave inicio y fin - Por defecto)</span>
    <div class="track"><div class="dot ease-default"></div></div>
  </div>
  <div class="test-row">
    <span class="label">ease-in (Entrada lenta, salida rápida)</span>
    <div class="track"><div class="dot ease-in-class"></div></div>
  </div>
  <div class="test-row">
    <span class="label">ease-out (Entrada rápida, salida lenta)</span>
    <div class="track"><div class="dot ease-out-class"></div></div>
  </div>
  <div class="test-row">
    <span class="label">ease-in-out (Inicio lento, medio rápido, fin lento)</span>
    <div class="track"><div class="dot ease-in-out-class"></div></div>
  </div>
</div>`;

const cssCode = `@keyframes moveAcross {
  0%, 100% { transform: translateX(0); }
  50% { transform: translateX(calc(100% - 16px)); }
}

.easing-tester {
  display: flex;
  flex-direction: column;
  gap: 12px;
  width: 100%;
}

.test-row {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.label {
  font-size: 0.75rem;
  color: var(--dm-light-300);
}

.track {
  width: 100%;
  height: 20px;
  background-color: rgba(255, 255, 255, 0.05);
  border-radius: 9999px;
  padding: 2px;
}

.dot {
  width: 16px;
  height: 16px;
  border-radius: 50%;
  background-color: var(--dm-purple, #a855f7);
  animation: moveAcross 2.5s infinite;
}

.ease-linear {
  animation-timing-function: linear;
  background-color: var(--dm-blue, #3b82f6);
}

.ease-default {
  animation-timing-function: ease;
  background-color: var(--dm-green, #22c55e);
}

.ease-in-class {
  animation-timing-function: ease-in;
  background-color: var(--dm-red, #ef4444);
}

.ease-out-class {
  animation-timing-function: ease-out;
  background-color: var(--dm-yellow, #eab308);
}

.ease-in-out-class {
  animation-timing-function: ease-in-out;
  background-color: var(--dm-purple, #a855f7);
}`;

const practiceSteps = [
  { number: 1, text: 'Prueba a alternar las timing-functions y observa el movimiento de los puntos', color: 'dm-purple', rotate: '2deg' },
  { number: 2, text: 'Usa ease-out para elementos que entran en la pantalla (se siente responsivo)', color: 'dm-green', rotate: '-3deg' },
  { number: 3, text: 'Usa ease-in para elementos que salen de la pantalla (parece acelerar al irse)', color: 'app-color-yellow400', rotate: '4deg' },
  { number: 4, text: 'Reserva linear para loaders, fondos giratorios o efectos continuos de looping', color: 'dm-blue', rotate: '-1deg' },
];
---

<CourseLayout
  title="Animation Timing Function - Genesis Pixel"
  currentLesson="/keyframes/animation-timing-function"
  prevLesson={{ title: 'Animation Duration', href: '/keyframes/animation-duration' }}
  nextLesson={{ title: 'Animation Delay', href: '/keyframes/animation-delay' }}
>
  <ChapterHeader
    chapterNumber="01"
    chapterLabel="Capítulo 1 · Lección 8"
    title="Animation Timing Function"
  />

  <article class="prose prose-invert max-w-none" style="margin-top: 64px;">
    <h3>Por qué el movimiento lineal se siente falso</h3>
    <p>
      Cuando aprendes a manejar una bicicleta, no arrancas a velocidad máxima desde el primer pedaleo ni tampoco paras en seco. Aceleras gradualmente y desacelerás antes de detenerte. Ese es el movimiento natural que el cerebro humano espera. Cuando algo se mueve a velocidad constante en pantalla, algo en nosotros lo detecta como artificial, robótico.
    </p>
    <p>
      La propiedad <code>animation-timing-function</code> resuelve exactamente eso. Define la curva de aceleración de la animación a lo largo de su duración: cuándo va rápido, cuándo desacelera, cuándo arranca despacio. Es lo que convierte un movimiento mecánico en uno que se siente vivo.
    </p>

    <h3>Las cinco curvas estándar de CSS</h3>
    <ul class="space-y-3 mt-4 mb-8 list-none pl-0">
      <li class="flex gap-3">
        <span class="text-[var(--dm-green)]">✦</span>
        <span><strong>linear:</strong> Velocidad perfectamente constante de principio a fin. Útil para rotaciones continuas, fondos en movimiento o cualquier cosa donde quieras que el usuario no perciba inicio ni final del ciclo.</span>
      </li>
      <li class="flex gap-3">
        <span class="text-[var(--dm-green)]">✦</span>
        <span><strong>ease:</strong> (Valor por defecto) Arranca despacio, acelera en el centro y termina despacio. Produce transiciones bastante naturales para la mayoría de casos genéricos.</span>
      </li>
      <li class="flex gap-3">
        <span class="text-[var(--dm-green)]">✦</span>
        <span><strong>ease-in:</strong> Comienza muy despacio y acelera progresivamente. Imita un objeto que toma impulso, como una pelota que empieza a rodar cústera abajo.</span>
      </li>
      <li class="flex gap-3">
        <span class="text-[var(--dm-green)]">✦</span>
        <span><strong>ease-out:</strong> Empieza a velocidad máxima y desacelera suavemente. Perfecto para elementos que entran a la pantalla —se sienten responsivos e inmediatos.</span>
      </li>
      <li class="flex gap-3">
        <span class="text-[var(--dm-green)]">✦</span>
        <span><strong>ease-in-out:</strong> Simétrico: inicio lento, centro rápido, final lento. Ideal para movimientos de vaivén o carruseles que van y vienen.</span>
      </li>
    </ul>

    <h3>La regla que marca la diferencia en UI</h3>
    <p>
      Hay una decisión de diseño que los mejores equipos de producto aplican consistentemente:
    </p>
    <ul class="space-y-2 list-disc pl-6 mb-6">
      <li><strong>Cuando algo entra a pantalla</strong> (modal, menú, toast): usa <code>ease-out</code>. La entrada rápida le da al usuario la sensación de que la UI responde instantáneamente a su acción.</li>
      <li><strong>Cuando algo sale de pantalla</strong> (cierre de modal, dismissal): usa <code>ease-in</code>. El elemento parece tomar impulso al irse, desapareciendo sin entorpecer la navegación.</li>
      <li><strong>Para loops decorativos</strong> (fondos, orbs flotantes): usa <code>ease-in-out</code> o <code>linear</code>.</li>
    </ul>
  </article>

  <div class="my-8 not-prose">
    <ConsejoProfesional tip="¿Sabías que puedes crear tus propios easings personalizados? Con cubic-bezier(x1, y1, x2, y2) puedes definir curvas elásticas avanzadas que simulan rebotes o retrocesos elásticos." />
  </div>

  <h3 class="mb-8 mt-12 text-center font-medium text-[var(--color-text)]">
    Comparación visual de Timing Functions
  </h3>

  <div class="mb-6 flex flex-col gap-6 lg:flex-row">
    <TabbedCodeBlock
      group="timing-functions-demo"
      tabs={[
        { id: 'html', label: 'HTML', code: htmlCode },
        { id: 'css', label: 'CSS', code: cssCode },
      ]}
    />
    <ResultPreview description="Compara cómo se distribuye la velocidad del movimiento de izquierda a derecha en función del easing aplicado.">
      <div class="flex items-center justify-center h-full w-full px-4">
        <div class="easing-tester">
          <div class="test-row">
            <span class="label">linear (Velocidad constante)</span>
            <div class="track"><div class="dot ease-linear"></div></div>
          </div>
          <div class="test-row">
            <span class="label">ease (Suave inicio y fin)</span>
            <div class="track"><div class="dot ease-default"></div></div>
          </div>
          <div class="test-row">
            <span class="label">ease-in (Entrada lenta, salida rápida)</span>
            <div class="track"><div class="dot ease-in-class"></div></div>
          </div>
          <div class="test-row">
            <span class="label">ease-out (Entrada rápida, salida lenta)</span>
            <div class="track"><div class="dot ease-out-class"></div></div>
          </div>
          <div class="test-row">
            <span class="label">ease-in-out (Inicio/fin lento, medio rápido)</span>
            <div class="track"><div class="dot ease-in-out-class"></div></div>
          </div>
        </div>
      </div>
    </ResultPreview>
  </div>

  <div class="my-8 flex flex-col gap-6">
    <ErroresComunesV3 errors={[
      { label: 'Usar "linear" para todo', description: 'El movimiento lineal se siente frío, maquinal y poco natural en menús o modales. Evítalo en transiciones de UI principales.' },
      { label: 'Escribir mal los valores predefinidos', description: 'Escribir easein o easeout sin el guion medio hará que el navegador ignore la propiedad e implante el valor ease por defecto.' },
    ]} />

    <PracticeCards
      title="Practica lo Aprendido"
      description="Cambia el timing-function del código y experimenta con transiciones rápidas y lentas."
      steps={practiceSteps}
    />
  </div>
</CourseLayout>

<style>
  @keyframes moveAcross {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(calc(100% - 16px)); }
  }

  .easing-tester {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
  }

  .test-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .label {
    font-size: 0.75rem;
    color: var(--dm-light-300);
  }

  .track {
    width: 100%;
    height: 20px;
    background-color: rgba(255, 255, 255, 0.05);
    border-radius: 9999px;
    padding: 2px;
  }

  .dot {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background-color: var(--dm-purple, #a855f7);
    animation: moveAcross 2.5s infinite;
  }

  .ease-linear {
    animation-timing-function: linear;
    background-color: var(--dm-blue, #3b82f6);
  }

  .ease-default {
    animation-timing-function: ease;
    background-color: var(--dm-green, #22c55e);
  }

  .ease-in-class {
    animation-timing-function: ease-in;
    background-color: var(--dm-red, #ef4444);
  }

  .ease-out-class {
    animation-timing-function: ease-out;
    background-color: var(--dm-yellow, #eab308);
  }

  .ease-in-out-class {
    animation-timing-function: ease-in-out;
    background-color: var(--dm-purple, #a855f7);
  }
</style>

<script>
  import { initCodeInteractions } from '../../scripts/code-interactions.js';
  document.addEventListener('astro:page-load', () => initCodeInteractions());
</script>
