    50% { transform: translateY(-6px); }
  }

  .glow-card {
    width: 220px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    position: relative;
    overflow: hidden;
    padding: 16px;
