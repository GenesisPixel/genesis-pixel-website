---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects';
---

<Layout title="Proyectos - GenesisPixel">
  <Navbar />

  <main class="mx-auto max-w-7xl px-6 pb-24 pt-24">
    <div class="mb-12">
      <h1 class="font-acorn text-4xl font-bold text-[var(--color-text)] sm:text-5xl">Proyectos</h1>
      <p class="mt-4 text-lg text-[var(--dm-light-300)]">
        Explora proyectos completos que combinan múltiples técnicas y tecnologías.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {projects.map((project) => (
        <ProjectCard
          title={project.title}
          description={project.description}
          category={project.category}
          difficulty={project.difficulty}
          tags={project.tags}
        />
      ))}
    </div>

    <section class="mt-16">
      <div class="overflow-hidden rounded-[var(--radius-base)] border border-white/5 bg-gradient-to-br from-white/[0.02] to-transparent p-8 text-center sm:p-12">
        <h2 class="font-acorn text-2xl font-bold text-[var(--color-text)]">Más Proyectos Próximamente</h2>
        <p class="mx-auto mt-4 max-w-xl text-[var(--dm-light-300)]">
          Estamos trabajando en nuevos proyectos para ayudarte a aprender las últimas técnicas de desarrollo web.
        </p>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
