---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import Container from '../components/Container.astro';
import Hero from '../components/Hero.astro';
import BentoCards from '../components/BentoCards.astro';

const resources = [
  {
    category: 'Herramientas',
    gradient: 'from-[var(--dm-blue)]/20 to-[var(--dm-blue-dark)]',
    border: 'border-[var(--dm-blue)]/20',
    icon: `<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
    items: [
      { name: 'CodePen', description: 'Editor de código en línea para HTML, CSS y JavaScript.', url: 'https://codepen.io' },
      { name: 'Figma', description: 'Herramienta de diseño colaborativo para equipos.', url: 'https://figma.com' },
      { name: 'VS Code', description: 'Editor de código fuente gratuito y extensible.', url: 'https://code.visualstudio.com' },
      { name: 'Chrome DevTools', description: 'Herramientas de desarrollo integradas en el navegador.', url: 'https://developer.chrome.com/docs/devtools/' },
    ],
  },
  {
    category: 'Documentación',
    gradient: 'from-[var(--dm-green)]/20 to-[var(--dm-green-dark)]',
    border: 'border-[var(--dm-green)]/20',
    icon: `<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>`,
    items: [
      { name: 'MDN Web Docs', description: 'Documentación completa de tecnologías web.', url: 'https://developer.mozilla.org' },
      { name: 'CSS Reference', description: 'Guía visual y referencia completa de CSS.', url: 'https://cssreference.io' },
      { name: 'Three.js Docs', description: 'Documentación oficial de la librería Three.js.', url: 'https://threejs.org/docs/' },
      { name: 'GSAP Docs', description: 'Documentación de GreenSock Animation Platform.', url: 'https://greensock.com/docs/' },
    ],
  },
  {
    category: 'Comunidad',
    gradient: 'from-[var(--dm-purple)]/20 to-[var(--dm-purple-dark)]',
    border: 'border-[var(--dm-purple)]/20',
    icon: `<svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>`,
    items: [
      { name: 'Dev.to', description: 'Comunidad global de desarrolladores y creadores.', url: 'https://dev.to' },
      { name: 'CodePen Community', description: 'Explora creaciones e inspiración de la comunidad.', url: 'https://codepen.io/discover' },
      { name: 'GitHub', description: 'Plataforma líder de código abierto y colaboración.', url: 'https://github.com' },
      { name: 'Stack Overflow', description: 'Foro de preguntas y respuestas técnicas.', url: 'https://stackoverflow.com' },
    ],
  },
];
---

<Layout title="Recursos - GenesisPixel">
  <main class="pb-24">
    <Hero
      title="Recursos"
      description="Herramientas, documentación y recursos recomendados para tu aprendizaje."
    />
    <BentoCards />
    <Container>
      <div class="space-y-16">
        {resources.map((section) => (
          <section>
            <div class="mb-8 flex items-center gap-3">
              <div class="flex h-9 w-9 items-center justify-center rounded-lg border border-white/10 bg-white/[0.04] text-[var(--color-text)]">
                {section.icon}
              </div>
              <h2 class="font-afronaut text-2xl font-light tracking-tight text-[var(--color-text)]">
                {section.category}
              </h2>
            </div>
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
              {section.items.map((item) => (
                <a
                  href={item.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class={`group relative overflow-hidden rounded-[var(--radius-base)] border ${section.border} bg-gradient-to-br ${section.gradient} p-6 transition-all duration-300 hover:scale-[1.02] hover:border-white/20`}
                >
                  {/* Glow effect on hover */}
                  <div class="pointer-events-none absolute -inset-px rounded-[var(--radius-base)] opacity-0 transition-opacity duration-300 group-hover:opacity-100"
                    style="box-shadow: 0 0 20px rgba(255,255,255,0.03);"
                  ></div>

                  <div class="relative z-10">
                    <div class="flex items-start justify-between">
                      <h3 class="text-sm font-medium text-[var(--color-text)] transition-colors group-hover:text-white">
                        {item.name}
                      </h3>
                      <svg class="mt-0.5 h-3.5 w-3.5 shrink-0 text-[var(--dm-light-300)] transition-all duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                      </svg>
                    </div>
                    <p class="mt-2 text-xs leading-relaxed text-[var(--dm-light-300)]">
                      {item.description}
                    </p>
                    <div class="mt-4 flex items-center gap-1 text-xs text-[var(--dm-light-300)] opacity-0 transition-all duration-300 group-hover:opacity-100">
                      <span>Visitar</span>
                      <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                      </svg>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </section>
        ))}
      </div>
    </Container>
  </main>

  <Footer />
</Layout>
