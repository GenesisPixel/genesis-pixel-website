---
import ShadersLayout from '../../layouts/ShadersLayout.astro';
import ChapterHeader from '../../components/ChapterHeader.astro';
import TabbedCodeBlock from '../../components/TabbedCodeBlock.astro';
import ResultPreview from '../../components/ResultPreview.astro';
import ConsejoProfesional from '../../components/ConsejoProfesional.astro';
import ErroresComunesV3 from '../../components/ErroresComunesV3.astro';
import PracticeCards from '../../components/PracticeCards.astro';

const orbeVertexCode = `// Classic Perlin 3D Noise by Stefan Gustavson
// (Función cnoise completa arriba del main)

uniform float u_time;
varying float vDistortion;

void main() {
  // Deformamos los vértices con ruido 3D
  float noise = cnoise(normal * 2.0 + u_time * 0.5);
  vDistortion = noise;

  // Empujamos cada vértice a lo largo de su normal
  vec3 newPosition = position + normal * (noise * 0.3);

  gl_Position = projectionMatrix * viewMatrix
    * modelMatrix * vec4(newPosition, 1.0);
}`;

const orbeFragmentCode = `varying float vDistortion;
uniform float u_time;

void main() {
  // Normalizamos la distorsión de -1..1 a 0..1
  float intensity = (vDistortion + 1.0) * 0.5;

  vec3 colorDark = vec3(0.04, 0.06, 0.1);
  vec3 colorBlue = vec3(0.34, 0.69, 0.98);  // 57B0FB
  vec3 colorPink = vec3(0.988, 0.364, 0.490); // FC5D7D

  // Mezclamos colores según cuánto se deformó el vértice
  vec3 mix1 = mix(colorDark, colorBlue, smoothstep(0.0, 0.6, intensity));
  vec3 finalColor = mix(mix1, colorPink, smoothstep(0.5, 1.0, intensity));

  gl_FragColor = vec4(finalColor, 1.0);
}`;

const portalVertexCode = `uniform float u_time;
varying vec2 vUv;

void main() {
  vUv = uv;
  gl_Position = vec4(position, 1.0);
}`;

const portalFragmentCode = `uniform float u_time;
varying vec2 vUv;

void main() {
  // Centramos el origen en (0.5, 0.5)
  vec2 uv = vUv - 0.5;
  
  // Distancia al centro = radio del anillo
  float dist = length(uv);
  
  // Ángulo en el plano 2D
  float angle = atan(uv.y, uv.x);
  
  // Creamos anillos pulsantes con rotación temporal
  float rings = sin(dist * 30.0 - u_time * 3.0 + angle * 3.0);
  rings = smoothstep(0.0, 0.1, rings);
  
  // Colores Genesis Pixel según la distancia al centro
  vec3 colorCore = vec3(0.988, 0.364, 0.490); // Rosa
  vec3 colorEdge = vec3(0.34, 0.69, 0.98);    // Azul
  vec3 color = mix(colorCore, colorEdge, smoothstep(0.0, 0.5, dist));
  
  // Máscara circular para bordes limpios
  float mask = 1.0 - smoothstep(0.45, 0.5, dist);
  
  gl_FragColor = vec4(color * (rings * 0.7 + 0.3), mask);
}`;

const practiceSteps = [
  { number: 1, text: 'Modifica el multiplicador del ruido (noise * 0.3) del Orbe para hacerlo más o menos orgánico.', color: 'dm-purple', rotate: '2deg' },
  { number: 2, text: 'Cambia los colores del Orbe usando la paleta de tu propia marca.', color: 'dm-green', rotate: '-3deg' },
  { number: 3, text: 'En el Portal, ajusta la velocidad de rotación (u_time * 3.0) para que gire más rápido.', color: 'app-color-yellow400', rotate: '4deg' },
  { number: 4, text: 'Combina ambos: Coloca el Portal como fondo y el Orbe encima como elemento hero.', color: 'dm-blue', rotate: '-1deg' },
];
---

<ShadersLayout
  title="GenesisPixel | Proyecto Final de Shaders "
  currentLesson="/shaders/proyecto-final"
  prevLesson={{ title: 'Integración con Three.js', href: '/shaders/integracion-threejs' }}
>
  <ChapterHeader
    chapterNumber="06"
    chapterLabel="Capítulo 6 · Proyecto Final"
    title="Proyecto Final de Shaders"
    readingTime="10"
    difficulty="Shaders GLSL"
  />

  <article class="prose prose-invert max-w-none" style="margin-top: 64px;">
    <h3>El Arquitecto del Lienzo Digital</h3>
    <p>Has conquistado el nivel más profundo y técnico del diseño web interactivo. Entendiste cómo engañar a la geometría deformando sus vértices, cómo pintar un millón de píxeles al mismo tiempo usando matemáticas, y cómo usar ruido para simular la vida orgánica de la naturaleza.</p>

    <h3>Proyecto 1 — El Orbe Procedural</h3>
    <p>Una esfera hiper-subdividida deformada completamente con ruido Perlin 3D en el Vertex Shader. Los colores de su superficie también son procedurales: responden directamente a cuánto se deformó cada vértice en 3D, creando una sintonía perfecta entre geometría y color.</p>

    <h3>Proyecto 2 — El Portal Dimensional</h3>
    <p>Un portal 2D puro usando solo un plano y matemáticas en el Fragment Shader. Sin geometría 3D. Sin texturas externas. Solo coordenadas UV, la función <code>atan()</code> para el ángulo y <code>length()</code> para la distancia, creando anillos que giran y pulsan en el tiempo.</p>
  </article>

  <div class="my-8 not-prose">
    <ConsejoProfesional tip="Estos dos proyectos resumen los dos grandes poderes de los Shaders: el Vertex Shader transforma la geometría (forma), y el Fragment Shader transforma el color (apariencia). Dominar ambos es dominar la GPU por completo." />
  </div>

  <!-- Proyecto 1 -->
  <div class="mt-16 mb-4 text-center">
    <h3 class="font-medium mb-2">Proyecto 1 — El Orbe Procedural</h3>
    <p class="text-sm mb-6" style="color: white; opacity: 0.7;">
      Una esfera deformada con ruido 3D Perlin tanto en vértices como en color. La paleta responde a la intensidad de la deformación física.
    </p>
  </div>

  <div class="mb-6 flex flex-col gap-6 lg:flex-row">
    <TabbedCodeBlock
      group="proyecto-orbe"
      tabs={[
        { id: 'vertex', label: 'Vertex Shader', code: orbeVertexCode },
        { id: 'fragment', label: 'Fragment Shader', code: orbeFragmentCode },
      ]}
    />
    <ResultPreview description="Arrastra para rotar. Una esfera que respira usando puras matemáticas de ruido 3D.">
      <div class="flex items-center justify-center h-full w-full bg-[#0a0a14] overflow-hidden rounded-none" id="demo-orbe" style="cursor: grab;">
      </div>
    </ResultPreview>
  </div>

  <!-- Proyecto 2 -->
  <div class="mt-16 mb-4 text-center">
    <h3 class="font-medium mb-2">Proyecto 2 — El Portal Dimensional</h3>
    <p class="text-sm mb-6" style="color: white; opacity: 0.7;">
      Un portal puro en 2D. Solo matemáticas de ángulo y distancia en el Fragment Shader. Cero geometría 3D, cero texturas.
    </p>
  </div>

  <div class="mb-6 flex flex-col gap-6 lg:flex-row">
    <TabbedCodeBlock
      group="proyecto-portal"
      tabs={[
        { id: 'vertex', label: 'Vertex Shader', code: portalVertexCode },
        { id: 'fragment', label: 'Fragment Shader', code: portalFragmentCode },
      ]}
    />
    <ResultPreview description="Anillos que giran y pulsan generados con atan(), length() y sin(). Todo procedural.">
      <div class="flex items-center justify-center h-full w-full bg-[#0a0a14] overflow-hidden rounded-none" id="demo-portal">
      </div>
    </ResultPreview>
  </div>

  <div class="my-8 flex flex-col gap-6">
    <PracticeCards
      title="Desafío Final"
      description="Combina ambos proyectos y crea la portada de tu portfolio."
      steps={practiceSteps}
    />
  </div>

  <!-- Resumen del capítulo -->
  <div class="py-6">
    <h3 class="mb-8 text-center font-medium text-[var(--color-text)]">
      Lo que aprendiste en este capítulo
    </h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-6">
      {[
        { prop: 'GLSL', desc: 'El lenguaje de la GPU: tipos estrictos, sin console.log, velocidad pura' },
        { prop: 'Vertex Shader', desc: 'Controla la forma moviendo vértices con matemáticas y ruido' },
        { prop: 'Fragment Shader', desc: 'Controla el color de cada píxel con fórmulas matemáticas' },
        { prop: 'Uniforms', desc: 'El puente de datos de JavaScript (CPU) hacia el Shader (GPU)' },
        { prop: 'Varyings', desc: 'Cómo pasar datos calculados del Vertex Shader al Fragment Shader' },
        { prop: 'Coordenadas UV', desc: 'El mapa 2D que envuelve la geometría para aplicar texturas y colores' },
        { prop: 'Ruido Perlin / Simplex', desc: 'Caos orgánico y suave: la base de fuego, agua y materia' },
        { prop: 'u_time', desc: 'El reloj de la GPU: la fuente de toda animación procedural' },
        { prop: 'u_mouse', desc: 'Interactividad reactiva: el cursor como input de datos en tiempo real' },
        { prop: 'onBeforeCompile', desc: 'Hackear materiales de Three.js para preservar luces e inyectar GLSL' },
      ].map((item, index) => (
        <div class="flex gap-4">
          <span class="mt-0.5 shrink-0 font-afronaut text-[13px] text-[var(--color-text)]" style="opacity: 0.4 !important;">
            {String(index + 1).padStart(2, '0')}
          </span>
          <div class="flex flex-col gap-1">
            <span class="text-[14px] text-white" style="color: white; opacity: 1 !important; font-family: var(--font-afronaut, system-ui, sans-serif); font-weight: 300;">
              {item.prop}
            </span>
            <span class="text-[13px] leading-relaxed text-[var(--dm-light-200)]">
              {item.desc}
            </span>
          </div>
        </div>
      ))}
    </div>
  </div>

</ShadersLayout>

<script>
  import * as THREE from 'three';
  import { OrbitControls } from 'three/addons/controls/OrbitControls.js';

  document.addEventListener('astro:page-load', () => {
    // ── PROYECTO 1: ORBE PROCEDURAL ──────────────────────────────────────
    const containerOrbe = document.getElementById('demo-orbe');
    if (containerOrbe) {
      while(containerOrbe.firstChild) containerOrbe.removeChild(containerOrbe.firstChild);

      const sceneO = new THREE.Scene();
      const cameraO = new THREE.PerspectiveCamera(45, containerOrbe.clientWidth / containerOrbe.clientHeight, 0.1, 100);
      cameraO.position.set(0, 0, 4);

      const rendererO = new THREE.WebGLRenderer({ antialias: true, alpha: true });
      rendererO.setPixelRatio(Math.min(window.devicePixelRatio, 2));
      rendererO.setSize(containerOrbe.clientWidth, containerOrbe.clientHeight);
      containerOrbe.appendChild(rendererO.domElement);

      const controlsO = new OrbitControls(cameraO, rendererO.domElement);
      controlsO.enableDamping = true;
      controlsO.enablePan = false;

      const geoO = new THREE.IcosahedronGeometry(1.2, 128);

      const vsOrbe = `
        uniform float u_time;
        varying vec2 vUv;
        varying float vDistortion;

        vec4 permute(vec4 x){return mod(((x*34.0)+1.0)*x, 289.0);}
        vec4 taylorInvSqrt(vec4 r){return 1.79284291400159 - 0.85373472095314 * r;}
        vec3 fade(vec3 t) {return t*t*t*(t*(t*6.0-15.0)+10.0);}

        float cnoise(vec3 P){
          vec3 Pi0 = floor(P); vec3 Pi1 = Pi0 + vec3(1.0);
          Pi0 = mod(Pi0, 289.0); Pi1 = mod(Pi1, 289.0);
          vec3 Pf0 = fract(P); vec3 Pf1 = Pf0 - vec3(1.0);
          vec4 ix = vec4(Pi0.x, Pi1.x, Pi0.x, Pi1.x);
          vec4 iy = vec4(Pi0.yy, Pi1.yy);
          vec4 iz0 = Pi0.zzzz; vec4 iz1 = Pi1.zzzz;
          vec4 ixy = permute(permute(ix) + iy);
          vec4 ixy0 = permute(ixy + iz0); vec4 ixy1 = permute(ixy + iz1);
          vec4 gx0 = ixy0 / 7.0; vec4 gy0 = fract(floor(gx0) / 7.0) - 0.5;
          gx0 = fract(gx0); vec4 gz0 = vec4(0.5) - abs(gx0) - abs(gy0);
          vec4 sz0 = step(gz0, vec4(0.0));
          gx0 -= sz0 * (step(0.0, gx0) - 0.5); gy0 -= sz0 * (step(0.0, gy0) - 0.5);
          vec4 gx1 = ixy1 / 7.0; vec4 gy1 = fract(floor(gx1) / 7.0) - 0.5;
          gx1 = fract(gx1); vec4 gz1 = vec4(0.5) - abs(gx1) - abs(gy1);
          vec4 sz1 = step(gz1, vec4(0.0));
          gx1 -= sz1 * (step(0.0, gx1) - 0.5); gy1 -= sz1 * (step(0.0, gy1) - 0.5);
          vec3 g000 = vec3(gx0.x,gy0.x,gz0.x); vec3 g100 = vec3(gx0.y,gy0.y,gz0.y);
          vec3 g010 = vec3(gx0.z,gy0.z,gz0.z); vec3 g110 = vec3(gx0.w,gy0.w,gz0.w);
          vec3 g001 = vec3(gx1.x,gy1.x,gz1.x); vec3 g101 = vec3(gx1.y,gy1.y,gz1.y);
          vec3 g011 = vec3(gx1.z,gy1.z,gz1.z); vec3 g111 = vec3(gx1.w,gy1.w,gz1.w);
          vec4 norm0 = taylorInvSqrt(vec4(dot(g000,g000),dot(g010,g010),dot(g100,g100),dot(g110,g110)));
          g000 *= norm0.x; g010 *= norm0.y; g100 *= norm0.z; g110 *= norm0.w;
          vec4 norm1 = taylorInvSqrt(vec4(dot(g001,g001),dot(g011,g011),dot(g101,g101),dot(g111,g111)));
          g001 *= norm1.x; g011 *= norm1.y; g101 *= norm1.z; g111 *= norm1.w;
          float n000 = dot(g000, Pf0); float n100 = dot(g100, vec3(Pf1.x, Pf0.yz));
          float n010 = dot(g010, vec3(Pf0.x, Pf1.y, Pf0.z)); float n110 = dot(g110, vec3(Pf1.xy, Pf0.z));
          float n001 = dot(g001, vec3(Pf0.xy, Pf1.z)); float n101 = dot(g101, vec3(Pf1.x, Pf0.y, Pf1.z));
          float n011 = dot(g011, vec3(Pf0.x, Pf1.yz)); float n111 = dot(g111, Pf1);
          vec3 fade_xyz = fade(Pf0);
          vec4 n_z = mix(vec4(n000,n100,n010,n110), vec4(n001,n101,n011,n111), fade_xyz.z);
          vec2 n_yz = mix(n_z.xy, n_z.zw, fade_xyz.y);
          float n_xyz = mix(n_yz.x, n_yz.y, fade_xyz.x);
          return 2.2 * n_xyz;
        }

        void main() {
          vUv = uv;
          float noise = cnoise(normal * 2.0 + u_time * 0.5);
          vDistortion = noise;
          vec3 newPosition = position + normal * (noise * 0.3);
          gl_Position = projectionMatrix * viewMatrix * modelMatrix * vec4(newPosition, 1.0);
        }
      `;

      const fsOrbe = `
        varying vec2 vUv;
        varying float vDistortion;
        uniform float u_time;
        void main() {
          float intensity = (vDistortion + 1.0) * 0.5;
          vec3 colorDark = vec3(0.04, 0.06, 0.1);
          vec3 colorBlue = vec3(0.34, 0.69, 0.98);
          vec3 colorPink = vec3(0.988, 0.364, 0.490);
          vec3 mix1 = mix(colorDark, colorBlue, smoothstep(0.0, 0.6, intensity));
          vec3 finalColor = mix(mix1, colorPink, smoothstep(0.5, 1.0, intensity));
          gl_FragColor = vec4(finalColor, 1.0);
        }
      `;

      const matO = new THREE.ShaderMaterial({ vertexShader: vsOrbe, fragmentShader: fsOrbe, uniforms: { u_time: { value: 0 } } });
      const meshO = new THREE.Mesh(geoO, matO);
      sceneO.add(meshO);

      let animIdO;
      const clockO = new THREE.Clock();
      const animateO = () => {
        animIdO = requestAnimationFrame(animateO);
        controlsO.update();
        matO.uniforms.u_time.value = clockO.getElapsedTime();
        meshO.rotation.y += 0.002;
        rendererO.render(sceneO, cameraO);
      };
      animateO();

      const resizeO = () => { cameraO.aspect = containerOrbe.clientWidth / containerOrbe.clientHeight; cameraO.updateProjectionMatrix(); rendererO.setSize(containerOrbe.clientWidth, containerOrbe.clientHeight); };
      window.addEventListener('resize', resizeO);

      document.addEventListener('astro:before-swap', () => {
        cancelAnimationFrame(animIdO);
        window.removeEventListener('resize', resizeO);
        controlsO.dispose(); rendererO.dispose(); matO.dispose(); geoO.dispose();
      }, { once: true });
    }

    // ── PROYECTO 2: PORTAL DIMENSIONAL ───────────────────────────────────
    const containerPortal = document.getElementById('demo-portal');
    if (containerPortal) {
      while(containerPortal.firstChild) containerPortal.removeChild(containerPortal.firstChild);

      const sceneP = new THREE.Scene();
      const cameraP = new THREE.OrthographicCamera(-1, 1, 1, -1, 0.1, 10);
      cameraP.position.z = 1;

      const rendererP = new THREE.WebGLRenderer({ antialias: false, alpha: true });
      rendererP.setSize(containerPortal.clientWidth, containerPortal.clientHeight);
      containerPortal.appendChild(rendererP.domElement);

      const geoP = new THREE.PlaneGeometry(2, 2);

      const vsPortal = `
        varying vec2 vUv;
        void main() { vUv = uv; gl_Position = vec4(position, 1.0); }
      `;

      const fsPortal = `
        uniform float u_time;
        varying vec2 vUv;
        void main() {
          vec2 uv = vUv - 0.5;
          float dist = length(uv);
          float angle = atan(uv.y, uv.x);
          float rings = sin(dist * 30.0 - u_time * 3.0 + angle * 3.0);
          rings = smoothstep(0.0, 0.1, rings);
          vec3 colorCore = vec3(0.988, 0.364, 0.490);
          vec3 colorEdge = vec3(0.34, 0.69, 0.98);
          vec3 color = mix(colorCore, colorEdge, smoothstep(0.0, 0.5, dist));
          float mask = 1.0 - smoothstep(0.45, 0.5, dist);
          gl_FragColor = vec4(color * (rings * 0.7 + 0.3), mask);
        }
      `;

      const matP = new THREE.ShaderMaterial({ vertexShader: vsPortal, fragmentShader: fsPortal, uniforms: { u_time: { value: 0 } }, transparent: true });
      const meshP = new THREE.Mesh(geoP, matP);
      sceneP.add(meshP);

      let animIdP;
      const clockP = new THREE.Clock();
      const animateP = () => {
        animIdP = requestAnimationFrame(animateP);
        matP.uniforms.u_time.value = clockP.getElapsedTime();
        rendererP.render(sceneP, cameraP);
      };
      animateP();

      const resizeP = () => { rendererP.setSize(containerPortal.clientWidth, containerPortal.clientHeight); };
      window.addEventListener('resize', resizeP);

      document.addEventListener('astro:before-swap', () => {
        cancelAnimationFrame(animIdP);
        window.removeEventListener('resize', resizeP);
        rendererP.dispose(); matP.dispose(); geoP.dispose();
      }, { once: true });
    }
  });
</script>
