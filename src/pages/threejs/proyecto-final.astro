import ThreejsLayout from '../../layouts/ThreejsLayout.astro';
import ChapterHeader from '../../components/ChapterHeader.astro';
import TabbedCodeBlock from '../../components/TabbedCodeBlock.astro';
import ResultPreview from '../../components/ResultPreview.astro';
import ConsejoProfesional from '../../components/ConsejoProfesional.astro';
import ErroresComunesV3 from '../../components/ErroresComunesV3.astro';
import PracticeCards from '../../components/PracticeCards.astro';

const threejsHtml = `<div id="demo-final" class="threejs-container"></div>`;

const threejsJs = `import * as THREE from 'three';
import { OrbitControls } from 'three/addons/controls/OrbitControls.js';

// 1. Scene & Camera
const scene = new THREE.Scene();
scene.fog = new THREE.FogExp2('#0a0a14', 0.08);

const camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 100);
camera.position.set(0, 2, 8);

// 2. Premium Renderer
const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.toneMapping = THREE.ACESFilmicToneMapping;
document.getElementById('demo-final').appendChild(renderer.domElement);

// 3. Controls
const controls = new OrbitControls(camera, renderer.domElement);
controls.enableDamping = true;
controls.dampingFactor = 0.05;
controls.enablePan = false;
controls.enableZoom = false;

// 4. Group for animation
const group = new THREE.Group();
scene.add(group);

// 5. Core Crystal
const geometry = new THREE.IcosahedronGeometry(1.2, 0);
const material = new THREE.MeshStandardMaterial({
  color: 0x9FA6FF,
  metalness: 0.8,
  roughness: 0.2,
  wireframe: true,
  emissive: 0x57B0FB,
  emissiveIntensity: 0.2
});
const core = new THREE.Mesh(geometry, material);
group.add(core);

// Inner Core
const innerGeo = new THREE.IcosahedronGeometry(0.8, 0);
const innerMat = new THREE.MeshStandardMaterial({
  color: 0xFC5D7D,
  metalness: 1,
  roughness: 0.1
});
const innerCore = new THREE.Mesh(innerGeo, innerMat);
group.add(innerCore);

// 6. Rings of Particles
const particlesCount = 2000;
const posArray = new Float32Array(particlesCount * 3);
const colorsArray = new Float32Array(particlesCount * 3);

const color1 = new THREE.Color(0x9FA6FF);
const color2 = new THREE.Color(0xFC5D7D);

for (let i = 0; i < particlesCount; i++) {
  const r = 3 + Math.random() * 3;
  const theta = Math.random() * Math.PI * 2;
  const phi = (Math.random() - 0.5) * 0.5;

  posArray[i * 3] = r * Math.cos(theta);
  posArray[i * 3 + 1] = r * Math.sin(phi);
  posArray[i * 3 + 2] = r * Math.sin(theta);

  const mixedColor = color1.clone().lerp(color2, Math.random());
  colorsArray[i * 3] = mixedColor.r;
  colorsArray[i * 3 + 1] = mixedColor.g;
  colorsArray[i * 3 + 2] = mixedColor.b;
}

const particlesGeo = new THREE.BufferGeometry();
particlesGeo.setAttribute('position', new THREE.BufferAttribute(posArray, 3));
particlesGeo.setAttribute('color', new THREE.BufferAttribute(colorsArray, 3));

const particlesMat = new THREE.PointsMaterial({
  size: 0.02,
  vertexColors: true,
  transparent: true,
  opacity: 0.8,
  blending: THREE.AdditiveBlending
});
const particlesMesh = new THREE.Points(particlesGeo, particlesMat);
group.add(particlesMesh);

// 7. Dramatic Lighting
const mainLight = new THREE.DirectionalLight(0xffffff, 2);
mainLight.position.set(5, 5, 2);
scene.add(mainLight);

const ambientLight = new THREE.AmbientLight(0xffffff, 0.5);
scene.add(ambientLight);

// 8. Animation Loop
const clock = new THREE.Clock();
let mouseX = 0;
let mouseY = 0;

window.addEventListener('mousemove', (event) => {
  mouseX = (event.clientX / window.innerWidth) * 2 - 1;
  mouseY = -(event.clientY / window.innerHeight) * 2 + 1;
});

function animate() {
  requestAnimationFrame(animate);
  const time = clock.getElapsedTime();
  controls.update();

  // Floating & Rotation
  group.position.y = Math.sin(time * 1.5) * 0.2;
  core.rotation.x = time * 0.3;
  core.rotation.y = time * 0.4;
  innerCore.rotation.x = -time * 0.5;
  innerCore.rotation.y = -time * 0.2;
  particlesMesh.rotation.y = time * 0.1;

  // Mouse interactivity
  group.rotation.x = THREE.MathUtils.lerp(group.rotation.x, mouseY * 0.3, 0.05);
  group.rotation.y = THREE.MathUtils.lerp(group.rotation.y, mouseX * 0.3, 0.05);

  renderer.render(scene, camera);
}
animate();`;
---

<ThreejsLayout
  title="GenesisPixel | Proyecto Final de Three.js "
  currentLesson="/threejs/proyecto-final"
  prevLesson={{ title: 'Escenas para producción', href: '/threejs/escenas-produccion' }}
  
>
  <ChapterHeader
    chapterNumber="05"
    chapterLabel="Capítulo 5 · Lección 15"
    title="Proyecto Final de Three.js"
    readingTime={12}
    difficulty="Three.js"
  />


  <article class="prose prose-invert max-w-none" style="margin-top: 64px;">
    <h3>La Graduación Inmersiva</h3>
    <p>Has recorrido un camino técnico fascinante. Aprendiste a invocar el mundo (Scene), a observarlo (Camera), a pintarlo (Renderer), y a llenarlo de esqueletos (Geometries) recubiertos de piel reactiva a la luz (Materials). Le diste movimiento con el tiempo y le otorgaste interactividad.</p>
    
    <h3>El Proyecto: La Base Espacial</h3>
    <p>Para tu proyecto final, vamos a unir todas las piezas. Construiremos una escena interactiva que podrías presentar como el Hero (portada principal) de un sitio web de vanguardia. Un pequeño avión en un entorno espacial que reacciona a los movimientos del ratón, con sombras, luces dramáticas y controles de cámara sutiles.</p>

    <h3>Requisitos del Proyecto</h3>
    <ul class="space-y-2 list-disc pl-6 mb-6">
      <li><strong>Arquitectura:</strong> Código organizado, con resize handler y un perfecto dispose en cleanup.</li>
      <li><strong>Escena Base:</strong> Renderer con antialiasing, píxel ratio dinámico, y fondos inmersivos.</li>
      <li><strong>Luces y Sombras:</strong> Un DirectionalLight con castShadow activado, iluminando suavemente a través del escenario.</li>
      <li><strong>Asset Externo:</strong> Uso de GLTFLoader para traer nuestro modelo <code>small-airplane.glb</code>.</li>
      <li><strong>Interacción Fluida:</strong> Uso de GSAP (opcional) y Delta Time para hacer flotar el avión con elegancia.</li>
    </ul>

    <h3>El Arte de lo Sutil</h3>
    <p>El error de los principiantes es hacer que la escena maree al usuario. Tu escena debe acompañar el diseño de la web, no secuestrarlo. Movimientos suaves, oscilaciones levitantes (Math.sin) e interactividad guiada son las claves de una experiencia premium.</p>
  </article>

  <h3 class="mb-8 mt-12 text-center font-medium text-[var(--color-text)]">
    El Resultado Esperado
  </h3>

  <div class="mb-6 flex flex-col gap-6 lg:flex-row">
    <TabbedCodeBlock
      group="proyecto-threejs"
      tabs={[
        { id: 'html', label: 'HTML', code: threejsHtml },
        { id: 'js', label: 'JavaScript', code: threejsJs },
      ]}
    />
    <ResultPreview description="Una experiencia de producción.">
      <div class="flex items-center justify-center h-full w-full bg-[#0a0a14] overflow-hidden rounded-none" id="demo-final" style="height: 500px;">
      </div>
    </ResultPreview>
  </div>

  <div class="my-8 flex flex-col gap-6">
    <PracticeCards
      title="El Reto Final"
      description="Construye tu propio ecosistema 3D en la plataforma."
      steps={[
        { number: 1, text: 'Instancia toda la base: Scene, PerspectiveCamera, y WebGLRenderer.', color: 'dm-purple', rotate: '-3deg' },
        { number: 2, text: 'Usa geometrías procedimentales y materiales con wireframe para un look premium.', color: 'dm-green', rotate: '2deg' },
        { number: 3, text: 'Crea un sistema de partículas circulares usando math.sin y math.cos.', color: 'app-color-yellow400', rotate: '-5deg' },
        { number: 4, text: 'Implementa requestAnimationFrame usando Clock() para una rotación suave e interactiva al ratón.', color: 'dm-blue', rotate: '3deg' },
      ]}
    />
  </div>

  <!-- Resumen del capítulo -->
  <div class="py-6">
    <h3 class="mb-8 text-center font-medium text-[var(--color-text)]">
      Lo que aprendiste en este capítulo
    </h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-6">
      {[
        { prop: 'Scene & Camera', desc: 'El lienzo fundamental y los ojos del espectador' },
        { prop: 'WebGLRenderer', desc: 'El motor que dibuja los píxeles con soporte para antialiasing' },
        { prop: 'Geometrías y Materiales', desc: 'Esqueletos matemáticos y sus texturas reactivas a la luz' },
        { prop: 'Luces', desc: 'Iluminación ambiental, direccional y puntual para dar volumen' },
        { prop: 'Sombras', desc: 'Configuración de castShadow y receiveShadow para realismo' },
        { prop: 'Modelos 3D', desc: 'Carga de assets externos optimizados (GLTF/GLB)' },
        { prop: 'OrbitControls', desc: 'Interacción de cámara con soporte para inercia (damping)' },
        { prop: 'Animation Loop', desc: 'requestAnimationFrame y uso del Clock de Three.js' },
        { prop: 'Resize Handler', desc: 'Adaptar el aspect ratio y el tamaño del renderer dinámicamente' },
        { prop: 'Limpieza (Dispose)', desc: 'Liberar memoria de la GPU destruyendo mallas y materiales' },
      ].map((item, index) => (
        <div class="flex gap-4">
          <span class="mt-0.5 shrink-0 font-afronaut text-[13px] text-[var(--color-text)]" style="opacity: 0.4 !important;">
            {String(index + 1).padStart(2, '0')}
          </span>
          <div class="flex flex-col gap-1">
            <span class="text-[14px] text-white" style="color: white; opacity: 1 !important; font-family: var(--font-afronaut, system-ui, sans-serif); font-weight: 300;">
              {item.prop}
            </span>
            <span class="text-[13px] leading-relaxed text-[var(--dm-light-200)]">
              {item.desc}
            </span>
          </div>
        </div>
      ))}
    </div>
  </div>

</ThreejsLayout>

<script>

  import * as THREE from 'three';
  import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
  import { initAllCodeInteractions } from '../../scripts/code-interactions.js';

  document.addEventListener('astro:page-load', () => {
    initAllCodeInteractions();

    const container = document.getElementById('demo-final');
    if (!container) return;
    
    while(container.firstChild) container.removeChild(container.firstChild);

    // 1. Scene
    const scene = new THREE.Scene();
    scene.fog = new THREE.FogExp2('#0a0a14', 0.08);

    // 2. Camera
    const camera = new THREE.PerspectiveCamera(45, container.clientWidth / container.clientHeight, 0.1, 100);
    camera.position.set(0, 2, 8);

    // 3. Renderer (Premium Setup)
    const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setSize(container.clientWidth, container.clientHeight);
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    container.appendChild(renderer.domElement);

    // 4. Controles (restringidos)
    const controls = new OrbitControls(camera, renderer.domElement);
    controls.enableDamping = true;
    controls.dampingFactor = 0.05;
    controls.enablePan = false;
    controls.enableZoom = false;
    controls.minPolarAngle = Math.PI / 4;
    controls.maxPolarAngle = Math.PI / 2 + 0.1;

    // 5. Group for animation
    const group = new THREE.Group();
    scene.add(group);

    // 6. Core Crystal
    const geometry = new THREE.IcosahedronGeometry(1.2, 0);
    const material = new THREE.MeshStandardMaterial({
      color: 0x9FA6FF,
      metalness: 0.8,
      roughness: 0.2,
      wireframe: true,
      emissive: 0x57B0FB,
      emissiveIntensity: 0.2
    });
    const core = new THREE.Mesh(geometry, material);
    group.add(core);

    const innerGeo = new THREE.IcosahedronGeometry(0.8, 0);
    const innerMat = new THREE.MeshStandardMaterial({
      color: 0xFC5D7D,
      metalness: 1,
      roughness: 0.1
    });
    const innerCore = new THREE.Mesh(innerGeo, innerMat);
    group.add(innerCore);

    // 7. Rings of Particles
    const particlesCount = 2000;
    const posArray = new Float32Array(particlesCount * 3);
    const colorsArray = new Float32Array(particlesCount * 3);

    const color1 = new THREE.Color(0x9FA6FF);
    const color2 = new THREE.Color(0xFC5D7D);

    for (let i = 0; i < particlesCount; i++) {
      const r = 3 + Math.random() * 3;
      const theta = Math.random() * Math.PI * 2;
      const phi = (Math.random() - 0.5) * 0.5;

      posArray[i * 3] = r * Math.cos(theta);
      posArray[i * 3 + 1] = r * Math.sin(phi);
      posArray[i * 3 + 2] = r * Math.sin(theta);

      const mixedColor = color1.clone().lerp(color2, Math.random());
      colorsArray[i * 3] = mixedColor.r;
      colorsArray[i * 3 + 1] = mixedColor.g;
      colorsArray[i * 3 + 2] = mixedColor.b;
    }

    const particlesGeo = new THREE.BufferGeometry();
    particlesGeo.setAttribute('position', new THREE.BufferAttribute(posArray, 3));
    particlesGeo.setAttribute('color', new THREE.BufferAttribute(colorsArray, 3));

    const particlesMat = new THREE.PointsMaterial({
      size: 0.02,
      vertexColors: true,
      transparent: true,
      opacity: 0.8,
      blending: THREE.AdditiveBlending
    });
    const particlesMesh = new THREE.Points(particlesGeo, particlesMat);
    group.add(particlesMesh);

    // 8. Luces
    const mainLight = new THREE.DirectionalLight(0xffffff, 2);
    mainLight.position.set(5, 5, 2);
    scene.add(mainLight);

    const ambientLight = new THREE.AmbientLight(0xffffff, 0.5);
    scene.add(ambientLight);

    // 9. Bucle de Animación y Reloj
    const clock = new THREE.Clock();
    let animationId;
    let mouseX = 0;
    let mouseY = 0;

    const onMouseMove = (event) => {
      mouseX = (event.clientX / window.innerWidth) * 2 - 1;
      mouseY = -(event.clientY / window.innerHeight) * 2 + 1;
    };
    container.addEventListener('mousemove', onMouseMove);

    const animate = () => {
      animationId = requestAnimationFrame(animate);
      const time = clock.getElapsedTime();

      controls.update();

      group.position.y = Math.sin(time * 1.5) * 0.2;
      core.rotation.x = time * 0.3;
      core.rotation.y = time * 0.4;
      innerCore.rotation.x = -time * 0.5;
      innerCore.rotation.y = -time * 0.2;
      particlesMesh.rotation.y = time * 0.1;

      group.rotation.x = THREE.MathUtils.lerp(group.rotation.x, mouseY * 0.3, 0.05);
      group.rotation.y = THREE.MathUtils.lerp(group.rotation.y, mouseX * 0.3, 0.05);

      renderer.render(scene, camera);
    };
    animate();

    // 10. Gestión de Resize
    const handleResize = () => {
      camera.aspect = container.clientWidth / container.clientHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(container.clientWidth, container.clientHeight);
    };
    window.addEventListener('resize', handleResize);

    // 11. Limpieza Profesional (Dispose)
    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(animationId);
      window.removeEventListener('resize', handleResize);
      container.removeEventListener('mousemove', onMouseMove);
      
      scene.traverse((child) => {
        if (child.isMesh || child.isPoints) {
          child.geometry.dispose();
          if (Array.isArray(child.material)) {
            child.material.forEach(mat => mat.dispose());
          } else {
            child.material.dispose();
          }
        }
      });
      
      controls.dispose();
      renderer.dispose();
    }, { once: true });
  });

</script>
