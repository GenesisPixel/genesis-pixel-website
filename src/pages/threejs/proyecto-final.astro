---
import ThreejsLayout from '../../layouts/ThreejsLayout.astro';
import ChapterHeader from '../../components/ChapterHeader.astro';
import TabbedCodeBlock from '../../components/TabbedCodeBlock.astro';
import ResultPreview from '../../components/ResultPreview.astro';
import ConsejoProfesional from '../../components/ConsejoProfesional.astro';
import ErroresComunesV3 from '../../components/ErroresComunesV3.astro';
import PracticeCards from '../../components/PracticeCards.astro';

const threejsHtml = `<div id="demo-final" class="threejs-container"></div>`;

const threejsJs = `import * as THREE from 'three';
import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';
import { OrbitControls } from 'three/addons/controls/OrbitControls.js';

// 1. Scene & Camera
const scene = new THREE.Scene();
scene.fog = new THREE.FogExp2('#0a0a14', 0.05);

const camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 100);
camera.position.set(3, 2, 6);

// 2. Premium Renderer
const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.shadowMap.enabled = true;
renderer.shadowMap.type = THREE.PCFSoftShadowMap;
renderer.toneMapping = THREE.ACESFilmicToneMapping;
document.getElementById('demo-final').appendChild(renderer.domElement);

// 3. Controls
const controls = new OrbitControls(camera, renderer.domElement);
controls.enableDamping = true;
controls.dampingFactor = 0.05;
controls.enablePan = false;
controls.enableZoom = false;

// 4. Dramatic Lighting
const mainLight = new THREE.DirectionalLight(0x57B0FB, 3);
mainLight.position.set(5, 5, 2);
mainLight.castShadow = true;
scene.add(mainLight);

const backLight = new THREE.PointLight(0xFC5D7D, 3, 10);
backLight.position.set(-3, 1, -3);
scene.add(backLight);

// 5. Environment & Particles
const floor = new THREE.Mesh(
  new THREE.PlaneGeometry(20, 20),
  new THREE.MeshStandardMaterial({ color: 0x111111, roughness: 0.1, metalness: 0.8 })
);
floor.rotation.x = -Math.PI / 2;
floor.position.y = -1;
floor.receiveShadow = true;
scene.add(floor);

// 6. Load Model
let airplane;
new GLTFLoader().load('/models-three.js/small-airplane.glb', (gltf) => {
  airplane = gltf.scene;
  airplane.scale.set(0.6, 0.6, 0.6);
  airplane.traverse((child) => {
    if (child.isMesh) {
      child.castShadow = true;
      child.receiveShadow = true;
    }
  });
  scene.add(airplane);
});

// 7. Animation Loop
const clock = new THREE.Clock();
function animate() {
  requestAnimationFrame(animate);
  const time = clock.getElapsedTime();
  controls.update();

  if (airplane) {
    airplane.position.y = Math.sin(time * 1.5) * 0.2;
    airplane.rotation.z = Math.sin(time * 1) * 0.1;
  }

  renderer.render(scene, camera);
}
animate();`;
---

<ThreejsLayout
  title="GenesisPixel | Proyecto Final de Three.js "
  currentLesson="/threejs/proyecto-final"
  prevLesson={{ title: 'Escenas para producción', href: '/threejs/escenas-produccion' }}
  
>
  <ChapterHeader
    chapterNumber="05"
    chapterLabel="Capítulo 5 · Lección 15"
    title="Proyecto Final de Three.js"
    readingTime={12}
    difficulty="Three.js"
  />


  <article class="prose prose-invert max-w-none" style="margin-top: 64px;">
    <h3>La Graduación Inmersiva</h3>
    <p>Has recorrido un camino técnico fascinante. Aprendiste a invocar el mundo (Scene), a observarlo (Camera), a pintarlo (Renderer), y a llenarlo de esqueletos (Geometries) recubiertos de piel reactiva a la luz (Materials). Le diste movimiento con el tiempo y le otorgaste interactividad.</p>
    
    <h3>El Proyecto: La Base Espacial</h3>
    <p>Para tu proyecto final, vamos a unir todas las piezas. Construiremos una escena interactiva que podrías presentar como el Hero (portada principal) de un sitio web de vanguardia. Un pequeño avión en un entorno espacial que reacciona a los movimientos del ratón, con sombras, luces dramáticas y controles de cámara sutiles.</p>

    <h3>Requisitos del Proyecto</h3>
    <ul class="space-y-2 list-disc pl-6 mb-6">
      <li><strong>Arquitectura:</strong> Código organizado, con resize handler y un perfecto dispose en cleanup.</li>
      <li><strong>Escena Base:</strong> Renderer con antialiasing, píxel ratio dinámico, y fondos inmersivos.</li>
      <li><strong>Luces y Sombras:</strong> Un DirectionalLight con castShadow activado, iluminando suavemente a través del escenario.</li>
      <li><strong>Asset Externo:</strong> Uso de GLTFLoader para traer nuestro modelo <code>small-airplane.glb</code>.</li>
      <li><strong>Interacción Fluida:</strong> Uso de GSAP (opcional) y Delta Time para hacer flotar el avión con elegancia.</li>
    </ul>

    <h3>El Arte de lo Sutil</h3>
    <p>El error de los principiantes es hacer que la escena maree al usuario. Tu escena debe acompañar el diseño de la web, no secuestrarlo. Movimientos suaves, oscilaciones levitantes (Math.sin) e interactividad guiada son las claves de una experiencia premium.</p>
  </article>

  <h3 class="mb-8 mt-12 text-center font-medium text-[var(--color-text)]">
    El Resultado Esperado
  </h3>

  <div class="mb-6 flex flex-col gap-6 lg:flex-row">
    <TabbedCodeBlock
      group="proyecto-threejs"
      tabs={[
        { id: 'html', label: 'HTML', code: threejsHtml },
        { id: 'js', label: 'JavaScript', code: threejsJs },
      ]}
    />
    <ResultPreview description="Una experiencia de producción.">
      <div class="flex items-center justify-center h-full w-full bg-[#0a0a14] overflow-hidden rounded-none" id="demo-final" style="height: 500px;">
      </div>
    </ResultPreview>
  </div>

  <div class="my-8 flex flex-col gap-6">
    <PracticeCards
      title="El Reto Final"
      description="Construye tu propio ecosistema 3D en la plataforma."
      steps={[
        { number: 1, text: 'Instancia toda la base: Scene, PerspectiveCamera, y WebGLRenderer.', color: 'dm-purple', rotate: '-3deg' },
        { number: 2, text: 'Añade iluminación dramática y activa el soporte de sombras en el Renderer.', color: 'dm-green', rotate: '2deg' },
        { number: 3, text: 'Carga el modelo GLTF y sitúalo en el centro. Usa OrbitControls con enableDamping.', color: 'app-color-yellow400', rotate: '-5deg' },
        { number: 4, text: 'Implementa requestAnimationFrame usando Clock() para una rotación suave e infinita.', color: 'dm-blue', rotate: '3deg' },
      ]}
    />
  </div>

</ThreejsLayout>

<script>

  import * as THREE from 'three';
  import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';
  import { OrbitControls } from 'three/addons/controls/OrbitControls.js';

  document.addEventListener('astro:page-load', () => {
    const container = document.getElementById('demo-final');
    if (!container) return;
    
    while(container.firstChild) container.removeChild(container.firstChild);

    // 1. Scene
    const scene = new THREE.Scene();
    scene.fog = new THREE.FogExp2('#0a0a14', 0.05);

    // 2. Camera
    const camera = new THREE.PerspectiveCamera(45, container.clientWidth / container.clientHeight, 0.1, 100);
    camera.position.set(3, 2, 6);

    // 3. Renderer (Premium Setup)
    const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setSize(container.clientWidth, container.clientHeight);
    renderer.shadowMap.enabled = true;
    renderer.shadowMap.type = THREE.PCFSoftShadowMap;
    renderer.toneMapping = THREE.ACESFilmicToneMapping; // Colores más realistas
    container.appendChild(renderer.domElement);

    // 4. Controles (restringidos)
    const controls = new OrbitControls(camera, renderer.domElement);
    controls.enableDamping = true;
    controls.dampingFactor = 0.05;
    controls.enablePan = false;
    controls.enableZoom = false; // Bloqueamos zoom para no interferir con scroll web
    controls.minPolarAngle = Math.PI / 4;
    controls.maxPolarAngle = Math.PI / 2 + 0.1;

    // 5. Luces dramáticas
    const ambientLight = new THREE.AmbientLight(0xffffff, 0.5);
    scene.add(ambientLight);

    const mainLight = new THREE.DirectionalLight(0x57B0FB, 3);
    mainLight.position.set(5, 5, 2);
    mainLight.castShadow = true;
    mainLight.shadow.mapSize.width = 1024;
    mainLight.shadow.mapSize.height = 1024;
    scene.add(mainLight);

    const backLight = new THREE.PointLight(0xFC5D7D, 3, 10);
    backLight.position.set(-3, 1, -3);
    scene.add(backLight);

    // 6. Entorno (Suelo)
    const floorGeo = new THREE.PlaneGeometry(20, 20);
    const floorMat = new THREE.MeshStandardMaterial({ 
      color: 0x111111, 
      roughness: 0.1, 
      metalness: 0.8 
    });
    const floor = new THREE.Mesh(floorGeo, floorMat);
    floor.rotation.x = -Math.PI / 2;
    floor.position.y = -1;
    floor.receiveShadow = true;
    scene.add(floor);

    // 7. Partículas (Estrellas / Polvo)
    const particlesGeo = new THREE.BufferGeometry();
    const particlesCount = 200;
    const posArray = new Float32Array(particlesCount * 3);
    
    for(let i = 0; i < particlesCount * 3; i++) {
      posArray[i] = (Math.random() - 0.5) * 15;
    }
    particlesGeo.setAttribute('position', new THREE.BufferAttribute(posArray, 3));
    
    const particlesMat = new THREE.PointsMaterial({
      size: 0.05,
      color: 0x9FA6FF,
      transparent: true,
      opacity: 0.8
    });
    const particlesMesh = new THREE.Points(particlesGeo, particlesMat);
    scene.add(particlesMesh);

    // 8. Cargar el Modelo
    let airplane;
    const loader = new GLTFLoader();
    
    loader.load('/models-three.js/small-airplane.glb', (gltf) => {
      airplane = gltf.scene;
      airplane.scale.set(0.6, 0.6, 0.6);
      
      // Aseguramos que los meshes del modelo proyecten sombras
      airplane.traverse((child) => {
        if (child.isMesh) {
          child.castShadow = true;
          child.receiveShadow = true;
        }
      });
      
      scene.add(airplane);
    });

    // 9. Bucle de Animación y Reloj
    const clock = new THREE.Clock();
    let animationId;
    let mouseX = 0;
    let mouseY = 0;

    // Efecto Parallax con el ratón
    const onMouseMove = (event) => {
      mouseX = (event.clientX / window.innerWidth) * 2 - 1;
      mouseY = -(event.clientY / window.innerHeight) * 2 + 1;
    };
    container.addEventListener('mousemove', onMouseMove);

    const animate = () => {
      animationId = requestAnimationFrame(animate);
      const time = clock.getElapsedTime();

      controls.update();

      // Animamos el avión suavemente
      if (airplane) {
        // Levitación
        airplane.position.y = Math.sin(time * 1.5) * 0.2;
        // Inclinación
        airplane.rotation.z = Math.sin(time * 1) * 0.1;
        
        // Reacción al ratón sutil
        airplane.rotation.x = THREE.MathUtils.lerp(airplane.rotation.x, mouseY * 0.2, 0.05);
        airplane.rotation.y = THREE.MathUtils.lerp(airplane.rotation.y, mouseX * 0.3, 0.05);
      }

      // Animamos las partículas
      particlesMesh.rotation.y = time * 0.05;

      renderer.render(scene, camera);
    };
    animate();

    // 10. Gestión de Resize
    const handleResize = () => {
      camera.aspect = container.clientWidth / container.clientHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(container.clientWidth, container.clientHeight);
    };
    window.addEventListener('resize', handleResize);

    // 11. Limpieza Profesional (Dispose)
    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(animationId);
      window.removeEventListener('resize', handleResize);
      container.removeEventListener('mousemove', onMouseMove);
      
      // Cleanup de geometría y materiales
      scene.traverse((child) => {
        if (child.isMesh || child.isPoints) {
          child.geometry.dispose();
          if (Array.isArray(child.material)) {
            child.material.forEach(mat => mat.dispose());
          } else {
            child.material.dispose();
          }
        }
      });
      
      controls.dispose();
      renderer.dispose();
    }, { once: true });
  });

</script>
