---
import TransitionsLayout from '../../layouts/TransitionsLayout.astro';
import ChapterHeader from '../../components/ChapterHeader.astro';
import TabbedCodeBlock from '../../components/TabbedCodeBlock.astro';
import ResultPreview from '../../components/ResultPreview.astro';
import ConsejoProfesional from '../../components/ConsejoProfesional.astro';
import ErroresComunesV3 from '../../components/ErroresComunesV3.astro';
import PracticeCards from '../../components/PracticeCards.astro';

const htmlCode = `<div class="system-demo">
  <button class="btn">Botón Principal</button>
  <input type="text" class="input" placeholder="Campo de texto" />
  <div class="tag">Etiqueta</div>
</div>

<style>
  .system-demo {
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: center;
  }
</style>`;

const cssCode = `:root {
  /* Motion Design Tokens */
  --dur-fast: 0.15s;
  --dur-base: 0.3s;
  --dur-slow: 0.5s;
  
  --ease-in-out: cubic-bezier(0.4, 0, 0.2, 1);
  --ease-out: cubic-bezier(0, 0, 0.2, 1);
  --ease-bounce: cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

.btn {
  padding: 12px 24px;
  background: #a855f7;
  color: #0f172a;
  border: none;
  border-radius: 0;
  font-weight: bold;
  font-family: 'afronaut', serif;
  cursor: pointer;
  transition: transform var(--dur-fast) var(--ease-bounce),
              background var(--dur-fast) var(--ease-out);
}

.btn:hover {
  background: #c084fc;
  transform: scale(1.05);
}

.input {
  padding: 10px 12px;
  background: #18181b;
  border: 1px solid #3f3f46;
  border-radius: 0;
  color: white;
  font-family: 'afronaut', serif;
  outline: none;
  transition: border-color var(--dur-base) var(--ease-out);
}

.input:focus {
  border-color: #a855f7;
}

.tag {
  padding: 6px 12px;
  background: rgba(255,255,255,0.1);
  border: 1px dashed rgba(255,255,255,0.3);
  border-radius: 0;
  color: white;
  font-family: 'afronaut', serif;
  font-weight: 300;
  cursor: pointer;
  transition: all var(--dur-fast) var(--ease-in-out);
}

.tag:hover {
  background: rgba(255,255,255,0.2);
}`;

const practiceSteps = [
  { number: 1, text: 'Extrae tus duraciones comunes (150ms, 300ms) a variables CSS.', color: 'dm-purple', rotate: '10deg' },
  { number: 2, text: 'Extrae tus curvas de Bezier favoritas a variables.', color: 'dm-green', rotate: '2deg' },
  { number: 3, text: 'Usa estas variables en todos los componentes de tu proyecto.', color: 'app-color-yellow400', rotate: '-5deg' },
  { number: 4, text: 'Si un día quieres que la app se sienta "más rápida", solo cambias las variables base.', color: 'dm-blue', rotate: '2deg' },
  { number: 5, text: 'A esto se le llama un "Motion Design System".', color: 'dm-red', rotate: '-5deg' },
];
---

<TransitionsLayout
  title="GenesisPixel | Sistema consistente de UI "
  currentLesson="/transitions/sistema-consistente"
  prevLesson={{ title: 'Transiciones combinadas', href: '/transitions/transiciones-combinadas' }}
  nextLesson={{ title: 'Proyecto final', href: '/transitions/proyecto-final' }}
>
  <ChapterHeader
    chapterNumber="03"
    chapterLabel="Capítulo 3 · Lección 14"
    title="Sistema Consistente de UI"
    readingTime={5}
    difficulty="CSS Transitions"
  />

  <article class="prose prose-invert max-w-none" style="margin-top: 64px;">
    <h3>El problema de los números mágicos</h3>
    <p>
      A medida que tu proyecto web crece, tendrás docenas de botones, tarjetas, inputs y modales. Si en cada uno de ellos te pones a escribir duraciones aleatorias (<code>0.2s</code> aquí, <code>0.35s</code> allá, <code>ease</code> acá, <code>linear</code> en otro lado), tu web terminará pareciendo un parque de diversiones caótico.
      No habrá consistencia. Tu marca no tendrá una "identidad de movimiento".
    </p>

    <h3>Motion Tokens</h3>
    <p>
      Al igual que guardamos nuestra paleta de colores en Variables CSS (Design Tokens), debemos hacer lo mismo con nuestras reglas de animación (Motion Tokens).
      Definiremos una escala de duraciones y una paleta de curvas (easing).
    </p>

    <div class="my-6">
      <TabbedCodeBlock group="duration-scale" tabs={[{ id: 'css', label: 'CSS', code: `/* Ejemplo de una escala profesional */
--duration-fast: 150ms;   /* Microinteracciones, hovers simples */
--duration-normal: 300ms; /* Desplegables, menús, estados focales */
--duration-slow: 500ms;   /* Transiciones de página, modales grandes */` }]} />
    </div>
  </article>

  <div class="not-prose">
      <ConsejoProfesional tip="Frameworks modernos como Tailwind CSS incluyen un sistema de escalas por defecto (clases como duration-300 o ease-in-out). Usa esos tokens de diseño para no reinventar la rueda." />
    </div>

  <h3 class="mb-8 mt-12 text-center font-medium text-[var(--color-text)]">
    Ejemplo práctico
  </h3>

  <div class="mb-6 flex flex-col gap-6 lg:flex-row">
    <TabbedCodeBlock
      group="example"
      tabs={[
        { id: 'html', label: 'HTML', code: htmlCode },
        { id: 'css', label: 'CSS', code: cssCode },
      ]}
    />
    <ResultPreview description="Todos los elementos de este contenedor están sincronizados usando variables. Si hiciéramos un cambio global, todos responderían al unísono manteniendo la armonía en toda la página.">
      <div style="display: flex; gap: 16px; justify-content: center; align-items: center; height: 100%; flex-wrap: wrap; padding: 20px;">
        <style>
          .t-sys { --d-fast: 0.15s; --d-base: 0.3s; --e-out: cubic-bezier(0, 0, 0.2, 1); --e-bounce: cubic-bezier(0.68, -0.55, 0.265, 1.55); }
          .t-sys-btn { padding: 10px 20px; background: #a855f7; color: #0f172a; border: none; border-radius: 0; font-weight: bold; font-family: 'afronaut', serif; cursor: pointer; transition: transform var(--d-fast) var(--e-bounce), background var(--d-fast) var(--e-out); }
          .t-sys-btn:hover { background: #c084fc; transform: scale(1.05); }
          .t-sys-input { padding: 10px 12px; background: #18181b; border: 1px solid #3f3f46; border-radius: 0; color: white; font-family: 'afronaut', serif; outline: none; transition: border-color var(--d-base) var(--e-out); }
          .t-sys-input:focus { border-color: #a855f7; }
          .t-sys-tag { padding: 6px 12px; background: rgba(255,255,255,0.1); border: 1px dashed rgba(255,255,255,0.3); border-radius: 0; color: white; font-family: 'afronaut', serif; font-weight: 300; cursor: pointer; transition: all var(--d-fast) var(--e-out); }
          .t-sys-tag:hover { background: rgba(255,255,255,0.2); }
        </style>
        <div class="t-sys" style="display: flex; flex-direction: column; gap: 16px; align-items: center;">
          <button class="t-sys-btn">Botón Principal</button>
          <input type="text" class="t-sys-input" placeholder="Campo de texto" />
          <div class="t-sys-tag">Etiqueta</div>
        </div>
      </div>
    </ResultPreview>
  </div>

  

  <div class="my-8 flex flex-col gap-6">
    <ErroresComunesV3 errors={[
      { label: 'Valores quemados (Hardcoded)', description: 'Escribir 0.28s en diferentes archivos de manera manual. Usa variables para que los cambios sean escalables a nivel de sistema.' },
      { label: 'Variables excesivamente complejas', description: 'Tener --duration-200, --duration-250, --duration-300. Demasiadas opciones derrotan el propósito del sistema. Limítate a rápido, base y lento.' }
    ]} />
    <PracticeCards
      title="Practica lo Aprendido"
      description="Audita tu código actual y reemplaza todos los tiempos estáticos por variables CSS."
      steps={practiceSteps}
    />
  </div>
</TransitionsLayout>

<script>
  import { initCodeInteractions } from '../../scripts/code-interactions.js';
  document.addEventListener('astro:page-load', () => initCodeInteractions());
  document.addEventListener('astro:after-swap', () => initCodeInteractions());
</script>
