---
import TransitionsLayout from '../../layouts/TransitionsLayout.astro';
import ChapterHeader from '../../components/ChapterHeader.astro';
import TabbedCodeBlock from '../../components/TabbedCodeBlock.astro';
import ResultPreview from '../../components/ResultPreview.astro';
import ConsejoProfesional from '../../components/ConsejoProfesional.astro';
import ErroresComunesV3 from '../../components/ErroresComunesV3.astro';
import PracticeCards from '../../components/PracticeCards.astro';

const htmlCode = `<button class="download-btn">
  <span class="icon">⬇</span>
  Descargar
</button>`;

const cssCode = `.download-btn {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 12px 24px;
  background: #a855f7;
  color: #0f172a;
  border: none;
  border-radius: 0;
  cursor: pointer;
  font-weight: bold;
  font-family: 'afronaut', serif;
  
  /* Transicionamos el color de fondo y una ligera elevación */
  transition: transform 0.2s ease, background 0.2s ease;
}

.icon {
  display: inline-block;
  /* El icono responderá con una curva de rebote distinta al botón */
  transition: transform 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

.download-btn:hover {
  background: #06b6d4;
  transform: translateY(-2px);
}

/* Solo animamos el icono cuando el contenedor tiene hover */
.download-btn:hover .icon {
  transform: translateY(4px);
}`;

const practiceSteps = [
  { number: 1, text: 'Asigna duraciones distintas a diferentes propiedades separándolas por comas.', color: 'dm-purple', rotate: '10deg' },
  { number: 2, text: 'Para que se sienta orgánico, no todas las partes de tu UI deben durar lo mismo.', color: 'dm-green', rotate: '2deg' },
  { number: 3, text: 'Aplica una transición rápida al background y lenta al icono.', color: 'app-color-yellow400', rotate: '-5deg' },
  { number: 4, text: 'Combina transform: translateY para crear un efecto de gravedad en la flecha.', color: 'dm-blue', rotate: '2deg' },
  { number: 5, text: 'Lograrás que el componente parezca vivo y compuesto de varias piezas.', color: 'dm-red', rotate: '-5deg' },
];
---

<TransitionsLayout
  title="Transiciones combinadas - Genesis Pixel"
  currentLesson="/transitions/transiciones-combinadas"
  prevLesson={{ title: 'Microinteracciones', href: '/transitions/microinteracciones' }}
  nextLesson={{ title: 'Sistema consistente de UI', href: '/transitions/sistema-consistente' }}
>
  <ChapterHeader
    chapterNumber="03"
    chapterLabel="Capítulo 3 · Lección 13"
    title="Transiciones Combinadas Avanzadas"
    readingTime={5}
  />

  <article class="prose prose-invert max-w-none" style="margin-top: 64px;">
    <h3>Orquestando el caos</h3>
    <p>
      Hasta ahora hemos sido simples: <code>transition: all 0.3s ease</code>. Pero en las interfaces de más alto nivel (como Apple, Stripe, o Vercel), rara vez verás que todo cambie al mismo tiempo y a la misma velocidad. La clave del "Motion Design" premium está en la <strong>combinación y sincronización de múltiples transiciones</strong> con valores distintos.
    </p>

    <h3>Desacoplando propiedades</h3>
    <p>
      Un elemento puede desvanecerse (opacity) en 0.2s, pero escalar (transform) en 0.6s con rebote. El usuario no percibe la matemática, pero su cerebro percibe algo que se siente suave y físico.
    </p>
    <div class="bg-black/30 p-4 rounded-lg my-4 font-mono text-sm border border-white/10">
      transition: opacity 0.2s linear, transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
    </div>

    <h3>Movimientos opuestos</h3>
    <p>
      Otra técnica fascinante es hacer que el contenedor principal se mueva hacia arriba, pero un elemento hijo (como un ícono) se mueva hacia abajo. Esto genera una sensación de inercia o peso, ideal para botones de descarga o envío.
    </p>
  </article>

  <div class="not-prose">
      <ConsejoProfesional tip="Al combinar múltiples valores largos separados por comas, tu CSS puede volverse ilegible. Aprovecha las variables CSS (Custom Properties) para almacenar tus curvas de Bezier favoritas." />
    </div>

  <h3 class="mb-8 mt-12 text-center font-medium text-[var(--color-text)]">
    Ejemplo práctico (Efecto Inercia)
  </h3>

  <div class="mb-6 flex flex-col gap-6 lg:flex-row">
    <TabbedCodeBlock
      group="example"
      tabs={[
        { id: 'html', label: 'HTML', code: htmlCode },
        { id: 'css', label: 'CSS', code: cssCode },
      ]}
    />
    <ResultPreview description="Haz hover. El botón sube ligeramente de forma rápida. Sin embargo, la flecha de descarga baja bruscamente y rebota con una curva elástica.">
      <div style="display: flex; justify-content: center; align-items: center; height: 100%;">
        <style>
          .t-down-btn { display: flex; align-items: center; gap: 8px; padding: 12px 24px; background: #a855f7; color: #0f172a; border: none; border-radius: 0; cursor: pointer; font-weight: bold; font-family: 'afronaut', serif; transition: transform 0.2s ease, background 0.2s ease; font-size: 16px; }
          .t-down-icon { display: inline-block; font-size: 18px; transition: transform 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55); }
          .t-down-btn:hover { background: #06b6d4; transform: translateY(-2px); }
          .t-down-btn:hover .t-down-icon { transform: translateY(4px); }
        </style>
        <button class="t-down-btn">
          <span class="t-down-icon">⬇</span>
          Descargar
        </button>
      </div>
    </ResultPreview>
  </div>

  

  <div class="my-8 flex flex-col gap-6">
    <ErroresComunesV3 errors={[
      { label: 'Exagerar con las combinaciones', description: 'Si un botón se mueve, cambia de color, escala, brilla y da vueltas a la vez, se sentirá caricaturesco, no premium. Mantén las coreografías sutiles.' },
      { label: 'Descoordinación temporal', description: 'Asegúrate de que la suma de delays y duraciones de los elementos combinados no exceda un límite razonable (como 0.5s) para que se sienta como una sola acción fluida.' }
    ]} />
    <PracticeCards
      title="Practica lo Aprendido"
      description="Genera inercia y movimiento secundario en tus elementos de acción."
      steps={practiceSteps}
    />
  </div>
</TransitionsLayout>

<script>
  import { initCodeInteractions } from '../../scripts/code-interactions.js';
  document.addEventListener('astro:page-load', () => initCodeInteractions());
  document.addEventListener('astro:after-swap', () => initCodeInteractions());
</script>
